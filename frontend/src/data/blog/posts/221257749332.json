  "body": "<div id=\"post-view221257749332\" class=\" pcol2 _param(1) _postViewArea221257749332\">\n\t\t\t\t\t\t\t<div style=\"font-size:10pt; font-family:'957317_10';\" class=\"view\"><div id=\"SEDOC-1524471394557--536156952\" class=\"se_doc_viewer se_body_wrap se_theme_transparent \" data-docversion=\"1.0\">\n<div class=\"se_doc_header_start\" id=\"SEDOC-1524471394557--536156952_se_doc_header_start\"></div>\n<!-- SE_DOC_HEADER_START -->\n<div id=\"SEDOC-1524471394557--536156952_viewer_head\" class=\"se_viewer_head\"></div>\n<div class=\"se_component_wrap\">\n<div class=\"se_component se_documentTitle documentTitle_blog  is-fill\">\n    <div class=\"se_sectionArea is-fill se_align-left\">\n        <!-- --> \n<div class=\"blog2_series\">\n\t<a href=\"/PostList.naver?blogId=isuhani&categoryNo=7&from=postList&parentCategoryNo=7\" class=\"pcol2\" onclick=\"sendClickNlog('pst.category','');\">체형척추관절통증</a>\n</div>\n<div class=\"pcol1\"> \n<!--\n -->\n        <!-- SE_DOC_HEADER_TITLE_TOP-->\n     \t<div id=\"SEDOC-1524471394557--536156952_se_doc_title_top\" class=\"se_doc_title_top\"></div>\n        <div class=\"se_editArea\">\n        \t<div class=\"se_viewArea se_ff_nanumgothic se_fs_D2\">\n\t            <div class=\"se_editView se_title\">\n\t                <div class=\"se_textView\">\n                        <h3 class=\"se_textarea\">\n                            <!-- -->adrenal fatigue : 부신피로(부신 스트레스 장애)에 대하여 [남성역한의원 이수한의원]<!-- -->\n                            \n                        </h3>\n                        \n                        \n\t                </div>\n\t            </div>\n\t        </div>\n        </div><!-- SE_DOC_HEADER_TITLE_MIDDLE-->\n        <div id=\"SEDOC-1524471394557--536156952_se_doc_title_middle\" class=\"se_doc_title_middle\"></div>\n        <!-- SE_DOC_HEADER_CONTENTS_START -->\n        <!-- -->\n</div>\n<div class=\"blog2_container\">\n    <span class=\"writer\">\n        <span class=\"area_profile\"><a href=\"https://blog.naver.com/isuhani\" class=\"link\" onclick=\"sendClickNlog('pst.profile', '');\" target=\"_top\"><img src=\"https://blogpfthumb-phinf.pstatic.net/MjAyMzA2MjRfMjk2/MDAxNjg3NTg2MTc2NTc2.yKTPcF6FagHJrdvFPFcT4RgC-X3It5WmAiFESzLPWtQg.wTXTu1jAosaSi3b25IpUXH_ybNKgCPSu-BNVXK7rk1Eg.JPEG.isuhani/%EB%AC%B8%ED%95%99%EC%A7%84%EC%9B%90%EC%9E%A5%EB%8B%98_%EB%B8%94%EB%A1%9C%EA%B7%B8_%ED%94%84%EB%A1%9C%ED%95%84.jpg/%25E1%2584%2586%25E1%2585%25AE%25E1%2586%25AB%25E1%2584%2592%25E1%2585%25A1%25E1%2586%25A8%25E1%2584%258C%25E1%2585%25B5%25E1%2586%25AB%25E1%2584%258B%25E1%2585%25AF%25E1%2586%25AB%25E1%2584%258C%25E1%2585%25A1%25E1%2586%25BC%25E1%2584%2582%25E1%2585%25B5%25E1%2586%25B7_%25E1%2584%2587%25E1%2585%25B3%25E1%2586%25AF%25E1%2584%2585%25E1%2585%25A9%25E1%2584%2580%25E1%2585%25B3_%25E1%2584%2591%25E1%2585%25B3%25E1%2584%2585%25E1%2585%25A9%25E1%2584%2591%25E1%2585%25B5%25E1%2586%25AF.jpg?type=s1\" class=\"img\" alt=\"프로파일\"></a></span>\n        <span class=\"nick\"><a href=\"https://blog.naver.com/isuhani\" class=\"link pcol2\" onclick=\"sendClickNlog('pst.username', '');\" target=\"_top\">문학진 나효석 원장</a></span>\n        <span class=\"desc\">\n            <i class=\"dot\"> ・ </i>\n            <span class=\"se_publishDate pcol2\">2018. 4. 20. 21:22</span>\n        </span>\n    </span>\n\n</div>\n<div class=\"blog2_post_function\">\n\t<a href=\"#\" id=\"copyBtn_221257749332\" class=\"url pcol2 _setClipboard _returnFalse _se3copybtn _transPosition\" title=\"https://blog.naver.com/isuhani/221257749332\" style=\"cursor:pointer;\" >URL 복사</a>\n\n            <a href=\"#\" class=\"btn_buddy btn_addbuddy pcol2 _buddy_popup_btn _returnFalse _rosRestrictAll\" onclick=\"sendClickNlog('pst.addnei', '');\"><i class=\"ico\"></i> 이웃추가<i class=\"aline\"></i></a>\n\t<div class=\"overflow_menu\" >\n        <a href=\"#\" class=\"btn_overflow_menu _open_overflowmenu pcol2 _param(221257749332) _returnFalse\" role=\"button\" area-haspopup=\"true\" area-expanded=\"false\"><span class=\"blind\">본문 기타 기능</span></a>\n\t\t<div id=\"overflowmenu-221257749332\" class=\"lyr_overflow_menu _overflowmenu_layer\" area-hidden=\"true\">\n               <a href=\"#\" onclick=\"window.nsc='blog.post';return false;\" id=\"_title_spiButton\" class=\"naver-splugin btn_splugin share _title_share\"\n                  data-style=\"unity\"\n                  data-url=\"https://blog.naver.com/isuhani/221257749332\"\n                  data-oninitialize=\"splugin_oninitialize(1);\"\n                  data-me-display=\"off\"\n                  data-likeServiceId=\"BLOG\"\n                  data-likeContentsId=\"isuhani_221257749332\"\n                  data-spic-cid=\"221257749332\"\n                  data-logDomain=\"https://proxy.blog.naver.com/spi/v1/api/shareLog\"\n                  data-canonical-url=\"https://blog.naver.com/isuhani/221257749332\"\n                  data-option=\"{baseElement:'_title_spiButton', layerPosition:'outside-bottom', align:'right', marginLeft:0, marginTop:4}\">\n                   공유하기\n                <span class=\"ico_share _title_share_icon\"></span>\n               </a>\n                <a href=\"#\" class=\"_report _param(https://srp2.naver.com/report?svc=BLG&exit=close&ctype=AA01&cwriterenc=EEwYsJMirKJ5NiZtd4lfvmPsHZqR2YqNdqJDSFZlFvU%3D&ctitle=adrenal%20fatigue%20%3A%20%EB%B6%80%EC%8B%A0%ED%94%BC%EB%A1%9C(%EB%B6%80%EC%8B%A0%20%EC%8A%A4%ED%8A%B8%EB%A0%88%EC%8A%A4%20%EC%9E%A5%EC%95%A0)%EC%97%90%20%EB%8C%80%ED%95%98%EC%97%AC%20%5B%EB%82%A8%EC%84%B1%EC%97%AD%ED%95%9C%EC%9D%98%EC%9B%90%20%EC%9D%B4%EC%88%98%ED%95%9C%EC%9D%98%EC%9B%90%5D&cwriter=isuh***&dark=disable&memtype=Y&env=pc&cnickname=isuh***&vsvc=BLG&cid=isuhani%40%4049462061%40%40mylog%40%40221257749332) _returnFalse\">신고하기<span class=\"ico_report\"></span></a>\n\t\t</div>\n\t</div>\n    <input type=\"text\" value=\"https://blog.naver.com/isuhani/221257749332\" alt=\"url\" class=\"copyTargetUrl\" style=\"display:none;\" title=\"URL 복사\">\n</div>\n<!--\n -->\n        <!-- SE_DOC_HEADER_CONTENTS_END -->\n        <!-- SE_DOC_HEADER_TITLE_BOTTOM-->\n        <div id=\"SEDOC-1524471394557--536156952_se_doc_title_bottom\" class=\"se_doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1524471394557--536156952_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1524471394557--536156952_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->부신은 스트레스와 밀접한 관련이 있는 내분비기관입니다. 양쪽 신장(kidney)의 위쪽에 붙어있는 부신은&nbsp;내부나 외부에서 오는 여러 종류의 스트레스에 대한 반응을 유발시키고 지시하는 역할을 합니다. 부신에서는&nbsp;항스트레스호르몬인 코티졸(cortisol)을 생산해서 분비하는데, 코티솔의 양이 부족하게 되면 우리 몸은 각종 스트레스에 저항하는 힘이 약해지게 되어 무기력해지게 됩니다. 이러한&nbsp;부신기능의 저하는 전신상태에도 영향을 미치게 되어 공포, 불안, 우울, 무기력증을 보이고 집중력장애와 단기 기억력쇠퇴를 유발하기도 합니다.&nbsp;우리몸을 만성피로의 상태로 몰고 갑니다.<!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1524471394557--536156952_image_0_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODA0MjBfMTU0/MDAxNTI0MjI2NjUxMjQ0.nC4xN7s7l1wH0fUIWFWPxKI1NpDU3jLIj1WMf-Gdy44g.ufxIH10vIDhhi4VRyLJYR5Fss4ykVB59rDeksjEHkHcg.JPEG.isuhani/adrenal-alarm-state.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1524471394557--536156952_image_0_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODA0MjBfMTU0/MDAxNTI0MjI2NjUxMjQ0.nC4xN7s7l1wH0fUIWFWPxKI1NpDU3jLIj1WMf-Gdy44g.ufxIH10vIDhhi4VRyLJYR5Fss4ykVB59rDeksjEHkHcg.JPEG.isuhani/adrenal-alarm-state.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODA0MjBfMTU0/MDAxNTI0MjI2NjUxMjQ0.nC4xN7s7l1wH0fUIWFWPxKI1NpDU3jLIj1WMf-Gdy44g.ufxIH10vIDhhi4VRyLJYR5Fss4ykVB59rDeksjEHkHcg.JPEG.isuhani/adrenal-alarm-state.jpg?type=w580\" data-width=\"525\" data-height=\"669\" width=\"525\" height=\"669\" data-attachment-id=\"IOrsBKUg_G_SxCI8dbPp7Je1P9CQ\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>우리가 스트레스에 노출되면 부신은 그 스트레스에 반응하여 과항진됩니다. 코티솔을 많이 생산하고 과량을&nbsp;분비하게 되죠. 이 단계를 스트레스의 경고기(alarm stage)라고 합니다. <br></span><span>스트레스가 단기간에 해소되지 않고 계속 이어지게되면 부신의 기능은 항진과 저하를 반복하는 경향을 보이게 되는데, 이 시기를&nbsp;저항기(resistance stage)라고 합니다. <br></span><span>만성적인 스트레스는 부신의 기능저하를 초래하고 부신에서의 코</span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>티솔 생산과 분비가 저하되어 체내 코티솔 양이 고갈되게 됩니다. 고갈기(exhaustion stage)라 부르는 이 단계가 되면 신체는 내부적, 외부적인 스트레스에 대응하지 못하게 됩니다.&nbsp;<br></span><span><br></span><span>&nbsp;<br></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-left\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:297px\">\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1524471394557--536156952_image_1_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODA0MjBfNzkg/MDAxNTI0MjI2Njc2OTMw.lUYAA2MlhmrRNY28dxSLsu5sA209aaBSV_IUw-1Ehhgg.GGqSEdYdt1KeDmdQLYCuZGeNH5mf-IFmhaq45A8Ldc0g.JPEG.isuhani/B0FAC0CF%C4%AEB7%CE%B8AE.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1524471394557--536156952_image_1_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODA0MjBfNzkg/MDAxNTI0MjI2Njc2OTMw.lUYAA2MlhmrRNY28dxSLsu5sA209aaBSV_IUw-1Ehhgg.GGqSEdYdt1KeDmdQLYCuZGeNH5mf-IFmhaq45A8Ldc0g.JPEG.isuhani/B0FAC0CF%C4%AEB7%CE%B8AE.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODA0MjBfNzkg/MDAxNTI0MjI2Njc2OTMw.lUYAA2MlhmrRNY28dxSLsu5sA209aaBSV_IUw-1Ehhgg.GGqSEdYdt1KeDmdQLYCuZGeNH5mf-IFmhaq45A8Ldc0g.JPEG.isuhani/B0FAC0CF%C4%AEB7%CE%B8AE.jpg?type=w580\" data-width=\"297\" data-height=\"170\" width=\"297\" height=\"170\" data-attachment-id=\"IbnLlEHphZoW8qb2d56O2LlajoDo\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>스트레스의 종류는 크게 4가지로 나눌 수 있겠습니다. <br></span><span>1. 신체적인 스트레스 : 장기간의 일, 심한 육체적 노동, 수면부족, 자세나 신체구조의 긴장(왜곡-비틀림) 등이 이에 속합니다. 외상도 신체적 스트레스에 속합니다. <br></span><span><br></span><span>2. 화학적인 스트레스 : 불균형적인 음식섭취. 과도하게 정제된 음식. 커피, 차, 콜라, 초콜릿, 니코틴, 알코올, 다양한 약물들이 우리 몸에 화학적인 스트레스를 줍니다. 색소, 첨가제, 인공 설탕, 살충제, 각종 폐기물, 농약, 화학비료, 다양한 종류의 화학가스도 해당되죠. 고산병의 원인이기도 한 산소부족도 우리몸에는 화학적인 스트레스를 줍니다. <br></span><span><br></span><span>3. 온도 스트레스 : 너무 뜨겁거나 너무 추우면 우리 몸에 온도 스트레스를 줍니다. 에어컨에 계속 노출되는 환경에서 지내는 사람, 음식 냉장고 안을 들락거려야 하는 사람도 온도 스트레스를 받죠. <br></span><span><br></span><span>4, 감정적인 스트레스 : 치료하기 가장 힘든 범주의 스트레스입니다. 사랑하는 사람의 죽음이나 병환, 개인적인 채무관계, 경제적 곤궁 등 사람의 마음을 힘들게(슬픔, 분노, 우울 등 종류와 상관없이 '힘들게')하는 감정들은 모두 스트레스가 됩니다. <br></span><span><br></span><span>현대 사회에서는 장기간의 끊이지 않는 감정적, 화학적 스트레스로 인해 부신 기능이 회복될 수 있는 기회를 주지 않는 경향이 있습니다. </span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-left\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:203px\">\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1524471394557--536156952_image_2_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODA0MjBfMjM3/MDAxNTI0MjI2NjkwMTIw.kRWriiaRwgKvBFhVYTgYGOWoERDAHxxZ6YqwpPY_Pr8g.Z3S91_u0ad7FIeJ5j_IXTxbO0DHrVBCYNV6UbTqYrVEg.JPEG.isuhani/%EB%8B%A4%EC%9A%B4%EB%A1%9C%EB%93%9C_%2825%29.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1524471394557--536156952_image_2_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODA0MjBfMjM3/MDAxNTI0MjI2NjkwMTIw.kRWriiaRwgKvBFhVYTgYGOWoERDAHxxZ6YqwpPY_Pr8g.Z3S91_u0ad7FIeJ5j_IXTxbO0DHrVBCYNV6UbTqYrVEg.JPEG.isuhani/%EB%8B%A4%EC%9A%B4%EB%A1%9C%EB%93%9C_%2825%29.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODA0MjBfMjM3/MDAxNTI0MjI2NjkwMTIw.kRWriiaRwgKvBFhVYTgYGOWoERDAHxxZ6YqwpPY_Pr8g.Z3S91_u0ad7FIeJ5j_IXTxbO0DHrVBCYNV6UbTqYrVEg.JPEG.isuhani/%EB%8B%A4%EC%9A%B4%EB%A1%9C%EB%93%9C_%2825%29.jpg?type=w580\" data-width=\"203\" data-height=\"248\" width=\"203\" height=\"248\" data-attachment-id=\"IgfX5Bx_KVb8f1-_Wi4Cu4qM468Q\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>부신기능저하 시 나타나는 특징들을 살펴보겠습니다. </span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>1. 다양한 근육들의 압통이 심해집니다(우리 몸 여기저기를 누르면 통증을 심하게 느끼게 됩니다)<br></span><span>2. 기립성 현훈(앉아있다가 갑자기 일어설 때 생기는 어지럼증)을 유발합니다. <br></span><span>3. 체내수분이 부족해지면서 입안이 건조해지기도 합니다<br></span><span>4. 전중혈(가슴뼈 가운데)를 누르면 매우 아픈 반응이 나타납니다<br></span><span>5. 만성적인 피로감을 느끼게 됩니다. <br></span><span>6. 하체의 자세유지와 보행 등을 위한 근육이 약해진다. <br></span><span><br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-left\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:224px\">\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1524471394557--536156952_image_3_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODA0MjBfNjMg/MDAxNTI0MjI2NzI4OTk3.LM7hj8lXIGPzXMuhem18uSYZHUXDkogzjMQwspCg15cg.-nGoLhtNgQBFHrNxSKUrsJGHw9OxwLB0KxRoHKkbYxQg.JPEG.isuhani/images_%2821%29.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1524471394557--536156952_image_3_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODA0MjBfNjMg/MDAxNTI0MjI2NzI4OTk3.LM7hj8lXIGPzXMuhem18uSYZHUXDkogzjMQwspCg15cg.-nGoLhtNgQBFHrNxSKUrsJGHw9OxwLB0KxRoHKkbYxQg.JPEG.isuhani/images_%2821%29.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODA0MjBfNjMg/MDAxNTI0MjI2NzI4OTk3.LM7hj8lXIGPzXMuhem18uSYZHUXDkogzjMQwspCg15cg.-nGoLhtNgQBFHrNxSKUrsJGHw9OxwLB0KxRoHKkbYxQg.JPEG.isuhani/images_%2821%29.jpg?type=w580\" data-width=\"224\" data-height=\"225\" width=\"224\" height=\"225\" data-attachment-id=\"IkHCBu_RXqcw1IImVXKavBjjLqy0\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span><br></span><span><br></span><span>그 외에도 다양한 증상이 있으나 생략합니다. adrenal fatigue(부신피로, 부신 스트레스 장애) 등으로 검색하면 더 많은 내용을 볼 수 있습니다. <br></span><span>예를 들면<br></span><span><a class=\"se_link\" href=\"https://adrenalfatiguesolution.com/adrenal-fatigue-symptoms/\" target=\"_blank\">https://adrenalfatiguesolution.com/adrenal-fatigue-symptoms/</a><br></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n<div class=\"se_component se_oglink og_bSize \">\n    <div class=\"se_sectionArea se_align-left\">\n        <div class=\"se_editArea\" id=\"SEDOC-1524471394557--536156952_oglink_0\">\n            <div class=\"se_viewArea se_og_wrap\">\n                <a class=\"se_og_box  __se_link\" href=\"https://adrenalfatiguesolution.com/adrenal-fatigue-symptoms/\" target=\"_blank\" data-linktype=\"link\" data-linkdata='{\"link\" : \"https://adrenalfatiguesolution.com/adrenal-fatigue-symptoms/\"}'>\n                    <div class=\"se_og_thumb\">\n                        <img src=\"https://dthumb-phinf.pstatic.net/?src&#61;%22https%3A%2F%2Fadrenalfatiguesolution.com%2Fwp-content%2Fuploads%2F2017%2F12%2Fsymptoms-2.jpg%22&amp;type&#61;ff500_300\" alt=\"\">\n\t\t\t\t\t</div>\n                    <div class=\"se_og_txt\">\n                            <div class=\"se_og_tit\">7 Common Adrenal Fatigue Symptoms (And How To Treat Them!)</div>\n                                <div class=\"se_og_desc\">Do you recognize the 7 most common symptoms of Adrenal Fatigue? Chronic exhaustion, weakened immunity, and more. Find out what steps to take to feel better!</div>\n                            <div class=\"se_og_cp\">adrenalfatiguesolution.com</div>\n\n                    </div>\n                </a>\n            </div>\n        </div>\n    </div>\n</div>\n<script type=\"text/data\" class=\"__se_module_data\" data-module='{\"type\":\"v1_oglink\", \"docVersion\" : \"1.0\", \"id\" :\"SEDOC-1524471394557--536156952_oglink_0\" , \"data\" : {\"viewId\" : \"SEDOC-1524471394557--536156952_oglink_0\", \"link\" : \"https://adrenalfatiguesolution.com/adrenal-fatigue-symptoms/\", \"isVideo\" : \"false\", \"thumbnail\" : \"http://dthumb.phinf.naver.net/?src&#61;%22https%3A%2F%2Fadrenalfatiguesolution.com%2Fwp-content%2Fuploads%2F2017%2F12%2Fsymptoms-2.jpg%22&amp;type&#61;ff500_300\"}}'></script>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>이러한 adrenal fatigue, 부신피로 혹은 부신 스트레스 장애는 <br></span><span>충분한 휴식과<br></span><span>적절한 영양공급<br></span><span>신체적 이완 등에 의해 치료될 수 있습니다. <br></span><span><br></span><span>남성역 1번출구 바로 앞에 있는 이수한의원에서는 <br></span><span>현재 부신 상태에 맞는 적절한 한약처방과<br></span><span>신체적 이완을 돕고, 신체적 스트레스를 줄여주기 위한 침치료 및 추나교정요법<br></span><span>을 통해 부신의 기능회복을 돕고 빠른 회복이 가능하게 치료합니다. <br></span><span><br></span><span>예전에 많이 언급되던 '만성피로증후군'과 유사하기에<br></span><span>늘 피곤하고, 여기저기 쑤시고 아프면서, 의욕도 입맛도 없이 몸이 무겁기만하다면 <br></span><span>7호선 </span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>남성역 1번출구 바로 앞에 있는 이수한의원에서 치료를 받으시고 다시 활력을 되찾으세요 ^^</span><span></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->다음 포스팅에서는 스트레스의 3단계 및 부신호르몬인 cortisol의 분비 패턴에 대한 <!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->아래의 그래프에 대해 좀 더 자세히 알아보도록 하겠습니다. <!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n<div class=\"se_component se_imageStrip imageStrip3 default \">\n    <div class=\"se_sectionArea se_align-extend\">\n        <div class=\"se_viewArea\">\n            <div class=\"se_editArea\">\n\n                <div class=\"se_imageStripView\">\n                    <div class=\"se_mediaArea\">\n                                                <div class=\"se_imageStripArea\" style=\"width:41.80962030460241%;\">\n                        \t<a href=\"#\" onclick=\"return false;\" class=\"__se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"_img_0\", \"src\" : \"https://postfiles.pstatic.net/MjAxODA0MjBfMjc3/MDAxNTI0MjI2ODExNjUy.FekUKuyYscrvQYks_zu4cQnObErFFcCadLmPsTLpSjcg.jBCHGT847Y7FQ64Ci0OdYTzjCtHMgMo_IkI_LpXhVdog.JPEG.isuhani/stress-exhaustion-fatigue.jpg\"}'>\n\t\t\t\t\t\t\t\t<img alt=\"\" class=\"se_mediaImage __se_img_el\" data-attachment-id=\"IJ0MzuMIMAqiR5GyaPV1kizIq3yo\" src=\"https://postfiles.pstatic.net/MjAxODA0MjBfMjc3/MDAxNTI0MjI2ODExNjUy.FekUKuyYscrvQYks_zu4cQnObErFFcCadLmPsTLpSjcg.jBCHGT847Y7FQ64Ci0OdYTzjCtHMgMo_IkI_LpXhVdog.JPEG.isuhani/stress-exhaustion-fatigue.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODA0MjBfMjc3/MDAxNTI0MjI2ODExNjUy.FekUKuyYscrvQYks_zu4cQnObErFFcCadLmPsTLpSjcg.jBCHGT847Y7FQ64Ci0OdYTzjCtHMgMo_IkI_LpXhVdog.JPEG.isuhani/stress-exhaustion-fatigue.jpg?type=w580\" data-width=\"590\" data-height=\"395\" id=\"_img_0\">\n\t\t\t\t\t\t\t</a>                  \n\t\t\t\t\t\t</div>\n                                                <div class=\"se_imageStripArea\" style=\"width:37.65630467504283%;\">\n                        \t<a href=\"#\" onclick=\"return false;\" class=\"__se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"_img_1\", \"src\" : \"https://postfiles.pstatic.net/MjAxODA0MjBfNzYg/MDAxNTI0MjI2ODA4ODg4.d5uw3ndDRHaFEH1jzbdffIjy6x3tNFPhnmn3NSvlHFMg.NffxPOv_AujdyMk0tcxQxZkytY4fZz2LjAKY7ye_Yl