ss=\"se_doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1531112266700-688632253_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1531112266700-688632253_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->여름방학이 다가옵니다. 여름방학때는 학교에 다니면서 챙기기 힘들었던 부족한 학업 뿐만이 아니라 아이의 성장, 체력적인 부분도 같이 챙겨야합니다.<br> 실제로 <span style=\"background-color: rgb(197, 221, 156);\">아이들의 성장세를 보면 봄, 여름에 많이 자라는 경향이 있기 때문</span>에 여름 방학을 계획하면서 아이들의 성장에 신경을 써 주시는 것이 필요합니다. 당장 성장치료를 하지 않더라도 <span style=\"background-color: rgb(197, 221, 156);\">아이의 성장을 6개월마다 체크</span>를 해서 아이가 잘 자라고 있는지는 꼭 확인해 주셔야 아이의 성장세가 쳐지는 것을 놓치지 않을 수 있습니다. 아이의 성장세가 쳐진다는 것은 건강상의 문제를 나타내는 것일 수 있고 이후의 성인키를 좌우할 수 있으니 꼭 놓치지 않길 바랍니다. <!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1531112266700-688632253_image_0_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODA3MDlfODkg/MDAxNTMxMTA2NjMxNTEy.QL6tIce3xPz-97dUTq7y_UuqE9g0gVXxy0ErDOk_NQsg.Yb6Kn4q_ibpDZS8w_MN16hIu6hIW7jjHlJjPsAeyX_Ug.PNG.isuhani/520x408_sports.png\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1531112266700-688632253_image_0_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODA3MDlfODkg/MDAxNTMxMTA2NjMxNTEy.QL6tIce3xPz-97dUTq7y_UuqE9g0gVXxy0ErDOk_NQsg.Yb6Kn4q_ibpDZS8w_MN16hIu6hIW7jjHlJjPsAeyX_Ug.PNG.isuhani/520x408_sports.png?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODA3MDlfODkg/MDAxNTMxMTA2NjMxNTEy.QL6tIce3xPz-97dUTq7y_UuqE9g0gVXxy0ErDOk_NQsg.Yb6Kn4q_ibpDZS8w_MN16hIu6hIW7jjHlJjPsAeyX_Ug.PNG.isuhani/520x408_sports.png?type=w580\" data-width=\"520\" data-height=\"408\" width=\"520\" height=\"408\" data-attachment-id=\"IInYwbpkN_dBdGMVrrsqzekWfuYI\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->지금 잘 자라고 있더라도 초등 2-3학년의 여자아이, 초등 3-4학년의 남자아이들 중 또래보다 조숙한 느낌이 드는 아이들은 진료를 받고 뼈나이를 측정해서 아이가 혹시 성조숙의 경향이 있는지 꼭 체크해주시는 것이 좋습니다. 키가 큰 편이라고 생각해서 안심을 하고 있었다가 갑자기 가슴멍울이 잡힌다든가, 갑자기 사춘기의 징후가 보여서 당황하시는 부모님들이 많으니 미리미리 점검을 해 주세요. <!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->방학이 되면 치아건강 점검을 위해 치과를, 눈 건강 점검을 위해 안과를 방문하셨다면 올 여름방학에는 아이의 성장 점검을 위해 이수한의원에 내원하시길 바랍니다. <!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\"