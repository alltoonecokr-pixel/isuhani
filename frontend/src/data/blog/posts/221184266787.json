7\" class=\"lyr_overflow_menu _overflowmenu_layer\" area-hidden=\"true\">\n               <a href=\"#\" onclick=\"window.nsc='blog.post';return false;\" id=\"_title_spiButton\" class=\"naver-splugin btn_splugin share _title_share\"\n                  data-style=\"unity\"\n                  data-url=\"https://blog.naver.com/isuhani/221184266787\"\n                  data-oninitialize=\"splugin_oninitialize(1);\"\n                  data-me-display=\"off\"\n                  data-likeServiceId=\"BLOG\"\n                  data-likeContentsId=\"isuhani_221184266787\"\n                  data-spic-cid=\"221184266787\"\n                  data-logDomain=\"https://proxy.blog.naver.com/spi/v1/api/shareLog\"\n                  data-canonical-url=\"https://blog.naver.com/isuhani/221184266787\"\n                  data-option=\"{baseElement:'_title_spiButton', layerPosition:'outside-bottom', align:'right', marginLeft:0, marginTop:4}\">\n                   공유하기\n                <span class=\"ico_share _title_share_icon\"></span>\n               </a>\n                <a href=\"#\" class=\"_report _param(https://srp2.naver.com/report?svc=BLG&exit=close&ctype=AA01&cwriterenc=2XwEBqfFG3uNnu%2BA9yJjbRqgVasROUqAto1WWT9LDT8%3D&ctitle=%EC%84%B1%EC%9E%A5%EC%B9%98%EB%A3%8C%EB%8A%94%20%EC%96%B8%EC%A0%9C%EB%B6%80%ED%84%B0%2C%20%EB%AA%87%EC%82%B4%EB%B6%80%ED%84%B0%20%ED%95%98%EB%8A%94%EA%B2%8C%20%EC%A2%8B%EB%82%98%EC%9A%94%3F%20%EC%84%B1%EC%9E%A5%EC%B9%98%EB%A3%8C%20%EB%82%A8%EC%84%B1%EC%97%AD%20%EC%9D%B4%EC%88%98%ED%95%9C%EC%9D%98%EC%9B%90&cwriter=isuh***&dark=disable&memtype=Y&env=pc&cnickname=isuh***&vsvc=BLG&cid=isuhani%40%4049462061%40%40mylog%40%40221184266787) _returnFalse\">신고하기<span class=\"ico_report\"></span></a>\n\t\t</div>\n\t</div>\n    <input type=\"text\" value=\"https://blog.naver.com/isuhani/221184266787\" alt=\"url\" class=\"copyTargetUrl\" style=\"display:none;\" title=\"URL 복사\">\n</div>\n<!--\n -->\n        <!-- SE_DOC_HEADER_CONTENTS_END -->\n        <!-- SE_DOC_HEADER_TITLE_BOTTOM-->\n        <div id=\"SEDOC-1515823123320--921182438_se_doc_title_bottom\" class=\"se_doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1515823123320--921182438_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1515823123320--921182438_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>애들이 키가 안크는 이유에는 어떤게 있나요?</span><br><span>선천적 요인은 유전요인으로 부모님의 키가 작은 경우입니다. </span><br><span>후천적 요인은 영양, 운동, 수면, 스트레스 및 환경 등 노력하면 개선할 수 있는 요인들이죠. 외국의 연구결과를 보면 성장에 영향을 주는 요인들은 다음과 같습니다. </span><br><span>영양 31%, 환경 26%, 유전 23%, 운동 20%</span><br><span>따라서 아이가 키가 작고 성장이 느리다면 영양, 운동, 환경(수면, 스트레스)을 개선해 주어야 합니다. </span><br>&nbsp; <br>&nbsp;<!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-left\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:265px\">\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1515823123320--921182438_image_0_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODAxMTNfMTgy/MDAxNTE1ODIzMDU2NTc4.-AhSYZPxnwuYd-XQ-sf3cljjUw6Ez_HBiQJvYyIfcHcg.Pi7XbyUvXmE2-efhL9pwTB_ES5DWt0WKub4leb8ftLQg.JPEG.isuhani/EC9881EC96911.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1515823123320--921182438_image_0_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODAxMTNfMTgy/MDAxNTE1ODIzMDU2NTc4.-AhSYZPxnwuYd-XQ-sf3cljjUw6Ez_HBiQJvYyIfcHcg.Pi7XbyUvXmE2-efhL9pwTB_ES5DWt0WKub4leb8ftLQg.JPEG.isuhani/EC9881EC96911.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODAxMTNfMTgy/MDAxNTE1ODIzMDU2NTc4.-AhSYZPxnwuYd-XQ-sf3cljjUw6Ez_HBiQJvYyIfcHcg.Pi7XbyUvXmE2-efhL9pwTB_ES5DWt0WKub4leb8ftLQg.JPEG.isuhani/EC9881EC96911.jpg?type=w580\" data-width=\"265\" data-height=\"264\" width=\"265\" height=\"264\" data-attachment-id=\"IeCXSiiqrDGvvvBrmpxGYVn6l1xM\" alt=\"\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><br>&nbsp;<br> <span>어떤 경우에 성장 치료가 필요한가요?<br></span><span></span><br><span>1. 평균신장보다 10cm 이상 키가 작은 아이</span><br><span lang=\"EN-US\">2. 1년에 4cm 미만의 속도로 자라는 아이</span><br><span>3. 또래보다 키가 많이 작으면서 소화기 질환(식욕부진, 소화불량, 복통, <br></span><span>&nbsp;&nbsp;&nbsp;&nbsp; 설사, 변비 등), 잦은 호흡기 질환(감기, 천식, 비염 등) 등이 있는 아이</span><br><span>4. 또래보다 키가 작으면서 소아비만인 아이</span><br>&nbsp; <br>&nbsp;<!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-left\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:260px\">\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1515823123320--921182438_image_1_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODAxMTNfOTgg/MDAxNTE1ODIzMDc5NTA5.xX_kVt4YMtqOH1Cz0sILKSfrQnjWSVYk6NjxxUi9GNAg.BGxIvSRoI2cAQbSeO33VJzCyS-kEXM-xJlh7YlO-zlgg.JPEG.isuhani/alba04201103031636060.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1515823123320--921182438_image_1_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODAxMTNfOTgg/MDAxNTE1ODIzMDc5NTA5.xX_kVt4YMtqOH1Cz0sILKSfrQnjWSVYk6NjxxUi9GNAg.BGxIvSRoI2cAQbSeO33VJzCyS-kEXM-xJlh7YlO-zlgg.JPEG.isuhani/alba04201103031636060.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODAxMTNfOTgg/MDAxNTE1ODIzMDc5NTA5.xX_kVt4YMtqOH1Cz0sILKSfrQnjWSVYk6NjxxUi9GNAg.BGxIvSRoI2cAQbSeO33VJzCyS-kEXM-xJlh7YlO-zlgg.JPEG.isuhani/alba04201103031636060.jpg?type=w580\" data-width=\"260\" data-height=\"308\" width=\"260\" height=\"308\" data-attachment-id=\"IdgwanfuYJII14qnDWrZr2ljRNIs\" alt=\"\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><br>&nbsp;<br>&nbsp;<br>&nbsp;<br><span>성장치료는 어느 시기에 하는게 좋나요?<br></span><br><span>아이가 태어나고 돌무렵이면 또래보다 성장이 빠른지 느린지 가늠이 됩니다. 또래보다 느린 것 같다면 만 2~3세까지 열심히 잘 먹게 해서 또래의 성장 속도를 따라잡게 해줘야죠(소아비만이 되지 않게 조절은 해야합니다). 이렇게 어린 나이의 아이들은 잔병치례 안하게, 배변 좋아지게, 잘 자게, 비염 아토피 등 질환이 잘 낫게 하는 게 곧 성장치료입니다. <br></span><span>유치원~초등학생 시절에도 또래아이와의 성장정도, 부모의 키와 비교한 성장정도를 판단해서 성장이 느리고 너무 작다면 시기에 상관없이 성장의 토대를 마련할 수 있는 치료를 해주는 게 좋습니다. <br></span><span><br></span><span>아이들의 성장치료는 늦어도 </span><span>남자는 14세 이전, 여자는 12세 이전에 하는게 좋습니다. 사춘기(2차성징)이 끝나는 남 16세, 여 14세가 넘어가면 성장판이 거의 닫히기 때문에 성장치료의 효과를 기대하기 어렵습니다. 남자는 음모가 자라고 변성기가 오기 전에, 여자는 초경을 시작하기 전에 해야 합니다. 연령에 따라 성장치료의 방법도 달라집니다. <br></span><span><br></span><span></span><br>&nbsp; <br><span>한의학적 성장치료는 성장호르몬의 분비를 촉진시켜 성장에 도움을 주는 한약을 기본으로 합니다. 그러나 한약을 통한 성장치료의 진정한 장점은 성장방해요인들까지 해결해준다는데 있습니다. </span><br><span>예컨데 소화기가 약해서 잘 안먹으려 들고 자주 체하고 설사나 변비가 있는 타입은 소화기를 튼튼히 하는 약재를 써서 소화기까지 치료하는 것입니다. </span><br><span>신경이 예민해서 밤에 잠을 깊이 못 자고 스트레스를 잘 받는 아이는 신경을 튼튼하게 해 주는 방법을 써야 하지요.</span><br><span>호흡기가 약해서 감기에 잘 걸리고, 비염이 있는 아이라면 호흡기를 튼튼하게 해야 하죠.</span><br>&nbsp; <br><span>한의학은 키 키우는데 무슨 약, 감기에 무슨 약 하는 식으로 일률적으로 정해진 처방을 쓰는 것이 아닙니다. 환자의 체질과 증상에 따라 가장 알맞은 방법을 찾는 것을 변증논치라고 하는데 이것이 한의학의 기본 정신입니다. </span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n</div>\n<!-- SE_DOC_CONTENTS_END -->\n<div class=\"__se_doc_title_end\" id=\"se_doc_contents_end\"></div>\n<div id=\"SEDOC-1515823123320--921182438_se_doc_footer\" class=\"se_doc_footer\"></div>\n</div></div>\n\t\t\t\t\t\t</div>",
