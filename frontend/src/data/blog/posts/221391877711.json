\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span style=\"color: black;\">유산을</span><span style=\"color: black;\"> </span><span style=\"color: black;\">한번이라도</span><span style=\"color: black;\"> </span><span style=\"color: black;\">경험하는</span><span style=\"color: black;\"> </span><span style=\"color: black;\">경우가</span><span style=\"color: black;\"> </span><span style=\"color: black;\">전체</span><span style=\"color: black;\"> </span><span style=\"color: black;\">임신여성의</span><span lang=\"EN-US\" style=\"color: black;\"> 15~20%</span><span style=\"color: black;\">에</span><span style=\"color: black;\"> </span><span style=\"color: black;\">해당할</span><span style=\"color: black;\"> </span><span style=\"color: black;\">정도로</span><span style=\"color: black;\"> </span><span style=\"color: black;\">유산의</span><span style=\"color: black;\"> </span><span style=\"color: black;\">발생확률은</span><span style=\"color: black;\"> </span><span style=\"color: black;\">높은</span><span style=\"color: black;\"> </span><span style=\"color: black;\">편입니다</span><span lang=\"EN-US\" style=\"color: black;\">. </span><span style=\"color: black;\">다만</span><span style=\"color: black;\"> </span><span style=\"color: black;\">한번의</span><span style=\"color: black;\"> </span><span style=\"color: black;\">유산을</span><span style=\"color: black;\"> </span><span style=\"color: black;\">겪은</span><span style=\"color: black;\"> </span><span style=\"color: black;\">후</span><span style=\"color: black;\"> </span><span style=\"color: black;\">연달아</span><span style=\"color: black;\"> </span><span style=\"color: black;\">유산을</span><span style=\"color: black;\"> </span><span style=\"color: black;\">겪으면서</span><span style=\"color: black;\"> </span><span style=\"color: black;\">습관성</span><span style=\"color: black;\"> </span><span style=\"color: black;\">유산</span><span style=\"color: black;\"> </span><span style=\"color: black;\">진단을</span><span style=\"color: black;\"> </span><span style=\"color: black;\">받게</span><span style=\"color: black;\"> </span><span style=\"color: black;\">되는</span><span style=\"color: black;\"> </span><span style=\"color: black;\">경우가</span><span style=\"color: black;\"> </span><span style=\"color: black;\">많기</span><span style=\"color: black;\"> </span><span style=\"color: black;\">때문에</span><span lang=\"EN-US\" style=\"color: black;\">, </span><span style=\"color: black;\">유산</span><span style=\"color: black;\"> </span><span style=\"color: black;\">후에</span><span style=\"color: black;\"> </span><span style=\"color: black;\">후유증</span><span style=\"color: black;\"> </span><span style=\"color: black;\">없이</span><span style=\"color: black;\"> </span><span style=\"color: black;\">회복하는</span><span style=\"color: black;\"> </span><span style=\"color: black;\">것이</span><span style=\"color: black;\"> </span><span style=\"color: black;\">중요합니다</span><span lang=\"EN-US\" style=\"color: black;\">. </span><span style=\"color: black;\">또한</span><span style=\"color: black;\"> </span><span style=\"color: black;\">다음</span><span style=\"color: black;\"> </span><span style=\"color: black;\">임신을</span><span style=\"color: black;\"> </span><span style=\"color: black;\">준비하기</span><span style=\"color: black;\"> </span><span style=\"color: black;\">위해</span><span style=\"color: black;\"> </span><span style=\"color: black;\">자궁과</span><span style=\"color: black;\"> </span><span style=\"color: black;\">난소기능의</span><span style=\"color: black;\"> </span><span style=\"color: black;\">회복을</span><span style=\"color: black;\"> </span><span style=\"color: black;\">돕는</span><span style=\"color: black;\"> </span><span style=\"color: black;\">과정을</span><span style=\"color: black;\"> </span><span style=\"color: black;\">거쳐서</span><span style=\"color: black;\"> </span><span style=\"color: black;\">난임</span><span style=\"color: black;\"> </span><span style=\"color: black;\">예방을</span><span style=\"color: black;\"> </span><span style=\"color: black;\">도모해야</span><span style=\"color: black;\"> </span><span style=\"color: black;\">합니다</span><span lang=\"EN-US\" style=\"color: black;\">. </span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span style=\"color: black;\">보통</span><span style=\"color: black;\"> </span><span style=\"color: black;\">유산을</span><span style=\"color: black;\"> </span><span style=\"color: black;\">겪고</span><span style=\"color: black;\"> </span><span style=\"color: black;\">나면</span><span style=\"color: black;\"> </span><span style=\"color: black;\">몸과</span><span style=\"color: black;\"> </span><span style=\"color: black;\">마음이</span><span style=\"color: black;\"> </span><span style=\"color: black;\">많이</span><span style=\"color: black;\"> </span><span style=\"color: black;\">힘들어지고</span><span style=\"color: black;\"> </span><span style=\"color: black;\">다음</span><span style=\"color: black;\"> </span><span style=\"color: black;\">임신에</span><span style=\"color: black;\"> </span><span style=\"color: black;\">대한</span><span style=\"color: black;\"> </span><span style=\"color: black;\">걱정도</span><span style=\"color: black;\"> </span><span style=\"color: black;\">커지게</span><span style=\"color: black;\"> </span><span style=\"color: black;\">마련입니다</span><span lang=\"EN-US\" style=\"color: black;\">. </span><span style=\"color: black;\">하지만</span><span style=\"color: black;\"> </span><span style=\"color: black;\">후유증이</span><span style=\"color: black;\"> </span><span style=\"color: black;\">남지</span><span style=\"color: black;\"> </span><span style=\"color: black;\">않도록</span><span style=\"color: black;\"> </span><span style=\"color: black;\">잘</span><span style=\"color: black;\"> </span><span style=\"color: black;\">치료하고</span><span style=\"color: black;\"> </span><span style=\"color: black;\">체계적으로</span><span style=\"color: black;\"> </span><span style=\"color: black;\">다음</span><span style=\"color: black;\"> </span><span style=\"color: black;\">임신을</span><span style=\"color: black;\"> </span><span style=\"color: black;\">준비하면</span><span style=\"color: black;\"> </span><span style=\"color: black;\">오히려</span><span style=\"color: black;\"> </span><span style=\"color: black;\">다음</span><span style=\"color: black;\"> </span><span style=\"color: black;\">번에는</span><span style=\"color: black;\"> </span><span style=\"color: black;\">임신</span><span style=\"color: black;\"> </span><span style=\"color: black;\">성공</span><span style=\"color: black;\"> </span><span style=\"color: black;\">가능성이</span><span style=\"color: black;\"> </span><span style=\"color: black;\">높아집니다</span><span lang=\"EN-US\" style=\"color: black;\">. </span><span style=\"color: black;\">유산</span><span style=\"color: black;\"> </span><span style=\"color: black;\">후</span><span style=\"color: black;\"> </span><span style=\"color: black;\">보약은</span><span style=\"color: black;\"> </span><span style=\"color: black;\">수술직후</span><span style=\"color: black;\"> </span><span style=\"color: black;\">한달에서</span><span style=\"color: black;\"> <span lang=\"EN-US\">100</span></span><span style=\"color: black;\">일</span><span style=\"color: black;\"> </span><span style=\"color: black;\">사이에</span><span style=\"color: black;\"> </span><span style=\"color: black;\">효과를</span><span style=\"color: black;\"> </span><span style=\"color: black;\">가장</span><span style=\"color: black;\"> </span><span style=\"color: black;\">잘</span><span style=\"color: black;\"> </span><span style=\"color: black;\">볼</span><span style=\"color: black;\"> </span><span style=\"color: black;\">수</span><span style=\"color: black;\"> </span><span style=\"color: black;\">있는</span><span style=\"color: black;\"> </span><span style=\"color: black;\">기간이기</span><span style=\"color: black;\"> </span><span style=\"color: black;\">때문에</span><span style=\"color: black;\"> </span><span style=\"color: black;\">치료와</span><span style=\"color: black;\"> </span><span style=\"color: black;\">몸조리를</span><span style=\"color: black;\"> </span><span style=\"color: black;\">이</span><span style=\"color: black;\"> </span><span style=\"color: black;\">시기에</span><span style=\"color: black;\"> </span><span style=\"color: black;\">집중하는</span><span style=\"color: black;\"> </span><span style=\"color: black;\">것이</span><span style=\"color: black;\"> </span><span style=\"color: black;\">효과적입니다</span><span lang=\"EN-US\" style=\"color: black;\">.</span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image defau