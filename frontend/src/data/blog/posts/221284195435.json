doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1527247788971-488102881_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1527247788971-488102881_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-justify\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->오늘의 선물이에요 ^^<br><br><br>몇일전에 홍삼캔디 올린 글 기억하시나요?&nbsp;<br>강ㅇㅇ 님께서 오늘도 내원하시면서<br><br>한의원 밑에 파는&nbsp;<br>옥수수를 사오셨어요<br><br><br><br>(사실 몇일전부터 찐옥수수가 그렇게 먹고싶었는데<br>타이밍 완전 대박입니다 ㅋㅋ)<!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-right\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:1920px\">\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1527247788971-488102881_image_0_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODA1MjVfNjkg/MDAxNTI3MjQ2OTU2MjYw.d4S5h8vuDsiBUDPpOQNcxfAw7ka9vDhaMG8kk90dpaEg.JBg-tbc1IynfIIJxsT_l1HTqTRDTl-OK_lA3ZO4bTLwg.JPEG.isuhani/6CCBBEA9-B37B-4A0D-AAB5-70FAD5C7AC01.jpeg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1527247788971-488102881_image_0_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODA1MjVfNjkg/MDAxNTI3MjQ2OTU2MjYw.d4S5h8vuDsiBUDPpOQNcxfAw7ka9vDhaMG8kk90dpaEg.JBg-tbc1IynfIIJxsT_l1HTqTRDTl-OK_lA3ZO4bTLwg.JPEG.isuhani/6CCBBEA9-B37B-4A0D-AAB5-70FAD5C7AC01.jpeg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODA1MjVfNjkg/MDAxNTI3MjQ2OTU2MjYw.d4S5h8vuDsiBUDPpOQNcxfAw7ka9vDhaMG8kk90dpaEg.JBg-tbc1IynfIIJxsT_l1HTqTRDTl-OK_lA3ZO4bTLwg.JPEG.isuhani/6CCBBEA9-B37B-4A0D-AAB5-70FAD5C7AC01.jpeg?type=w580\" data-width=\"1920\" data-height=\"1920\" width=\"1920\" height=\"1920\" data-attachment-id=\"I_oZAF9nWBry7txRVTBFQ6z9fnNg\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-justify\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->어머님께서&nbsp;<br>다른데는 뭐사주면 간호사샘들끼리 먹는데<br><br>우리 이수한의원은 원장님도 다 챙겨드린다고<br><br>원장님 드실거까지 다 사오셨다고.. ㅎㅎ<br><br><br><br>어머님 센스쟁이십니다<!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-right\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:1920px\">\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1527247788971-488102881_image_1_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODA1MjVfMjg2/MDAxNTI3MjQ2OTk3MjYx.5W0Gjycb6b6J_3AcKfa8knhMfZwvpQDfPYrVlzozBOQg.1Kzf6sJR48HfvGsQk4GqF4shPqBPebqsYS6VNjtZj-Qg.JPEG.isuhani/EF3718E6-FA7B-4315-B791-C8957B3FA