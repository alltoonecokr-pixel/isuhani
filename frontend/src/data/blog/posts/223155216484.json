  "body": "<div class=\"se-main-container\">\n                <div class=\"se-component se-text se-l-default\" id=\"SE-57bd9d54-0952-4876-85f4-f2709e63fa03\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n                                    <!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-ce13da49-057d-49b9-8e17-e923621e2ef2\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-bfabdf00-e0de-49cb-8990-0253bf57b80b\">운동이 부족한 사람도, </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-f6e21337-96ae-4ac1-a909-95b91ac0edaa\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-152469eb-28bf-44cc-baf2-5f48aa00ffc8\">운동을 많이 하는 사람도 </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-2394cd26-4c64-4c87-a394-1a068a87ab0f\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-4d169557-89b0-484a-b294-a5b837623211\">근육의 통증을 경험하게 됩니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-c2c3e1b2-591f-41de-b68b-02037ce00ee0\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-c7723536-abab-4f9a-ad6f-8d9743af7a2c\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-289c72c1-888b-4ee7-a270-c141c7700162\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-c1397407-af8b-4745-a0eb-c46f71f4a9f4\">자세가 안 좋아서 근육통이 생길 수도 있고</span></p><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-6d1ecb90-ac7e-4c92-a75a-0919d2e75617\">\n                    <div c