=\"se_doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1530865959321-1032044624_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1530865959321-1032044624_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1530865959321-1032044624_image_0_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODA3MDZfMjcx/MDAxNTMwODYyMzg5Nzc1.hBDbnf51sXE2mMsc6aVnQH9dEoY62SdvnQsjjKZ0_z8g.AtNywn-xujMAaNFDxHOr-8XxNffMB0kpfysATd_4peAg.JPEG.isuhani/%EC%83%9D%EB%A6%AC%ED%86%B5.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1530865959321-1032044624_image_0_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODA3MDZfMjcx/MDAxNTMwODYyMzg5Nzc1.hBDbnf51sXE2mMsc6aVnQH9dEoY62SdvnQsjjKZ0_z8g.AtNywn-xujMAaNFDxHOr-8XxNffMB0kpfysATd_4peAg.JPEG.isuhani/%EC%83%9D%EB%A6%AC%ED%86%B5.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODA3MDZfMjcx/MDAxNTMwODYyMzg5Nzc1.hBDbnf51sXE2mMsc6aVnQH9dEoY62SdvnQsjjKZ0_z8g.AtNywn-xujMAaNFDxHOr-8XxNffMB0kpfysATd_4peAg.JPEG.isuhani/%EC%83%9D%EB%A6%AC%ED%86%B5.jpg?type=w580\" data-width=\"338\" data-height=\"225\" width=\"338\" height=\"225\" data-attachment-id=\"ILkFh9JGWW_dqLBNWFGS8S7jw1o0\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span lang=\"EN-US\">&nbsp;</span><br><span> 생리통으로 고생하는 분들을 자주 뵙습니다. 대부분 다른 증상으로 내원했다가 부인과질환을 많이 보는 원장님이시니 여쭤본다면서 문의하는 경우가 많습니다. 생리통은 50%이상의 여성들이 경험하는 증상이다 보니 심하지 않으면 그냥 지내시는 경우가 많은 것 같습니다. 이보다 심한 경우에도 미혼여성들의 경우에는 진통제에 의지해 버티는 경우가 많습니다. &nbsp;<br></span><span><br></span> 그렇다면 그냥 지내도 되는 생리통과 병원에 가서 꼭 검사를 해봐야 하는 생리통의 차이에 대해서 알아볼까요? <br> <br><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span style=\"background-color: rgb(197, 221, 156);\">병원에 가서 굳이 검사를 할 필요가 없는 생리통은 주로 원발성 생리통입니다. 원발성 생리통이란 기저질환이 없이 통증이 월경주기에 따라 나타나는 것입니다. <br></span><span style=\"background-color: rgb(197, 221, 156);\"></span><br><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n\n\n\n<div class=\"se_component se_sectionTitle \">\n    <div class=\"se_sectionArea se_align-left\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_H2 \"\n            \t\t\tstyle=\"color: ;\n                        text-decoration: inherit;\n                        font-style: inherit;\n                        \">\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <h5 class=\"se_textarea\"><!-- SE3-TEXT { --> 원발성 생리통의 특징<!-- } SE3-TEXT --></h5>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --> <span lang=\"EN-US\"><span>1.<span>&nbsp;&nbsp;&nbsp;&nbsp; </span></span></span>주로 초경1-2년 이내 대개 젊은 여성에게 발생하지만 40대까지 지속되기도 함<br> <span lang=\"EN-US\"><span>2.<span>&nbsp;&nbsp;&nbsp;&nbsp; </span></span></span>월경 시작 몇 시간 전 통증이 시작돼서 시작 직후 48-72시간 정도 통증이 지속됨<br> <span lang=\"EN-US\"><span>3.<span>&nbsp;&nbsp;&nbsp;&nbsp; </span></span></span>증상은 치골 상부의 경련하는 듯한 통증, 요통, 앞쪽 대퇴부로의 방산통을 동반하기도 함<br> <span lang=\"EN-US\"><span>4.<span>&nbsp;&nbsp;&nbsp;&nbsp; </span></span></span>오심, 구토, 설사, 드물게 실신을 일으키기도 하는데 생체징후는 정상임<!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->원인 질환이 없는 원발성 생리통은 골반강 내 혈액순환이 원활하지 않는 것이 원인이 되어 나타나는 것이기 때문에 한방치료가 효과적이지요. 온경지통(溫經止痛)이라고 하여 말 그대로 자궁경락을 따뜻하게 해서 자궁근을 이완시키고 혈류공급을 원활하게 만드는 치료를 하면 많이 좋아질 수 있습니다. <!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span style=\"background-color: rgb(197, 221, 156);\"><br></span><span style=\"background-color: rgb(197, 221, 156);\">병원에 가서 꼭 검사를 해야하는 생리통은 속발성 생리통의 경우입니다. 속발성 생리통이란 골반의 내재된 질환이 있으면서 주기적 생리통이 있는 경우입니다. </span><span style=\"background-color: rgb(197, 221, 156);\"></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n\n\n\n<div class=\"se_component se_sectionTitle \">\n    <div class=\"se_sectionArea se_align-left\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_H2 \"\n            \t\t\tstyle=\"color: ;\n                        text-decoration: inherit;\n                        font-style: inherit;\n                        \">\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <h5 class=\"se_textarea\"><!-- SE3-TEXT { --> 속발성 생리통의 특징<!-- } SE3-TEXT --></h5>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span><span lang=\"EN-US\"><span><span lang=\"EN-US\"><span>1.<span>&nbsp;&nbsp;&nbsp;&nbsp; </span></span></span>속발성 생리통을 일으키는 기저질환 - 자궁내막증, 자궁선근종, 자궁근종과 용종, 유착, 골반 염증성질환, 뮐러관의 선천적 기형, 자궁경부 협착, 난소낭종, 골반울혈증후군<br> <span lang=\"EN-US\"><span>2.<span>&nbsp;&nbsp;&nbsp;&nbsp; </span></span></span>&nbsp;대부분 초경 이후 수년 뒤 발생함<br> <span lang=\"EN-US\"><span>3.<span>&nbsp;&nbsp;&nbsp;&nbsp; </span></span></span>생리양이 너무 많거나 적거나 생리사이에 부정출혈이 있는 경우가 있음<br> <span lang=\"EN-US\"><span>4.<span>&nbsp;&nbsp;&nbsp;&nbsp; </span></span></span>골반통의 부위가 중심이 아닌 경우<br> <span lang=\"EN-US\"><span>5.<span>&nbsp;&nbsp;&nbsp;&nbsp; </span></span></span>성교통이나 배변통이 동반되는 경우<br> <span lang=\"EN-US\"><span>6.<span>&nbsp;&nbsp;&nbsp;&nbsp; </span></span></span>증상이 점점 심해짐 <br> <span lang=\"EN-US\"><span>7.<span>&nbsp;&nbsp;&nbsp;&nbsp; </span></span></span>소염진통제나 경구용 피임제에 의한 통증 완화가 잘 이루어지지 않는 경우가 있음</span></span></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-center\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:400px\">\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1530865959321-1032044624_image_1_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODA3MDZfMTUy/MDAxNTMwODYzMDE5MDc5.nY0RD8gg0Spkeg-mSjPUTMTgO74OTVtyijEdzpdfOukg.y1ZRgi-mwEhVc0_ae-dpTkxM0w77nKsK50QgzcAkwbcg.JPEG.isuhani/KakaoTalk_20180406_112924663.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1530865959321-1032044624_image_1_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODA3MDZfMTUy/MDAxNTMwODYzMDE5MDc5.nY0RD8gg0Spkeg-mSjPUTMTgO74OTVtyijEdzpdfOukg.y1ZRgi-mwEhVc0_ae-dpTkxM0w77nKsK50QgzcAkwbcg.JPEG.isuhani/KakaoTalk_20180406_112924663.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODA3MDZfMTUy/MDAxNTMwODYzMDE5MDc5.nY0RD8gg0Spkeg-mSjPUTMTgO74OTVtyijEdzpdfOukg.y1ZRgi-mwEhVc0_ae-dpTkxM0w77nKsK50QgzcAkwbcg.JPEG.isuhani/KakaoTalk_20180406_112924663.jpg?type=w580\" data-width=\"400\" data-height=\"712\" width=\"400\" height=\"712\" data-attachment-id=\"ITVz7gzUL5L-3rZsAt12aqg262T8\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span lang=\"EN-US\">&nbsp;</span><br> 각각의 경우에 따라 생리통이 가벼운 문제가 아닌 경우가 있기 때문에 꼭 병원진료를 받아보시길 권합니다.<br> 진단을 받고나서 병원에서 제시하는 경구피임약이나 진통제 등의 치료법은 근본치료가 아니기 때문에 자궁이나 난소의 질환을 근본적으로 치료할 수 있는 한방치료를 받으시길 바랍니다.<!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->이수한의원에는 많은 치료경험을 가진 부인과 전문의 한의사가 진료를 하고 있습니다. <!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n     