 class=\"lyr_overflow_menu _overflowmenu_layer\" area-hidden=\"true\">\n               <a href=\"#\" onclick=\"window.nsc='blog.post';return false;\" id=\"_title_spiButton\" class=\"naver-splugin btn_splugin share _title_share\"\n                  data-style=\"unity\"\n                  data-url=\"https://blog.naver.com/isuhani/221237555961\"\n                  data-oninitialize=\"splugin_oninitialize(1);\"\n                  data-me-display=\"off\"\n                  data-likeServiceId=\"BLOG\"\n                  data-likeContentsId=\"isuhani_221237555961\"\n                  data-spic-cid=\"221237555961\"\n                  data-logDomain=\"https://proxy.blog.naver.com/spi/v1/api/shareLog\"\n                  data-canonical-url=\"https://blog.naver.com/isuhani/221237555961\"\n                  data-option=\"{baseElement:'_title_spiButton', layerPosition:'outside-bottom', align:'right', marginLeft:0, marginTop:4}\">\n                   공유하기\n                <span class=\"ico_share _title_share_icon\"></span>\n               </a>\n                <a href=\"#\" class=\"_report _param(https://srp2.naver.com/report?svc=BLG&exit=close&ctype=AA01&cwriterenc=VaGSqI8d6sJSV5NZqzYZEARhOtRtdCGpYhvroDPBx8A%3D&ctitle=%EC%86%8C%EC%95%84%EC%84%B1%EC%9E%A5.%20%EC%9A%B0%EB%A6%AC%20%EC%95%84%EC%9D%B4%EB%8A%94%20%EC%99%9C%20%EC%9E%98%20%ED%81%AC%EC%A7%80%20%EC%95%8A%EC%9D%84%EA%B9%8C%3F%20%5B%EB%82%A8%EC%84%B1%EC%97%AD%20%EC%86%8C%EC%95%84%20%ED%95%9C%EC%9D%98%EC%9B%90%5D&cwriter=isuh***&dark=disable&memtype=Y&env=pc&cnickname=isuh***&vsvc=BLG&cid=isuhani%40%4049462061%40%40mylog%40%40221237555961) _returnFalse\">신고하기<span class=\"ico_report\"></span></a>\n\t\t</div>\n\t</div>\n    <input type=\"text\" value=\"https://blog.naver.com/isuhani/221237555961\" alt=\"url\" class=\"copyTargetUrl\" style=\"display:none;\" title=\"URL 복사\">\n</div>\n<!--\n -->\n        <!-- SE_DOC_HEADER_CONTENTS_END -->\n        <!-- SE_DOC_HEADER_TITLE_BOTTOM-->\n        <div id=\"SEDOC-1522037285349-1940379626_se_doc_title_bottom\" class=\"se_doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1522037285349-1940379626_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1522037285349-1940379626_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><br>&nbsp;<br><strong><span><span style=\"color: rgb(58, 50, 195);\">우리 아이는 왜 잘 크지 않을까?</span>&nbsp;</span></strong><br>&nbsp;<br>&nbsp;&nbsp;<br>요즘 외모 못지 않게 키는 부모들의 걱정거리중에 하나입니다<span>.&nbsp;<br></span><span>부모들이 바라는 키는 여자는 168cm, 남자는 181cm 라는 조사결과가 있어요. 하지만 실제 성인 여자의 평균키는 161cm, 성인 남자의 평균키는 173cm 이니까 우리가 원하는 키는 평균보다 7-8cm 큰겁니다! <br></span><span><br></span><span><br></span><u>골고루 영양섭취를 잘 하는데도 우리 아이는 왜 키가 자라지 않을까?</u>&nbsp;하며<br>인터넷에서 정보를 얻거나 소아성장클리닉, 한의원에 가서 문의하기도 하겠죠. <br>&nbsp;<!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-left\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:190px\">\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1522037285349-1940379626_image_0_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODAzMjZfMTky/MDAxNTIyMDMyMjE3MzE0.L30JXBeBy-sefBlw5kJWMfZWbv9XkbfxRDz9xlYtBsEg.qovZX6ptErcKoiLjhvSTdmAIbRbJ6nGrb9BVFdTiHt8g.JPEG.isuhani/growth.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1522037285349-1940379626_image_0_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODAzMjZfMTky/MDAxNTIyMDMyMjE3MzE0.L30JXBeBy-sefBlw5kJWMfZWbv9XkbfxRDz9xlYtBsEg.qovZX6ptErcKoiLjhvSTdmAIbRbJ6nGrb9BVFdTiHt8g.JPEG.isuhani/growth.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODAzMjZfMTky/MDAxNTIyMDMyMjE3MzE0.L30JXBeBy-sefBlw5kJWMfZWbv9XkbfxRDz9xlYtBsEg.qovZX6ptErcKoiLjhvSTdmAIbRbJ6nGrb9BVFdTiHt8g.JPEG.isuhani/growth.jpg?type=w580\" data-width=\"190\" data-height=\"265\" width=\"190\" height=\"265\" data-attachment-id=\"IIN0H2kHVIPMHF0RSgR0OdwbtWlU\" alt=\"\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->&nbsp;<br>&nbsp;<br><strong><span style=\"color: rgb(233, 125, 129);\">근본적인 원인이&nbsp;있을까?</span></strong><br>키는 기본적으로 유전인자에 의해 결정이 됩니다.&nbsp;<span> <br></span><span>콩 심은데 콩 나고, 팥 심은데 팥 난다.&nbsp;맞습니다! <br></span><span>하지만 이런 말을 들을 때, 궁금증이 생겨야 합니다.<br></span><span><br></span><span>\"엄마 아빠가 작지만, 아이들이 큰 경우도 있는데요?\" <br></span><span><br></span><span>맞습니다. 그런경우가 있습니다. 반대로 엄마 아빠는 큰데, 아이는 작은 경우도 있죠. <br></span><span><br></span><span>그 유전자가 엄마 아빠의 유전자만이 아니라, 할아버지 할머니 외할아버지 할머니 삼촌 이모 고모 등 가까운 친척들의 유전자가 다 영향을 주는 거라서 그렇습니다. 가까운 친인척 중에 키가 큰 친척이 있다면 부모가 작더라도 키가 클 수 있는 확률이 있겠죠 ^^<br></span><span><br></span><span>또한 <br></span><span>최근의 연구들은 유전자가 있더라도 환경 요인에 의해 그 유전자가 힘을 쓸 수도 있고, 힘을 쓰지 못할 수도 있다고 합니다. <br></span><span>예를 들어 비만유전자를 가지고 있는 사람이 있다고 생각해봅시다. 비록 비만 유전자를 가지고 있더라도 어려서 좋은 식습관을 가진 가정환경에 의해 본인도 좋은 식습관이 형성이 되면 소아청소년기를 거치는 동안 비만이 아닌 정상체중을 유지할 수 있습니다. 당연히 성인이 된 후에도 계속 유지할 수 있죠. 그러나 일생의 어느 순간이든 식습관을 비롯한 내 생활환경, 내 생활습관이 바뀌면 내 몸 속의 비만유전자가 작동을 시작해서 비만체형으로 바뀔 수 있습니다.<br></span><span>키 성장도 다르지 않겠죠? <br></span><span>키가 클 수 있는 유전자가 몸 속에 있더라도, 생활환경 생활습관 질병유무 등의 요인에 의해 키가 크지 못 할 수 있는거죠. <br></span><span>영양섭취, 적절한 운동, 정서적 스트레스 유무 등 모든 것이 합해져서 유전자가 작동할지 여부, 얼마나 작동할지 여부가 영향을 받을 겁니다. <br></span><span></span><br>&nbsp;<br>&nbsp;<!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-left\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:259px\">\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1522037285349-1940379626_image_1_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODAzMjZfMTQz/MDAxNTIyMDMzMjk2MDYy.ISRuaIyxvq_js653X8XnGizIiizg4RHagdDsmVv4mdUg.UCpCRGCJ4s6uiefadRBtW6vPfjyPR4biVYyFLgpHZVMg.JPEG.isuhani/imagesCA0O4B34.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1522037285349-1940379626_image_1_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODAzMjZfMTQz/MDAxNTIyMDMzMjk2MDYy.ISRuaIyxvq_js653X8XnGizIiizg4RHagdDsmVv4mdUg.UCpCRGCJ4s6uiefadRBtW6vPfjyPR4biVYyFLgpHZVMg.JPEG.isuhani/imagesCA0O4B34.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODAzMjZfMTQz/MDAxNTIyMDMzMjk2MDYy.ISRuaIyxvq_js653X8XnGizIiizg4RHagdDsmVv4mdUg.UCpCRGCJ4s6uiefadRBtW6vPfjyPR4biVYyFLgpHZVMg.JPEG.isuhani/imagesCA0O4B34.jpg?type=w580\" data-width=\"259\" data-height=\"194\" width=\"259\" height=\"194\" data-attachment-id=\"IqMe4QPHgoFPPcmozRqYpPTjodhI\" alt=\"\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->&nbsp;<br>&nbsp;<br><strong><span style=\"color: rgb(233, 125, 129);\">사춘기가 빨라지는 것도 성장 저해 요인</span></strong><br><br><span>100년전에 비하면 먹을거리가 엄청나게 풍부한 세상에 살고 있습니다. <br></span><span>당연히 임신을 한 엄마도 잘 먹게 됩니다. 임산부 비만이 문제가 될 정도죠. <br></span><span>태어난 아이도 잘 먹습니다. 모유, 분유, 이유식 등 나이에 따른 먹을거리의 차이는 있지만 늘 부족하지 않게 먹고 있죠. <br></span><span><br></span>적절한 영양상태는 소아성장에 도움이되지만 과도한 영향섭취는 소아비만의 원인이고, 성조숙증과 조기 초경의 원인이 됩니다. <br><span>평균키보다 갑자기 빠르게 크거나 소아비만일 경우 2차 성징이&nbsp;빨리 시작된 건지에 대한&nbsp;세심한 관찰이 필요합니다. <br></span><span>매년 4-5cm 크던 아이가 갑자기 7 cm 가까이 크기 시작했다고 마냥기뻐할 게 아니죠.&nbsp;사춘기 급속성장기가 일찍 시작되서 성장이 빨리 끝날 수도 있거든요. 성장판 검사, 뼈나이 측정 등과 함께&nbsp;소아 성장, 성조숙 진료 경험이 풍부한 의료기관, 한의원 등에서 진료를 받아보는 게&nbsp;좋겠습니다. <br></span><span>여자 아이 체중이 40kg 정도가 되면 초경이 시작 될 수 있다고&nbsp;합니다.&nbsp;비만이라서&nbsp;어린나이에 40kg에 도달했다면 역시 성조숙, 조기초경 등에 대한 진료가 필요해요. <br></span>&nbsp;<!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-left\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:392px\">\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1522037285349-1940379626_image_2_img\", \"src\" : \"http://blogfiles.naver.net/20130128_55/isuhani_1359381342066dQB1I_PNG/%C5%B02.PNG\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1522037285349-1940379626_image_2_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/20130128_55/isuhani_1359381342066dQB1I_PNG/%C5%B02.PNG?type=w580\" width=\"392\" height=\"269\" data-attachment-id=\"\" alt=\"\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->&nbsp;<br>&nbsp;<br>&nbsp;<br><strong><span style=\"color: rgb(233, 125, 129);\">수면 그리고 스트레스</span></strong><br><br>아이들은 학원을 몇개씩 다니는게 하루 일과죠. 저 역시 아이들을 키우는 입장이 되어보니 어쩔 수 없이 보내게 되더라구요. <br>당연히 공을 차거나 뛰어놀 시간이 없어요. 놀아도 집안에서, 앉아서 놀죠 ㅜ.ㅠ 불쌍한 아이들. <br>정신건강은 물론 키 성장을 위해서는 스트레스를 풀수 있는 시간, 스트레스를 풀 수 있는 활동이 필요합니다. 뭘 하면 애들이 스트레스가 풀리는지는 부모가 다양한 시도를 하고, &nbsp;세심히 관찰해봐야 알 수 있어요. <br><span>TV,게임기,컴퓨터도 아이들의 스트레스를 풀어줄 수 있지만, 그 보다는 신체활동이 동반되는 스트레스 해소 거리가 있으면 좋아요.&nbsp;<br></span>&nbsp;<br>&nbsp;<!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-left\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:489px\">\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1522037285349-1940379626_image_3_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODAzMjZfMTI5/MDAxNTIyMDM2NTA1MTky.hqEoE1pcWUkJWZABUCOg-ffAWrfVegZTSNezYe5hAw4g.vXogsCWFBSDDlMdEDac-Js5XE4_jU_6zpUc6Z-rseZQg.JPEG.isuhani/BCBAC1B6BCF7C1F5.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1522037285349-1940379626_image_3_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODAzMjZfMTI5/MDAxNTIyMDM2NTA1MTky.hqEoE1pcWUkJWZABUCOg-ffAWrfVegZTSNezYe5hAw4g.vXogsCWFBSDDlMdEDac-Js5XE4_jU_6zpUc6Z-rseZQg.JPEG.isuhani/BCBAC1B6BCF7C1F5.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODAzMjZfMTI5/MDAxNTIyMDM2NTA1MTky.hqEoE1pcWUkJWZABUCOg-ffAWrfVegZTSNezYe5hAw4g.vXogsCWFBSDDlMdEDac-Js5XE4_jU_6zpUc6Z-rseZQg.JPEG.isuhani/BCBAC1B6BCF7C1F5.jpg?type=w580\" data-width=\"489\" data-height=\"389\" width=\"489\" height=\"389\" data-attachment-id=\"Im6txLchHU-1UWWBIPYVXb8izlY8\" alt=\"\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->&nbsp;<br>&nbsp;<br><strong><span style=\"color: rgb(255, 0, 0);\">성조숙증이란,</span> </strong>성호르몬의 조기분비로 인해 사춘기적 변화시기가&nbsp; 평균보다 빨리 나타나는 현상입니다.<br>사춘기 현상으로 유방 발달, 음모 발달, 고환 크기 증가 등이 여자아이가 만8세 이전, 남자아이가 만9세 이전에 나타나면 성조숙증으로 진단합니다.<br><span>&nbsp;<br></span><span>남녀 모두 만 9~12세 정도가 되면 성호르몬의 분비가 빨라지면서 2차 성징이 나타나죠. 이 시기를 사춘기라 합니다. <br></span><span>성호르몬이 분비가 되면 성장호르몬과 협력하여 키가 더 빨리 자라게(급속 성장기)&nbsp;해주는 대신, 몇 년 내에 성장이 멈추게 해버립니다. 보통 2차 성징이 시작되고 2년 정도 흐르면 키 성장은 멈추고 더 이상 안자랍니다. (보통의, 일반적인, 대부분의&nbsp;경우입니다.&nbsp;예외적으로 군대가서도 키가 컸다라는 전설적인 경험담을 듣기도 합니다)<br></span><span>그래서 2차성징과 급속성장기가 빨리 오면 빨리 키 성장이 끝나버려서 최종키가 작아질 수도 있는거죠. <br></span><span><br></span><span>요즘에는 인터넷을통한 음란물 노출 등으로 성호르몬 분비가 빨라질 수 있다는 우려도 있습니다.&nbsp;<br></span><span><span><br></span><br></span><span><br></span><span class=\"se_fs_T3\" style=\"color: rgb(241, 47, 34);\"><b>질병</b></span><span></span><span><br></span><span><br></span><span>여러가지 질병으로 몸이 허약하거나 각종 호르몬이 제대로 작용하지 못하게 되면 키 성장에 방해가 되겠죠. <br></span><span>비염, 아토피, 잦은 감기, 중이염 등의 질병이&nbsp;자꾸&nbsp;반복되는 경우도 이에 해당됩니다. <br></span><span>빨리빨리 치료해주는게 좋아요. <br></span><span><br></span><span><br></span><span><br></span><span>오늘은.<br></span><span>우리 아이는 왜 잘 크지 않을까? 에 대한 답을 해봤습니다. <br></span><span><br></span><span>미세먼지가 너무 심하네요.&nbsp;<br></span><span>마스크가 좀 답답하더라도 꼭 쓰고 다니세요~<br></span><span><br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1522037285349-1940379626_image_4_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODAzMjZfMTg2/MDAxNTIyMDM3MTUzNjEz.aaHS0S6nlwIrcy6xgcbFs2qXdQMz6_oCrkwgpQ1D0Fkg.gEMosV5FbgeOTzy4fwM_TZXahRXZ1fTgmgNqNoeW2DEg.PNG.isuhani/%EB%82%98%ED%9A%A8%EC%84%9D%EC%9B%90%EC%9E%A5_%EC%95%BD%EB%A0%A5.png\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1522037285349-1940379626_image_4_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODAzMjZfMTg2/MDAxNTIyMDM3MTUzNjEz.aaHS0S6nlwIrcy6xgcbFs2qXdQMz6_oCrkwgpQ1D0Fkg.gEMosV5FbgeOTzy4fwM_TZXahRXZ1fTgmgNqNoeW2DEg.PNG.isuhani/%EB%82%98%ED%9A%A8%EC%84%9D%EC%9B%90%EC%9E%A5_%EC%95%BD%EB%A0%A5.png?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODAzMjZfMTg2/MDAxNTIyMDM3MTUzNjEz.aaHS0S6nlwIrcy6xgcbFs2qXdQMz6_oCrkwgpQ1D0Fkg.gEMosV5Fbg