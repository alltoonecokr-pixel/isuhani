.net/MjAxOTA3MDJfMTcg/MDAxNTYyMDM2OTcyMDAy.tTxyFsbsmYadHgPeYDpyRD_SkxnLO6XR__inpUw-Efcg.HDhKTL7r0AvztEuHZ5N00gZz8vHcf4t-0oGFZOT_pp0g.JPEG.isuhani/20190628_203841.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                                        <img src=\"https://postfiles.pstatic.net/MjAxOTA3MDJfMTcg/MDAxNTYyMDM2OTcyMDAy.tTxyFsbsmYadHgPeYDpyRD_SkxnLO6XR__inpUw-Efcg.HDhKTL7r0AvztEuHZ5N00gZz8vHcf4t-0oGFZOT_pp0g.JPEG.isuhani/20190628_203841.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxOTA3MDJfMTcg/MDAxNTYyMDM2OTcyMDAy.tTxyFsbsmYadHgPeYDpyRD_SkxnLO6XR__inpUw-Efcg.HDhKTL7r0AvztEuHZ5N00gZz8vHcf4t-0oGFZOT_pp0g.JPEG.isuhani/20190628_203841.jpg?type=w580\" data-width=\"936\" data-height=\"702\" alt=\"\" class=\"se-image-resource\" />\n                                    </a>\n                                    <a href=\"#\" id=\"SE-1e092a27-c21b-4496-b6e1-e93049da6ee1\" class=\"se-module se-module-image __se_image_link __se_link\" style=\"width:50.0%;\" onclick=\"return false;\" data-linktype=\"img\" data-linkdata='{\"id\" : \"SE-1e092a27-c21b-4496-b6e1-e93049da6ee1\", \"src\" : \"https://postfiles.pstatic.net/MjAxOTA3MDJfNjAg/MDAxNTYyMDM2OTcxOTY2._GSGIRZcq0TQt6cQW4EIlkniwKmpl3RQ-RH4SSvXUTgg.P2Y85KRns7pIBPIzmx0QHHmP2B6tOmx1AWED9EVtM3Mg.JPEG.isuhani/20190628_203904.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                                        <img src=\"https://postfiles.pstatic.net/MjAxOTA3MDJfNjAg/MDAxNTYyMDM2OTcxOTY2._GSGIRZcq0TQt6cQW4EIlkniwKmpl3RQ-RH4SSvXUTgg.P2Y85KRns7pIBPIzmx0QHHmP2B6tOmx1AWED9EVtM3Mg.JPEG.isuhani/20190628_203904.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxOTA3MDJfNjAg/MDAxNTYyMDM2OTcxOTY2._GSGIRZcq0TQt6cQW4EIlkniwKmpl3RQ-RH4SSvXUTgg.P2Y85KRns7pIBPIzmx0QHHmP2B6tOmx1AWED9EVtM3Mg.JPEG.isuhani/20190628_203904.jpg?type=w580\" data-width=\"936\" data-height=\"702\" alt=\"\" class=\"se-image-resource\" />\n                                    </a>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                    <script type=\"text/data\" class=\"__se_module_data\" data-module='{\"type\":\"v2_imageGroup\", \"id\" :\"SE-ef4f3d16-8943-4e36-b12b-cd67b66a75b8\", \"data\": { \"layout\" : \"collage\" }}'></script>\n                </div>                <div class=\"se-component se-text se-l-default\" id=\"SE-b6dad864-db60-48ac-b6cc-3fd4af027401\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-6ad30e5e-8024-4517-8926-9cb076633a1c\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-4ef4ac06-8459-4bd1-bcf7-67b08b28ad4a\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-39f9db28-cfb2-4453-a596-a9d2974c8e4f\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-bc4695b2-1b7e-4da3-bd65-0d588ca8c157\">수술해서 제거한 덩어리 사진을 보여줬는데, 크기가 엄청납니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-43b1d0d5-0b34-4517-90f7-c09cc25c42c5\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-bfa939e3-1786-4ecf-a6c5-abc0fb153cca\">8kg. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-1011cd2f-86de-4127-b0f3-840d04f053b9\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-c27eb283-b990-4573-accf-3799cc47d2cd\">물과 덩어리가 섞여있었다 하고, </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-da6611e1-fcfe-4f83-a36b-84aaa62f04d4\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-73f5f5d2-d963-420b-9551-58d9d93cde69\">주변 장에 유착이 되어있어서 장의 일부도 제거했다고 하네요. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-37bf6200-5ac1-4a84-a104-03b4c7d0b782\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-5597b1cb-1421-4ecc-b706-d4538e5946cb\">(치료 중간에 변비가 너무 심해서 치질이 생겼다고 했는데, 장 유착 때문이었던거네요)</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-2a179e74-83da-44c0-8d18-0f6bd3e3a384\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-b647cf14-4ea7-4f1f-9210-bd48c92f1942\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-d62e76b7-ba71-4569-97a4-dece990c2331\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-82884caf-ef1c-4cb2-a394-05ffcf310869\">이 환자분은 다이어트가 아닌 종양 수술이 필요했던 환자분이었던 겁니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-4812b8f0-e75e-4e52-8c35-51012e300a60\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-2f5142b1-f98d-40db-b689-8bc07f8c121a\">종양을 제거하니 체중도 줄고 볼록했던 배도 사라졌어요. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-ca64a017-e16f-4806-ac60-fde6320954d9\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-66d2c408-6f4c-45f4-a10e-9b47e2c0f897\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-dbfea95a-a7aa-4a86-bcec-b3637b00f9fd\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-a8968eb5-73fd-4950-99f0-bd928403213b\">환하게 웃으며 인사하고 가시는 환자분을 보니, 제 마음이 가벼워집니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-2f5230f2-c61c-4681-93c9-4a1445591d40\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-4ee25090-cbb4-4803-acde-bfe14849668d\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-27e50e06-3587-4972-af98-9090a91ea5da\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-9241393c-4de6-4337-8695-1f881aee58de\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-66422e7c-a478-4c6d-8fec-92cd9ff74ca2\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-f3e3419f-fae6-48ba-8fc0-f37db73db5ed\">장 유착도 있었기 때문에 다이어트 치료를 계속 하면서 시간을 끌었으면 응급 상황이 벌어졌을 수도 있었을 것 같은데, 다행히 늦지 않게 발견되서 다행입니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-f179ceb6-5e3a-4109-81ad-2361e0e52225\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-d72a96f8-bf4b-4507-aba9-7a317a56a6c1\">​</span></p><!-- } SE-TEXT --></div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-312096d8-ea41-46d5-9e5a-58dfba11672e\">\n                    <div class=\"se-component-content se-component-content-fit\">\n                        <div class=\"se-section se-section-image se-l-default se-section-align-\" >\n\n                                <a href=\"#\" class=\"se-module se-module-image __se_image_link __se_link\" style=\" \" onclick=\"return false;\" data-linktype=\"img\" data-linkdata='{\"id\" : \"SE-312096d8-ea41-46d5-9e5a-58dfba11672e\", \"src\" : \"https://postfiles.pstatic.net/MjAxOTA3MDJfODcg/MDAxNTYyMDM3NTUwMjg1.Dv4acUyLJgHphcqHXDFpA0bhXdvOadtmk_GoJ3-xRR4g.8DzFbq9yABkvS7D3NAwR8zOSx32K8c59UwZUJrZoIcIg.JPEG.isuhani/경희이수한의원Logo-웹용.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                                    <img src=\"https://postfiles.pstatic.net/MjAxOTA3MDJfODcg/MDAxNTYyMDM3NTUwMjg1.Dv4acUyLJgHphcqHXDFpA0bhXdvOadtmk_GoJ3-xRR4g.8DzFbq9yABkvS7D3NAwR8zOSx32K8c59UwZUJrZoIcIg.JPEG.isuhani/경희이수한의원Logo-웹용.jpg?type=w80_blur\" data-lazy-src=\"https:/