7900765--52252033_se_doc_title_bottom\" class=\"se_doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1542787900765--52252033_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1542787900765--52252033_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>비가 오는 오후&nbsp;&nbsp;<br></span><span>환자분께서 급하게 들어옵니다<br></span><span><br></span><span>\"안녕하세요~\" 하고 인사를 했는데<br></span><span>어머님이 바닥에 꽃한다발을 두고 <br></span><span><br></span><span>다시 밖으로 나가십니다<br></span><span><br></span><span>그래서 밖에서 더 가져오실게 있는줄 알고<br></span><span>도와드리러 가는데<br></span><span><br></span><span>어머님이 안들어오시고 문밖에서 <br></span><span>꽃만 두고 가시려고 말합니다<br></span><span><br></span><span>그래서 문을 열고 어머님 안들어오시냐고<br></span><span>오늘은 치료 안받고 가시는거냐고<br></span><span>꽃은 왜 그냥 두고가시는거냐고 물어봤더니<br></span><span><br></span><span>어머님이 어디 다녀오시는 길인데<br></span><span>꽃을 받아오셨다고<br></span><span><br></span><span>너무 이뻐서&nbsp;<br></span><span>우리 이수한의원에 두고 간다고</span><span><br></span><span><br></span><span>꽃병에 꽂아두라고 하셨어요<br></span><span><br></span><span>그러고 그냥 가셨습니다</span><span><br></span><span><br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\