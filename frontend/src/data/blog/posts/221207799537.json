textarea\"><!-- SE3-TEXT { --><span><br></span><span style=\"color: rgb(0, 0, 0);\">오~ 발라보니 촉촉하네요&nbsp;<br></span><span style=\"color: rgb(0, 0, 0);\">보습력이 짱인거같아요<br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\">특히 겨울에 바르면 더 좋을거같구<br></span><span style=\"color: rgb(0, 0, 0);\">냄새는 자극적이지 않고 아주 은은한 냄새라서 좋아요<br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\">미란더커 크림이라고도 알려지고,<br></span><span style=\"color: rgb(0, 0, 0);\">호주의 바세린이라고 사람들이 많이들 알고계시네요<br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\">선물 감사합니다~&nbsp; 잘쓰겠습니다~</span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n</div>\n<!-- SE_DOC_CONTENTS_END -->\n<div class=\"__se_doc_title_end\" id=\"se_doc_contents_end\"></div>\n<div id=\"SEDOC-1518498773020--9625486_se_doc_footer\" class=\"se_doc_footer\"></div>\n</div></div>\n\t\t\t\t\t\t</div>",
