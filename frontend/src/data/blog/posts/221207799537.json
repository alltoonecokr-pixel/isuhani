SE_DOC_HEADER_TITLE_BOTTOM-->\n        <div id=\"SEDOC-1518498773020--9625486_se_doc_title_bottom\" class=\"se_doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1518498773020--9625486_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1518498773020--9625486_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span style=\"color: rgb(0, 0, 0);\">우리 이수한의원에 거의 매일 내원하시는 환자분께서<br></span><span style=\"color: rgb(0, 0, 0);\">호주를 다녀오셨는데 <br></span><span style=\"color: rgb(0, 0, 0);\">호주에서 선물을 가져다주셨어요~<br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\">Lucas' Papaw Ointment 라는 건데요..<br></span><span style=\"color: rgb(0, 0, 0);\">이게 뭔지 아시는 분 있나요? ^^<br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\">저도 처음보는거라... </span><span><br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1518498773020--9625486_image_0_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODAyMTNfMjMw/MDAxNTE4NDg4MDMyNzI4.FvGagUvYghkCYoxUgBOWrbhgT5ta7zUCe7faDOeDURgg.re4iTqf8tgk6VQoamob9lC59yBaYlUgqM9zm6q-0BQQg.JPEG.isuhani/KakaoTalk_20180213_111019938.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1518498773020--9625486_image_0_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODAyMTNfMjMw/MDAxNTE4NDg4MDMyNzI4.FvGagUvYghkCYoxUgBOWrbhgT5ta7zUCe7faDOeDURgg.re4iTqf8tgk6VQoamob9lC59yBaYlUgqM9zm6q-0BQQg.JPEG.isuhani/KakaoTalk_20180213_111019938.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODAyMTNfMjMw/MDAxNTE4NDg4MDMyNzI4.FvGagUvYghkCYoxUgBOWrbhgT5ta7zUCe7faDOeDURgg.re4iTqf8tgk6VQoamob9lC59yBaYlUgqM9zm6q-0BQQg.JPEG.isuhani/KakaoTalk_20180213_111019938.jpg?type=w580\" data-width=\"960\" data-height=\"960\" width=\"960\" height=\"960\" data-attachment-id=\"IZUPpqTkww2ZlIDh9EUcBGFiZCpU\" alt=\"\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span style=\"color: rgb(0, 0, 0);\">빨간색이라서 처음봤을때 '뭐지? 핸드크림인가? 로션인가?' 하고봤는데<br></span><span style=\"color: rgb(0, 0, 0);\">글씨를 읽어보니 Ointment 라고 쓰여있어서 '연고구나' 라고 생각을했죠..<br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\">그래서 앞뒤로 여기저기 잘 살펴봤습니다<br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\">Carica Papaya 와 Fresh Fermented Fruit 라고 쓰여있죠<br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\">이건 발효시킨 파파야라는 과일로 말들었다는 뜻인걸까요?<br></span><span style=\"color: rgb(0, 0, 0);\">아마도 이 연고의 주 재료인거같은데..<br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\">사실 파파야가 피부미용에 좋다고 알려져있어요 <br></span><span style=\"color: rgb(0, 0, 0);\">파파야는 미백, 보습 등 피부미용에 효과적이고, <br></span><span style=\"color: rgb(0, 0, 0);\">피부의 염증을 가라 앉히고, 피부 트러블을 감소시키는 효과도있습니다. </span><span><br></span><span></span><span><br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1518498773020--9625486_image_1_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODAyMTNfMjA4/MDAxNTE4NDg4NDA2NDk1.tXhNRBGjh7UcMlZBwY2b_C1P1iaDsUkEMdCvwTKqvbwg.ZXKXZHfzYMtSXFKQY9pZsq5LoXGzEbM9nfW8pK2Jfu0g.JPEG.isuhani/KakaoTalk_20180213_111020224.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1518498773020--9625486_image_1_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODAyMTNfMjA4/MDAxNTE4NDg4NDA2NDk1.tXhNRBGjh7UcMlZBwY2b_C1P1iaDsUkEMdCvwTKqvbwg.ZXKXZHfzYMtSXFKQY9pZsq5LoXGzEbM9nfW8pK2Jfu0g.JPEG.isuhani/KakaoTalk_20180213_111020224.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODAyMTNfMjA4/MDAxNTE4NDg4NDA2NDk1.tXhNRBGjh7UcMlZBwY2b_C1P1iaDsUkEMdCvwTKqvbwg.ZXKXZHfzYMtSXFKQY9pZsq5LoXGzEbM9nfW8pK2Jfu0g.JPEG.isuhani/KakaoTalk_20180213_111020224.jpg?type=w580\" data-width=\"960\" data-height=\"960\" width=\"960\" height=\"960\" data-attachment-id=\"I0OI9SsEoPHp0V0WTkAWsaRyFKS8\" alt=\"\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1518498773020--9625486_image_2_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODAyMTNfOTMg/MDAxNTE4NDg4NDA2NDk3.99K0yFa-ueHGTBqlbll6AcXawSPfzvTLKY-Wwlg64D8g.m8Li7yY5QPvNzhu0qECTMNoZgKoRI2xqbI4JgryFE_Mg.JPEG.isuhani/KakaoTalk_20180213_111020360.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1518498773020--9625486_image_2_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODAyMTNfOTMg/MDAxNTE4NDg4NDA2NDk3.99K0yFa-ueHGTBqlbll6AcXawSPfzvTLKY-Wwlg64D8g.m8Li7yY5QPvNzhu0qECTMNoZgKoRI2xqbI4JgryFE_Mg.JPEG.isuhani/KakaoTalk_20180213_111020360.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODAyMTNfOTMg/MDAxNTE4NDg4NDA2NDk3.99K0yFa-ueHGTBqlbll6AcXawSPfzvTLKY-Wwlg64D8g.m8Li7yY5QPvNzhu0qECTMNoZgKoRI2xqbI4JgryFE_Mg.JPEG.isuhani/KakaoTalk_20180213_111020360.jpg?type=w580\" data-width=\"960\" data-height=\"960\" width=\"960\" height=\"960\" data-attachment-id=\"INipLhRYXxE5AgOD1lav3VgxmBYY\" alt=\"\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span style=\"color: rgb(0, 0, 0);\">그래서 검색을 해봤습니다<br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\"><span style=\"color: rgb(0, 0, 0);\">포포(Papaw)나무는&nbsp;북미가&nbsp;원산지인&nbsp;낙엽&nbsp;활엽수로&nbsp;파파야를&nbsp;닮아&nbsp;스페인어로&nbsp;파파야를&nbsp;뜻하는&nbsp;포포라고&nbsp;불렀다는&nbsp;데서&nbsp;유래되었다고 하네요</span><br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\">그리고 이 빨간튜브의 정채는&nbsp;</span><span style=\"color: rgb(0, 0, 0);\">일명&nbsp;\"</span><span style=\"color: rgb(241, 47, 34);\"><b>루카스&nbsp;포포&nbsp;크림</b></span><span style=\"color: rgb(0, 0, 0);\">\"이라고&nbsp;불리네요</span><span> <br> <br></span><span style=\"color: rgb(0, 0, 0);\">효능은</span><span style=\"color: rgb(0, 0, 0);\">&nbsp;:&nbsp;</span><span style=\"color: rgb(241, 47, 34);\">화상,&nbsp;피부마찰,&nbsp;찢긴&nbsp;상처,&nbsp;갈라진&nbsp;피부, 기저귀 발진,&nbsp;벌레 물림,&nbsp;&nbsp;열린상처&nbsp;등<br></span><span style=\"color: rgb(241, 47, 34);\"><br></span><span style=\"color: rgb(0, 0, 0);\">약&nbsp;100여년전&nbsp;루카스&nbsp;박사가&nbsp;발명한&nbsp;호주&nbsp;브리지번산&nbsp;천천&nbsp;파파야&nbsp;나무로&nbsp;만든&nbsp;천연&nbsp;다목적&nbsp;크림이라고&nbsp;하네요<br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\">만능효능이있는 이 포포크림<br></span><span style=\"color: rgb(0, 0, 0);\"></span><span style=\"color: rgb(0, 0, 0);\">제가 한번 발라보겠습니다</span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\"></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n\t\t\t\t