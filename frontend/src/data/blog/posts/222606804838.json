-b1b2-7c7c6fdcfe3b\"><span style=\"\" class=\"se-fs-fs16 se-ff-system   \" id=\"SE-9ed10379-bf62-4404-9e8c-2279d2275119\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-db12ebdc-b253-4df3-8a79-29c2b8bd83a3\"><span style=\"color:#ba0000;\" class=\"se-fs-fs19 se-ff-system   \" id=\"SE-798da389-8348-47c4-a7c9-30e8cc55bb24\">토요일 휴진</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-853f6513-508d-45e7-9001-fe9794309ae8\"><span style=\"color:#ba0000;\" class=\"se-fs-fs19 se-ff-system   \" id=\"SE-4f60c7da-1fc6-42a1-b57c-8d22b1575714\">일요일 정상 진료 진료 이용에 참고해주세요</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-da49e8c1-460c-4e57-9d25-3dc3a73b2623\"><span style=\"\" class=\"se-fs-fs16 se-ff-system   \" id=\"SE-e8b84206-8b5a-4c3d-995e-766af86182cf\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-90999307-92f0-4bab-8f72-678826f560d9\"><span style=\"\" class=\"se-fs-fs16 se-ff-system   \" id=\"SE-d194cad7-75ab-4321-bf36-d04a8bc73da8\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-a6925090-8561-4434-93b6-aec6c6491722\"><span style=\"\" class=\"se-fs-fs16 se-ff-system   \" id=\"SE-b6b31cc9-0625-499d-a620-ed869cf16e7b\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-62ca4e17-3dc4-469f-8ded-12a75ec1aabb\"><span style=\"\" class=\"se-fs-fs16 se-ff-system   \" id=\"SE-765bafc0-d0e7-4cc5-96f9-e14ea3802173\">그럼 모두, </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-fb187eed-8ce3-4727-bd39-a57bf0fb28a2\"><span style=\"\" class=\"se-fs-fs16 se-ff-system   \" id=\"SE-475f3543-3620-481a-b3e3-cbf7686b663f\">2021년 잘 마무리 하시고,</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-76ee6961-5f55-4c57-a27c-746961db726c\"><span style=\"\" class=\"se-fs-fs16 se-ff-system   \" id=\"SE-7144dc3e-915e-444e-9732-7ca63f6ce42a\">2022년 새해에는 세상에 있는 모든 복 많이많이 받으시고</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-f3356304-5780-44f6-9f46-4a1355f05e61\"><span style=\"\" class=\"se-fs-fs16 se-ff-system   \" id=\"SE-5499aef8-b5c0-4b28-ac44-8ebd5e291713\">1번도 건강, 2번도 건강, 3번도 건강하시구요</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-ae0ce0b5-fe10-4b70-aefd-7a5cb1eb9543\"><span style=\"\" class=\"se-fs-fs16 se-ff-system   \" id=\"SE-7cae57b1-092e-4deb-8086-d433498966ff\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-95d8bf0c-5b98-4c15-a4b5-26c31eca41bf\"><span style=\"\" class=\"se-fs-fs16 se-ff-system   \" id=\"SE-ccbb334f-aa0d-4d6d-a729-9660018e9f7e\">내년에는 올해보다 더더 건강하고 더 행복하고</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-c944e571-bc91-4fa8-8046-9fc4d4bb7812\"><span style=\"\" class=\"se-fs-fs16 se-ff-system   \" id=\"SE-62442b9c-bf11-4519-a216-5761a2369860\">더 좋은 일들만 생기길 소망하고 희망합니다 </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-05113354-9efd-461d-a044-cfb4f080de7d\"><span style=\"\" class=\"se-fs-fs16 se-ff-system   \" id=\"SE-a9c48e34-d972-49ad-9875-a6d2844efcf1\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-1774b39c-4c2c-432c-a423-3b41e1fec758\"><span style=\"\" class=\"se-fs-fs16 se-ff-system   \" id=\"SE-fa43128c-da57-4378-84cd-0ccea193e22e\">내년에는 부디</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-95d9840f-24c7-4871-ad48-29aaa9cd53fe\"><span style=\"\" class=\"se-fs-fs16 se-ff-system   \" id=\"SE-77cbbf54-f08c-4448-8f4c-d123bc98bd97\">코로나가... 어느날 갑자기 증발해서</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-d28502fc-5d7a-4a9f-8811-18f0a28d62d0\"><span style=\"\" class=\"se-fs-fs16 se-ff-system   \" id=\"SE-cd52e935-247d-423d-85c7-7ed2ea53eb3a\">사라지는 기적같은 일이 생기길 아주아주 간절히 기도해봅니다 </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-a91d61e8-7a4a-4a1b-a869-52f0d76322ac\"><span style=\"\" class=\"se-fs-fs16 se-ff-system   \" id=\"SE-b502a278-ee5f-479b-ae84-5e1a10ef33f7\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-4ec0319a-1f41-46e1-9751-67d127aa087e\"><span style=\"\" class=\"se-fs-fs16 se-ff-system   \" id=\"SE-8753ae6f-e546-4e0f-9121-913042613d6b\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-3bfa8b48-7336-4f82-ac31-5a35fe55fd05\"><span style=\"\" class=\"se-fs-fs16 se-ff-system   \" id=\"SE-b534220f-d0e0-4f06-aaa8-13d0113b74a6\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-bffc6433-65dd-4dd1-b94a-651eeb149c58\"><span style=\"\" class=\"se-fs-fs16 se-ff-system   \" id=\"SE-5da754ed-3862-4d73-960b-5d49d3230b80\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-e492838b-6e41-445d-b6a5-9f304f5537c3\"><span style=\"\" class=\"se-fs-fs16 se-ff-system   \" id=\"SE-099fb74e-0230-448a-b561-d69d2be70b12\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-alig