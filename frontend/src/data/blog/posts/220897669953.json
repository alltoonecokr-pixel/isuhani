  "body": "<div id=\"post-view220897669953\" class=\" pcol2 _param(1) _postViewArea220897669953\">\n\t\t\t\t\t\t\t<div style=\"font-size:10pt; font-family:'957317_10';\" class=\"view\"><div id=\"SEDOC-1482986510868-8565018\" class=\"se_doc_viewer se_body_wrap se_theme_transparent \" data-docversion=\"\">\n<div class=\"se_doc_header_start\" id=\"SEDOC-1482986510868-8565018_se_doc_header_start\"></div>\n<!-- SE_DOC_HEADER_START -->\n<div id=\"SEDOC-1482986510868-8565018_viewer_head\" class=\"se_viewer_head\"></div>\n<div class=\"se_component_wrap\">\n<div class=\"se_component se_documentTitle documentTitle_blog  is-fill\">\n    <div class=\"se_sectionArea is-fill se_align-left\">\n        <!-- --> \n<div class=\"blog2_series\">\n\t<a href=\"/PostList.naver?blogId=isuhani&categoryNo=39&from=postList\" class=\"pcol2\" onclick=\"sendClickNlog('pst.category','');\">소아</a>\n</div>\n<div class=\"pcol1\"> \n<!--\n -->\n        <!-- SE_DOC_HEADER_TITLE_TOP-->\n     \t<div id=\"SEDOC-1482986510868-8565018_se_doc_title_top\" class=\"se_doc_title_top\"></div>\n        <div class=\"se_editArea\">\n        \t<div class=\"se_viewArea se_ff_nanumgothic se_fs_D2\">\n\t            <div class=\"se_editView se_title\">\n\t                <div class=\"se_textView\">\n                        <h3 class=\"se_textarea\">\n                            <!-- -->독감 치료, 한약으로 효과 볼까?<!-- -->\n                            \n                        </h3>\n\t                </div>\n\t            </div>\n\t        </div>\n        </div><!-- SE_DOC_HEADER_TITLE_MIDDLE-->\n        <div id=\"SEDOC-1482986510868-8565018_se_doc_title_middle\" class=\"se_doc_title_middle\"></div>\n        <!-- SE_DOC_HEADER_CONTENTS_START -->\n        <!-- -->\n</div>\n<div class=\"blog2_container\">\n    <span class=\"writer\">\n        <span class=\"area_profile\"><a href=\"https://blog.naver.com/isuhani\" class=\"link\" onclick=\"sendClickNlog('pst.profile', '');\" target=\"_top\"><img src=\"https://blogpfthumb-phinf.pstati