5339445_se_doc_title_bottom\" class=\"se_doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1515986551800--1725339445_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1515986551800--1725339445_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span><strong>여성의 경우 나이가 많아지면서 임신의 가능성이 낮아진다는 것은 많이들 알고 있을 것입니다.&nbsp;</strong><br></span><span><strong></strong><br></span><span><strong></strong><br></span><span><strong>아래의 그래프를 보시죠.</strong></span><br><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1515986551800--1725339445_image_0_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODAxMTVfOTMg/MDAxNTE1OTg1MTAxNzI5.fpp2v08HobBfi18QV-b9BBoMC91H6nymQCcHPAtuwPkg.p92wzgsMx8mHVTPO5_4W_E38hFcbCo87IHgD-U2ePY4g.JPEG.isuhani/02.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1515986551800--1725339445_image_0_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODAxMTVfOTMg/MDAxNTE1OTg1MTAxNzI5.fpp2v08HobBfi18QV-b9BBoMC91H6nymQCcHPAtuwPkg.p92wzgsMx8mHVTPO5_4W_E38hFcbCo87IHgD-U2ePY4g.JPEG.isuhani/02.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODAxMTVfOTMg/MDAxNTE1OTg1MTAxNzI5.fpp2v08HobBfi18QV-b9BBoMC91H6nymQCcHPAtuwPkg.p92wzgsMx8mHVTPO5_4W_E38hFcbCo87IHgD-U2ePY4g.JPEG.isuhani/02.jpg?type=w580\" data-width=\"552\" data-height=\"390\" width=\"552\" height=\"390\" data-attachment-id=\"Igqvq-EieDhc3o4euuaK6GmfOB08\" alt=\"\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span><b>(www.creaconceptions. com)</b><br></span><span><b></b></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><br><span><strong>위 그래프에서 검은색 선은 임신가능성을 나타냅니다</strong><br></span><span><strong>녹색 선은 불임가능성이죠. </strong><br></span><span><strong></strong><br></span><span><strong>그래프를 보면</strong><br></span><span><strong>20대 초반은 임신 가능성이 86%, 불임가능성은 3% 정도입니다.&nbsp; 불임 가능성이 아주 낮고, 임신이 잘 되는 나이입니다. </strong><br></span><span><strong></strong><br></span><span><strong>나이가 들 수록 </strong></span><span><strong> 임신가능성은 점차 낮아지고, 불임의 확률은 높아져갑니다. </strong></span><br>&nbsp;<br><strong>우리가 흔히 노산이라 말할 때 기준이 되는 나이인 35세가 넘어가면&nbsp;</strong><br><span><strong>임신 가능성이&nbsp;절반(52%)으로 줄어들고, 불임률이 15%를 넘어서기 시작합니다.&nbsp; </strong><br></span><span><strong></strong><br></span><span><strong>40대 초반에 들어서면 임신가능성보다 불임가능성이 더 높아지고</strong><br></span><span><strong></strong></span><span><strong>50세이상은 임신가능성이 0%가 됩니다(물론 순수하게 0%는 아닙니다. 간혹&nbsp;50세가 넘었는데 임신했다는 해외토픽 소식이 있긴 하죠)</strong></span><span><br></span>&nbsp;<br><br><b></b><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1515986551800--1725339445_image_1_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODAxMTVfMTQ1/MDAxNTE1OTg1MTAxNzI5.4jUr4WUKe9grWZXLrn0IAQF7LoESl6JHZ3mwiRA2itQg.AAwb5KMfRQ43Zzmi2Q2uGCVkqPAF7kkEyCURbjiXJD8g.JPEG.isuhani/slide_5.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1515986551800--1725339445_image_1_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODAxMTVfMTQ1/MDAxNTE1OTg1MTAxNzI5.4jUr4WUKe9grWZXLrn0IAQF7LoESl6JHZ3mwiRA2itQg.AAwb5KMfRQ43Zzmi2Q2uGCVkqPAF7kkEyCURbjiXJD8g.JPEG.isuhani/slide_5.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODAxMTVfMTQ1/MDAxNTE1OTg1MTAxNzI5.4jUr4WUKe9grWZXLrn0IAQF7LoESl6JHZ3mwiRA2itQg.AAwb5KMfRQ43Zzmi2Q2uGCVkqPAF7kkEyCURbjiXJD8g.JPEG.isuhani/slide_5.jpg?type=w580\" data-width=\"960\" data-height=\"720\" width=\"960\" height=\"720\" data-attachment-id=\"I4hSFrccBbqtvo2PH2AzFvV3JlnA\" alt=\"\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span><b>위 그래프의 파란색 선은 임신가능성입니다. 20대 초반에 100%에 가깝던 그래프가 급격히 떨어지면서 40-44세가 되면 임신가능성이 아주 낮아지죠. 첫 그래프과 비슷합니다.&nbsp; </b><br></span><span><b></b><br></span><span><b>회색 선은 임신 후 유산하는 비율을 나타냅니다. </b><br></span><span><b>35세 즈음부터 증가하면서 40세가 넘어가면 40% 정도의 산모가 유산을 한다는 것을 보여주는 그래프입니다. </b><br></span><span><b>(<a class=\"se_link\" href=\"http://www.medscape.com\" target=\"_blank\">www.medscape.com</a></b></span><span><b>)</b><br></span><span><b></b><br></span><span><b>여성의 나이가 증가할 수록 임신하기가 힘들고, 더군다나&nbsp;유산의 확률이 높아지기 때문에 임신을 했더라도 아기를 출산하기까지 넘어야 할 산이 높습니다. </b><br></span><span><b></b></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span><b></b><br></span><span><b></b><br></span><span><b>나이가 어리지만 임신이 잘 안되는 '난임'부부, </b><br></span><span><b>30대 중반을 넘어선 임신을 원하는 부부</b><br></span><span><b>둘째를 원하지만 임신이 잘 안되는 경우</b><br></span><span><b>임신은 되지만 유산을 하게 되는 경우</b><br></span><span><b>는</b><br></span><span><b>한방 치료로 몸 건강하게, 자궁이 튼튼하게하여 임신이 잘 될 수 있게 해주세요.</b><br></span><span><b></b></span><span><b>임신이 된 후에도 유산이 되지 않도록 '안태(安胎)'를 위한 한방치료 및&nbsp;관리를 해주세요. </b><br></span><span><br></span><span><b></b></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-right\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span><b>남성역 1번출구 앞</b><br></span><span><b>이수한의원</b><br></span><span><b>예약 02-584-1075</b><br></span><span><b>진료시간 확인 <a class=\"se_link\" href=\"https://blog.naver.com/isuhani/110135960820\" target=\"_blank\">https://blog.naver.com/isuhani/110135960820</a></b></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n<div class=\"se_component se_oglink og_bSize \">\n    <div class=\"se_sectionArea se_align-left\">\n        <div class=\"se_editArea\" id=\"SEDOC-1515986551800--1725339445_oglink_0\">\n            <div class=\"se_viewArea se_og_wrap\">\n                <a class=\"se_og_box  __se_link\" href=\"https://blog.naver.com/isuhani/110135960820\" target=\"_blank\" data-linktype=\"link\" data-linkdata='{\"link\" : \"https://blog.naver.com/isuhani/110135960820\"}'>\n                    <div class=\"se_og_txt\">\n                            <div class=\"se_og_tit\">의료진 소개, 진료시간, 카카오 상담</div>\n                                <div class=\"se_og_desc\">* 미리 전화예약 주시고 오시면 편하게 진료받으실 수 있습니다. TEL : 02-584-1075-------------------...</div>\n                            <div class=\"se_og_cp\">blog.naver.com</div>\n\n                    </div>\n                </a>\n            </div>\n        </div>\n    </div>\n</div>\n<script type=\"text/data\" class=\"__s