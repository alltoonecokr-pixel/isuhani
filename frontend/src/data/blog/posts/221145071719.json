>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1511246414851--164560177_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1511246414851--164560177_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>이수한의원이 </span><span><span lang=\"EN-US\">개원 10주년을 맞이 합니다.&nbsp;</span><br></span><span><span lang=\"EN-US\">이곳 남성역 1번출구 앞에서 진료한지 벌써 10년 입니다!!</span><br></span><span><span lang=\"EN-US\"></span><br></span><span><span lang=\"EN-US\">개원 10주년을 맞아,&nbsp;양질의 의료서비스를 제공하기 위해</span><br></span><span><span lang=\"EN-US\">한방부인과 전문의면서&nbsp;10여년간 함소아한의원 소아진료 경력의 나효석원장님을 초빙합니다. </span><br></span><span><span lang=\"EN-US\"></span><br></span><span><span lang=\"EN-US\">나효석원장님의 영입으로</span><br></span><span><span lang=\"EN-US\">감기, 호흡기질환, 중이염, 성장, 성조숙,&nbsp;틱(Tic)장애&nbsp;등의 소아과 질환에 대한 전문적인 진료와 치료를 제공할 수 있게 되었습니다. </span><br></span><span><span lang=\"EN-US\">또한 한방부인과 전문의인 여자원장님이라서&nbsp;생리불순, 자궁질환, 갱년기, 화병 등 여성 질환에 대해 편안하게 진료를 받을 수 있을 것으로 기대됩니다. </span><br></span><span><br></span><span><span lang=\"EN-US\"></span></span><span><span lang=\"EN-US\"> 문학진원장님 진료와함께 나효석원장님의 전문진료가 가능한 시스템을 확충하기 위해서는 병원의 리모델링이 불가피합니다. </span><br></span><span><span lang=\"EN-US\"></span><br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1511246414851--164560177_image_0_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxNzExMjFfMjQ5/MDAxNTExMjQ2Mzk1OTM0.qY9wgsQ9xWuCh8vEKBZMancYC10560-gjCzMlK5bUm4g.p02UJM5sedMqSVR2-aIizuFoMNwrkMOnVbv16KFqcwEg.JPEG.isuhani/171120-7%ED%98%B8%EC%84%A0-%EB%82%A8%EC%84%B13_4%EB%B2%88%EC%B6%9C%EA%B5%AC73702R-%EA%B2%BD%ED%9D%AC%EC%9D%B4%EC%88%98%ED%95%9C%EC%9D%98%EC%9B%90-%EC%9B%90%EB%B3%B8-01.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1511246414851--164560177_image_0_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxNzExMjFfMjQ5/MDAxNTExMjQ2Mzk1OTM0.qY9wgsQ9xWuCh8vEKBZMancYC10560-gjCzMlK5bUm4g.p02UJM5sedMqSVR2-aIizuFoMNwrkMOnVbv16KFqcwEg.JPEG.isuhani/171120-7%ED%98%B8%EC%84%A0-%EB%82%A8%EC%84%B13_4%EB%B2%88%EC%B6%9C%EA%B5%AC73702R-%EA%B2%BD%ED%9D%AC%EC%9D%B4%EC%88%98%ED%95%9C%EC%9D%98%EC%9B%90-%EC%9B%90%EB%B3%B8-01.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxNzExMjFfMjQ5/MDAxNTExMjQ2Mzk1OTM0.qY9wgsQ9xWuCh8vEKBZMancYC10560-gjCzMlK5bUm4g.p02UJM5sedMqSVR2-aIizuFoMNwrkMOnVbv16KFqcwEg.JPEG.isuhani/171120-7%ED%98%B8%EC%84%A0-%EB%82%A8%EC%84%B13_4%EB%B2%88%EC%B6%9C%EA%B5%AC73702R-%EA%B2%BD%ED%9D%AC%EC%9D%B4%EC%88%98%ED%95%9C%EC%9D%98%EC%9B%90-%EC%9B%90%EB%B3%B8-01.jpg?type=w580\" data-width=\"2835\" data-height=\"3402\" width=\"2835\" height=\"3402\" data-attachment-id=\"IVxGhGgKFjq64yBoIIiY-3jeERn8\" alt=\"\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span><br></span><span><br></span><span><span lang=\"EN-US\">그래서 </span></span><span><span lang=\"EN-US\">11월 27일부터 12월 16일까지 한의원 리모델링 공사를 진행합니다. </span><br></span><span><span lang=\"EN-US\"></span><br></span><span><span lang=\"EN-US\">이수한의원은</span><br></span><span><span lang=\"EN-US\"></span></span><span class=\"se_fs_T2\"><span class=\"se_fs_T2\" lang=\"EN-US\"><b> 이번주 토요일(11월 25일)까지 정상진료하고</b></span></span><span><span lang=\"EN-US\">,</span><br></span><span><span lang=\"EN-US\"> 리모델링 후, </span><br></span><span class=\"se_fs_T2\"><span class=\"se_fs_T2\" lang=\"EN-US\"><b>12월 18일(월)부터 다시 진료를 시작합니다. </b></span></span><span><span lang=\"EN-US\"></span><br></span><span><span lang=\"EN-US\"></span><br></span><span><span lang=\"EN-US\">진료이용에 참고하시길 부탁드리고, </span><br></span><span><span lang=\"EN-US\">더 나은 더 전문적인 진료로 보답하겠습니다. </span><br></span><span><br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n</div>\n<!-- SE_DOC_CONTENTS_END -->\n<div class=\"__se_doc_title_end\" id=\"se_doc_contents_end\"></div>\n<div id=\"SEDOC-1511246414851--164560177_se_doc_footer\" class=\"se_doc_footer\"></div>\n</div></div>\n\t\t\t\t\t\t</div>",
