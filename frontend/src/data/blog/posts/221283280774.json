1413_se_doc_title_bottom\" class=\"se_doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1527151464735-534351413_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1527151464735-534351413_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span style=\"color: rgb(0, 0, 0);\">주말마다 내원해서&nbsp;성장치료 받는 <br></span><span style=\"color: rgb(0, 0, 0);\">꼬마 환자 어머님이 </span><span style=\"color: rgb(0, 0, 0);\">주신 박카스를 <br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\">오늘에서야 먹어보네요~<br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\">냉장고에서 바로 꺼내서 그런지<br></span><span style=\"color: rgb(0, 0, 0);\">너무 시원해요 ^^<br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\">캬~<br></span><span><br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1527151464735-534351413_image_0_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODA1MjRfNTgg/MDAxNTI3MTQ5NzE2Mjk2.Aj6GH2FC-JrW5sTsVLucQhlN_pwCv3OUSOKidXqTX4Yg.L7I162UwowglJ5Ei3CkUIDN5LsMf-BLMmRr2HayrCLUg.JPEG.isuhani/KakaoTalk_20180524_164341084.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1527151464735-534351413_image_0_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODA1MjRfNTgg/MDAxNTI3MTQ5NzE2Mjk2.Aj6GH2FC-JrW5sTsVLucQhlN_pwCv3OUSOKidXqTX4Yg.L7I162UwowglJ5Ei3CkUIDN5LsMf-BLMmRr2HayrCLUg.JPEG.isuhani/KakaoTalk_20180524_164341084.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODA1MjRfNTgg/MDAxNTI3MTQ5NzE2Mjk2.Aj6GH2FC-JrW5sTsVLucQhlN_pwCv3OUSOKidXqTX4Yg.L7I162UwowglJ5Ei3CkUIDN5LsMf-BLMmRr2HayrCLUg.JPEG.isuhani/KakaoTalk_20180524_164341084.jpg?type=w580\" data-width=\"720\" data-height=\"960\" width=\"720\" height=\"960\" data-attachment-id=\"ISLGpF6cytEDktaM3fSd8SL7kw40\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span style=\"color: rgb(0, 76, 128);\">박카스 D</span><span style=\"color: rgb(0, 0, 0);\"> 라고 쓰여져있어서</span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\">D가 뭔지 궁굼해서 또.. 검색 해보았어요</span><br><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span style=\"color: rgb(0, 0, 0);\">검색해보니<span style=\"color: rgb(0, 0, 0);\">&nbsp;</span></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(99, 99, 99);\">\"1963년에 출시된 자양강장제로서, 타우린과 이노시톨이 함유되어 있다.<span style=\"color: rgb(99, 99, 99);\">&nbsp;</span></span><span style=\"color: rgb(99, 99, 99);\"><br></span><span style=\"color: rgb(99, 99, 99);\">1961년 '박카스-정'이 출시되었으며, 이듬해에는 앰플형태로 나왔다.<span style=\"color: rgb(99, 99, 99);\">&nbsp;</span></span><span style=\"color: rgb(99, 99, 99);\"><br></span><span style=\"color: rgb(99, 99, 99);\">1963년 현재와 같이 병에 담아 판매하면서 이름을 '박카스-디'를 지었다. 디(D)는 드링크(Drink)의 약자이다.<span style=\"color: rgb(99, 99, 99);\">&nbsp;</span></span><span style=\"color: rgb(99, 99, 99);\"><br></span><span style=\"color: rgb(99, 99, 99);\">1991년에는 '박카스-에프'를 출시하였는데, 에프(F)는 포르테(forte)를 뜻한다.<span style=\"color: rgb(99, 99, 99);\">&nbsp;</span></span><span style=\"color: rgb(99, 99, 99);\"><br></span><span style=\"color: rgb(99, 99, 99);\">2005년에는 다시 '박카스·디'로 바뀌었다. 이는 타우린 함량을 두배로 늘려 더블(Double)의 약자를 붙인 것이다.<span style=\"color: rgb(99, 99, 99);\">&nbsp;</span></span><span style=\"color: rgb(99, 99, 99);\"><br></span><span style=\"color: rgb(99, 99, 99);\">3월 자매품인 '박카스-디카페'를 의약품으로 출시하였다. 카페인이 들어있지 않으며, 두충이 함유되었다.<span style=\"color: rgb(99, 99, 99);\">&nbsp;</span></span><span style=\"color: rgb(99, 99, 99);\"><br></span><span style=\"color: rgb(99, 99, 99);\">현재 의약외품으로 분류되어, 슈퍼에서도 판매되고 있다. \" </span><span style=\"color: rgb(0, 0, 0);\">라고 되있네요</span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span style=\"color: rgb(0, 0, 0);\">이제 다들 아시겠죠?</span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\">으.. 저만 몰랐나요? (&gt;&lt;)/</span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\">박카스의 효능은</span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(241, 47, 34);\">육체피로, 병후의 체력저하, 식욕부진, 영양장애, 발열성, 소모성 질환 등의 경우 영양보급, 자양강장, 허약체질</span><span style=\"color: rgb(0, 0, 0);\"> 이라고 쓰여져있어요</span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span style=\"color: rgb(241, 47, 34);\">1일 1회 1병 복용</span><span style=\"color: rgb(0, 0, 0);\"> 이구요</span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\">오늘 1병 먹었으니, </span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\">꼬마환자 어머님의 정성과 사랑이 담긴 박카스를 먹어서</span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\">힘이 번쩍번쩍!! 날거에요 ^^ </span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\">감사합니다~</span><span style=\"color: rgb(0, 0, 0);\"><br></span><span style=\"color: rgb(0, 0, 0);\">이번주의 피로는 싹 다 날라갑니다~</span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n\n\n\n\n<div class=\"se_component se_sticker default \">\n\t<div class=\"se_sectionArea se_align-left\">\n\t\t<div class=\"se_editArea\">\n\t\t\t<div class=\"se_viewArea\">\n\t\t\t\t<div id=\"SEDOC-1527151464735-534351413_sticker_0\" class=\"se_sticker_area\">\n\t\t\t\t \t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_sticker_link __se_link\" data-linktype=\"sticker\" data-linkdata='{\"src\" : \"http://gfmarket.phinf.naver.net/moon_and_james/original_2.png\", \"packCode\" : \"moon_and_james\", \"seq\" : \"2\", \"width\" : \"105\", \"height\" : \"120\"}'>\n\t\t\t\t\t\t<img src=\"https://storep-phinf.pstatic.net/moon_and_james/original_2.png?type=p50_50\" class=\"__se_img_el\" alt=\"스티커 이미지\" width=\"105\" height=\"120\">\n\t\t\t\t\t</a>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n</div>\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n</div>\n<!-- SE_DOC_CONTENTS_END -->\n<div class=\"__se_doc_title_end\" id=\"se_doc_contents_end\"></div>\n<div id=\"SEDOC-1527151464735-534351413_se_doc_footer\" class=\"se_doc_footer\"></