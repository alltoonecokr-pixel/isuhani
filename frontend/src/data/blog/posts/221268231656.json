le_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1525422122151-141869401_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1525422122151-141869401_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>키가 작은 아이들 중에는<br></span><span>부모님이 '우리애는 너무 안먹어요'라고 말하는 애들이 종종 있습니다.&nbsp;</span><span><br></span><span><br></span><span>옛말에 '살이 키로 간다'는 말도 있죠. <br></span><span>물론!!! 과체중인 아이들은 이 살들이 나중에 다&nbsp;키로&nbsp;갈꺼라고 믿고 방치하면 안됩니다. 소아비만은&nbsp;꼭~~ 해결해줘야해요. <br></span><span><br></span><span>근데, 안먹어서 마른 애들은 잘 먹고 체중이 늘게 해줘야 하겠죠. 잘 먹어야 키도 큽니다. 성장에 필요한 영양분들이 있어야죠. <br></span><span><br></span><span>아래 그래프를 볼까요?<br></span><span><br></span><span>만 8세 여자아이의 체중 변화 그래프입니다. </span><span><br></span><span></span><br><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1525422122151-141869401_image_0_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODA1MDRfMTQw/MDAxNTI1NDIxNDY4NDI5.ACnjGnCWXOTiEljKmlnOkMTqXGEoUzEwv76va30tNhUg.7uyvqQBojwkyHLRij-43qsZSsmDKFehTx1Q60JO1LIEg.PNG.isuhani/8%EC%84%B8_%EC%97%AC%EC%95%84_%EC%B2%B4%EC%A4%91%EB%B3%80%ED%99%94_%E3%85%8A.png\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1525422122151-141869401_image_0_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODA1MDRfMTQw/MDAxNTI1NDIxNDY4NDI5.ACnjGnCWXOTiEljKmlnOkMTqXGEoUzEwv76va30tNhUg.7uyvqQBojwkyHLRij-43qsZSsmDKFehTx1Q60JO1LIEg.PNG.isuhani/8%EC%84%B8_%EC%97%AC%EC%95%84_%EC%B2%B4%EC%A4%91%EB%B3%80%ED%99%94_%E3%85%8A.png?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODA1MDRfMTQw/MDAxNTI1NDIxNDY4NDI5.ACnjGnCWXOTiEljKmlnOkMTqXGEoUzEwv76va30tNhUg.7uyvqQBojwkyHLRij-43qsZSsmDKFehTx1Q60JO1LIEg.PNG.isuhani/8%EC%84%B8_%EC%97%AC%EC%95%84_%EC%B2%B4%EC%A4%91%EB%B3%80%ED%99%94_%E3%85%8A.png?type=w580\" data-width=\"807\" data-height=\"815\" width=\"807\" height=\"815\" data-attachment-id=\"IDCiMT80JDEnp_Mw1wXFHj211e9M\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>처음 치료를 시작했던 시기에 비해 체중이 많이 늘었습니다. <br></span><span>그래프 곡선 (성장곡선)을 3칸 정도 뛰어넘은 게 보이죠? (빨간 화살표)<br></span><span><br></span><span>(그래프의 중간에 가장 굵은 청색선이 또래아이 평균입니다. 이 아이는 평균보다 한참 못미치는, \"너무 마른\" 아이였습니다)<br></span><span><br></span><span>그러면 아래 그래프를 이어서 볼께요<br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1525422122151-141869401_image_1_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODA1MDRfMjcx/MDAxNTI1NDIxNTUyNDMz.BLeYjgp8_ym2GofPBI6wYGTURaFTCn9D5y48HlqkAKMg.dm_xzJK08eEq8LNIYS0J6vZkEf4ulaqb77JaVVWS_Agg.PNG.isuhani/8%EC%84%B8_%EC%97%AC%EC%95%84_%ED%82%A4_%EB%B3%80%ED%99%94_5.png\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1525422122151-141869401_image_1_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODA1MDRfMjcx/MDAxNTI1NDIxNTUyNDMz.BLeYjgp8_ym2GofPBI6wYGTURaFTCn9D5y48HlqkAKMg.dm_xzJK08eEq8LNIYS0J6vZkEf4ulaqb77JaVVWS_Agg.PNG.isuhani/8%EC%84%B8_%EC%97%AC%EC%95%84_%ED%82%A4_%EB%B3%80%ED%99%94_5.png?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODA1MDRfMjcx/MDAxNTI1NDIxNTUyNDMz.BLeYjgp8_ym2GofPBI6wYGTURaFTCn9D5y48HlqkAKMg.dm_xzJK08eEq8LNIYS0J6vZkEf4ulaqb77JaVVWS_Agg.PNG.isuhani/8%EC%84%B8_%EC%97%AC%EC%95%84_%ED%82%A4_%EB%B3%80%ED%99%94_5.png?type=w580\" data-width=\"852\" data-height=\"808\" width=\"852\" height=\"808\" data-attachment-id=\"IFhrHO7onjY8DVoVUGlrdNKlOSk4\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>같은 여자아이의 키 변화입니다. <br></span><span>처음 치료를 시작하던 시기보도 키도 많이 자랐습니다. <br></span><span><br></span><span>이 그래프는 성장곡선에 키를 측정할때마다 표시를 해서 빨간 선으로 이은겁니다. 나이가 들어가면서 키가 커지니까 표시부위는 점점 위를 향해 갑니다. 중요한 건, 위로 얼마나 많이~ 올라가느냐죠. <br></span><span><br></span><span>이 여자아이는 성장곡선을 2칸 이상 뛰어넘었습니다. <br></span><span>(아이 성장에 관심이 있고, 성장치료를 받아보신 부모님이라면 성장곡선에서 한 칸을 뛰어넘는게 얼마나 어려운 일인지 아실겁니다)</span><span><br></span><span><br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>이 두 개의 그래프에서 강조하고 싶은 점은<br></span><span>이 아이가 체중이 늘기 시작하면서 키도 빨리 크기 시작했다는 겁니다!!!!<br></span><span><br></span><span>잘 먹고, 잘 놀고, 잘 자면서 잔병치례를 안하게 하는 것이 성장치료의 기본이라고 볼 수 있습니다. <br></span><span><br></span><span>아이가 어려서부터 (만 2세 이전에 이미 알 수 있습니다. 당연히 치료도 만 2세 이전부터 해주면 좋습니다. 만 2세가 중요한 이유는 다음에 기회가 되면 알려드리기로 할께요) 잘 안먹는 아이인걸 알게 된다면, 잘 먹을 수 있게끔 치료를 해주면 키가 크는데 큰 도움이 될 겁니다. <br></span><span><br></span><span>이상 남성역 1번 출구 앞에 있는 이수한의원이었습니다~~~~~<br></span><span></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1525422122151-141869401_image_2_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODA1MDRfMjUx/MDAxNTI1NDIyMDA0MzAx.3kNr34ZfIIrTYFt76U96Sd_thazr44rer4RT84PlP2