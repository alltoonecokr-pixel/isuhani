e_doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1521597616360-1536931101_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1521597616360-1536931101_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>글로벌 자동차 업체인 '우버'에서 선보인<br></span><span>자율주행차가 지난주에 보행자가 사망하는 교통사로를 냈습니다.<br></span><span>자율주행차에 의한 교통사고 여파가 여러 기업들의 자율주행차 개발에 여러모로 영향을 끼치고 있습니다. <br></span><span>관련기사 <a class=\"se_link\" href=\"http://news.joins.com/article/22459750\" target=\"_blank\">http://news.joins.com/article/22459750</a><br></span><span><br></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n<div class=\"se_component se_oglink default \">\n    <div class=\"se_sectionArea se_align-left\">\n        <div class=\"se_editArea\" id=\"SEDOC-1521597616360-1536931101_oglink_0\">\n            <div class=\"se_viewArea se_og_wrap\">\n                <a class=\"se_og_box  __se_link\" href=\"http://news.joins.com/article/22459750\" target=\"_blank\" data-linktype=\"link\" data-linkdata='{\"link\" : \"http://news.joins.com/article/22459750\"}'>\n                    <div class=\"se_og_thumb\">\n                        <img src=\"https://dthumb-phinf.pstatic.net/?src=%22http%3A%2F%2Fpds.joins.com%2Fnews%2Fcomponent%2Fhtmlphoto_mmdata%2F201803%2F21%2F71344e37-4c29-4387-b43c-f49693304f17.jpg%22&type=ff120\" alt=\"\">\n\t\t\t\t\t</div>\n                    <div class=\"se_og_txt\">\n                            <div class=\"se_og_tit\">우버 자율차 첫 보행자 사망사고 … 한밤 도로 갓길은 못 보나</div>\n                                <div class=\"se_og_desc\">경찰 관계자는 &quot;우버의 자율주행 차량이 도로 갓길의 사람을 인지하지 못한 것으로 파악하고 있다&quot;고 밝혔다. 경찰과 우버는 차량이 피해자를 인지하지 못한 이유가 센서를 포함해 자율주행 차량과 시스템 결함 때문인지 등을 정밀 조사 중이다. 팍스뉴스는 &quot;조사관들은 허츠버그가 사고를 당했을 당시 횡단보도 바깥에 있</div>\n                            <div class=\"se_og_cp\">news.joins.com</div>\n\n                    </div>\n                </a>\n            </div>\n        </div>\n    </div>\n</div>\n<script type=\"text/data\" class=\"__se_module_data\" data-module='{\"type\":\"v1_oglink\", \"docVersion\" : \"1.0\", \"id\" :\"SEDOC-1521597616360-1536931101_oglink_0\" , \"data\" : {\"viewId\" : \"SEDOC-1521597616360-1536931101_oglink_0\", \"link\" : \"http://news.joins.com/article/22459750\", \"isVideo\" : \"false\", \"thumbnail\" : \"http://dthumb.phinf.naver.net/?src=%22http%3A%2F%2Fpds.joins.com%2Fnews%2Fcomponent%2Fhtmlphoto_mmdata%2F201803%2F21%2F71344e37-4c29-4387-b43c-f49693304f17.jpg%22&amp;type=ff120\"}}'></script>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>자율주행차가 조명받는 이유는 <br></span><span>교통정체가 줄어들고, 운전자의 부주의에 의한 교통사고가 줄어들거란 기대 때문이었죠. 그런데 사망사고가 났으니 한동안 파장이 있을 듯 해요. <br></span><span><br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>우버 자율주행차 사고는 불행히도 사람이 사망에 이르렀지만, 사망에 이르지 않더라도, 사람이 운전하는 차거나 자율주행차거나 사고가 나면 사람이 다치게 마련입니다. <br></span><span><br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-left\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:271px\">\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1521597616360-1536931101_image_0_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODAzMjFfMTY3/MDAxNTIxNTk0OTEzODcw.GK9riZ9MC6XE6belWy7SBE37gAGX6WUIlABeOlC5Q9og.UIx_eEZg0syv7DoMygFW6gDQbNIZTYMm9kmdaPFrbGQg.JPEG.isuhani/%E3%84%B4_%ED%8E%B8%ED%83%80%EC%86%90%EC%83%81_%EA%B7%B8%EB%A6%BC_%EC%B9%BC%EB%9D%BC2.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1521597616360-1536931101_image_0_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODAzMjFfMTY3/MDAxNTIxNTk0OTEzODcw.GK9riZ9MC6XE6belWy7SBE37gAGX6WUIlABeOlC5Q9og.UIx_eEZg0syv7DoMygFW6gDQbNIZTYMm9kmdaPFrbGQg.JPEG.isuhani/%E3%84%B4_%ED%8E%B8%ED%83%80%EC%86%90%EC%83%81_%EA%B7%B8%EB%A6%BC_%EC%B9%BC%EB%9D%BC2.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODAzMjFfMTY3/MDAxNTIxNTk0OTEzODcw.GK9riZ9MC6XE6belWy7SBE37gAGX6WUIlABeOlC5Q9og.UIx_eEZg0syv7DoMygFW6gDQbNIZTYMm9kmdaPFrbGQg.JPEG.isuhani/%E3%84%B4_%ED%8E%B8%ED%83%80%EC%86%90%EC%83%81_%EA%B7%B8%EB%A6%BC_%EC%B9%BC%EB%9D%BC2.jpg?type=w580\" data-width=\"271\" data-height=\"498\" width=\"271\" height=\"498\" data-attachment-id=\"I9vdtDmrZmi_0RM5LwgLomVMaLnQ\" alt=\"\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>교통사고가 나면 뒷목 잡고 내린다고 하는데, 그럴만한 이유가 있습니다. <br></span><span>자동차사고 시 가장 많은 손상이 일어나는 부위가 바로 목! 경추입니다. <br></span><span>큰 사고가 아니라 가벼운사고인 경우에도 목은 다칠 수 있습니다. <br></span><span><br></span><span>진료실에서도 \"가벼운 접촉사고라 생각해서 안아플거라 생각했는데, 시간이 지나면서 점점 아파진다\"는 호소를 많이 듣습니다. <br></span><span><br></span><span>목의 손상은 <br></span><span>두통, 항강(뒷목이 뻣뻣하고 뻐근함), 어깨의 통증, 등의 통증, 날개뼈의 통증 뿐 아니라 <br></span><span>어지러움, 미식거리고 울렁거림, 손이 붓거나 저림 등의 다양한 증상을 유발합니다. <br></span><span><br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-left\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:500px\">\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1521597616360-1536931101_image_1_img\", \"src\" : \"https://www.spineuniverse.com/sites/default/files/imagecache/gallery-large/wysiwyg_imageupload/3998/2016/10/20/Neck%20Pain%2010.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1521597616360-1536931101_image_1_img\" class=\"se_mediaImage __se_img_el\" src=\"https://www.spineuniverse.com/sites/default/files/imagecache/gallery-large/wysiwyg_imageupload/3998/2016/10/20/Neck%20Pain%2010.jpg\" width=\"500\" height=\"333\" data-attachment-id=\"\" alt=\"\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span><br></span><span><br></span><span>그 외에<br></span><span>등(흉추)이나 허리(요추)가 다치는 일도 많아 등, 허리.. 심지어 다리로 땡기거나 저리는 증상도 생기곤 하죠. </span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>교통사고 후 불편하고 아픈 부위가 있으면 바로바로 잘 치료해야 합니다. <br></span><span>인대손상이 있을 경우 초기에 치료하지 않으면 손상이 회복되지 않은채 계속 남게 됩니다. 그러면 후유증이 생기게 되요. <br></span><span><br></span><span>발목을 삐끗한 후 같은 발목이 자꾸 삐끗삐끗 하는 경험이 있으신가요? 발목 염좌 후 인대가 제대로 회복되지 못해서 약해졌기 때문에 습관성으로 자주 삐게 되는겁니다. <br></span><span><br></span><span>목을 비롯한 척추주변도 마찬가지로 교통사고 후 인대 및 근육의 회복이 불완전하면 자꾸 아프게 되요. <br></span><span>목을 돌릴때 뼈가 걸리는 소리가 날 수도 있고 이따끔씩 뜨끔하는 통증이 남기도 하죠. 결국엔 목뼈의 퇴행을 빠르게 해서 디스크 등 치료하기 어려운 질환으로 진행될 수 있습니다. <br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span><br></span><span class=\"se_fs_T1\">지하철 7호선 남성역 1번출구 앞에 있는 이수한의원</span><span>에서는 침, 부항, 추나요법, 약침요법, 한약처방 등으로 증상에 맞게, 손상 정도에 맞게 적절한 치료를 통해 빠른 회복을 도와드립니다. <br></span><span><br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n<div class=\"se_component se_imageStrip imageStrip2 default \">\n    <div class=\"se_sectionArea se_align-extend\">\n        <div class=\"se_viewArea\">\n            <div class=\"se_editArea\">\n\n                <div class=\"se_imageStripView\">\n                    <div class=\"se_mediaArea\">\n                                                <div class=\"se_imageStripArea\" style=\"width:60.1063829787234%;\">\n                        \t<a href=\"#\" onclick=\"return false;\" class=\"__se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1521597616360-1536931101_image_2_img_0\", \"src\" : \"https://postfiles.pstatic.net/MjAxODAzMjFfMjQy/MDAxNTIxNTk3NDkyMzg0.1c83ryLTFPYeAjc-OMKtlo08O6uSBjR8sF1DpVOZ1FAg.ckLUsFDWb7Px-TirH6YBEYfwK9KeeWjCO2OvdjNGmFwg.JPEG.isuhani/01m_707_.jpg\"}'>\n\t\t\t\t\t\t\t\t<img alt=\"\" class=\"se_mediaImage __se_img_el\" data-attachment-id=\"IaxB_3NSxPS_C4u4qJW8u4cCAJ_Q\" src=\"https://postfiles.pstatic.net/MjAxODAzMjFfMjQy/MDAxNTIxNTk3NDkyMzg0.1c83ryLTFPYeAjc-OMKtlo08O6uSBjR8sF1DpVOZ1FAg.ckLUsFDWb7Px-TirH6YBEYfwK9KeeWjCO2OvdjNGmFwg.JPEG.isuhani/01m_707_.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODAzMjFfMjQy/MDAxNTIxNTk3NDkyMzg0.1c83ryLTFPYeAjc-OMKtlo08O6uSBjR8sF1DpVOZ1FAg.ckLUsFDWb7Px-TirH6YBEYfwK9KeeWjCO2OvdjNGmFwg.JPEG.isuhani/01m_707_.jpg?type=w580\" data-width=\"960\" data-height=\"720\" id=\"SEDOC-1521597616360-1536931101_image_2_img_0\">\n\t\t\t\t\t\t\t</a>                  \n\t\t\t\t\t\t</div>\n                                                <div class=\"se_imageStripArea\" style=\"width:39.8936170212766%;\">\n                        \t<a href=\"#\" onclick=\"return false;\" class=\"__se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1521597616360-1536931101_image_3_img_1\", \"src\" : \"https://postfiles.pstatic.net/MjAxODAzMjFfMTU1/MDAxNTIxNTk3MzI5NDE3.bl7HXsZtINJfdpy679jfcTA9WWIy1JfK_I-vjwEEIosg.gJypRafkuYcw9R5iHI67yrxhFJ1sH1HTYgAlDThGLqYg.JPEG.isuhani/%EB%B4%89%EC%B9%A8_3731522085_20090910213217_4756179866.jpg\"}'>\n\t\t\t\t\t\t\t\t<img alt=\"\" class=\"se_mediaImage __se_img_el\" data-att