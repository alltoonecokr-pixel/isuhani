h3 class=\"se_textarea\">\n                            <!-- -->[남성역여성한의원]생리 전에 자꾸 짜증이 나요<!-- -->\n                            \n                        </h3>\n                        \n                        \n\t                </div>\n\t            </div>\n\t        </div>\n        </div><!-- SE_DOC_HEADER_TITLE_MIDDLE-->\n        <div id=\"SEDOC-1525839982503-613646409_se_doc_title_middle\" class=\"se_doc_title_middle\"></div>\n        <!-- SE_DOC_HEADER_CONTENTS_START -->\n        <!-- -->\n</div>\n<div class=\"blog2_container\">\n    <span class=\"writer\">\n        <span class=\"area_profile\"><a href=\"https://blog.naver.com/isuhani\" class=\"link\" onclick=\"sendClickNlog('pst.profile', '');\" target=\"_top\"><img src=\"https://blogpfthumb-phinf.pstatic.net/MjAyMzA2MjRfMjk2/MDAxNjg3NTg2MTc2NTc2.yKTPcF6FagHJrdvFPFcT4RgC-X3It5WmAiFESzLPWtQg.wTXTu1jAosaSi3b25IpUXH_ybNKgCPSu-BNVXK7rk1Eg.JPEG.isuhani/%EB%AC%B8%ED%95%99%EC%A7%84%EC%9B%90%EC%9E%A5%EB%8B%98_%EB%B8%94%EB%A1%9C%EA%B7%B8_%ED%94%84%EB%A1%9C%ED%95%84.jpg/%25E1%2584%2586%25E1%2585%25AE%25E1%2586%25AB%25E1%2584%2592%25E1%2585%25A1%25E1%2586%25A8%25E1%2584%258C%25E1%2585%25B5%25E1%2586%25AB%25E1%2584%258B%25E1%2585%25AF%25E1%2586%25AB%25E1%2584%258C%25E1%2585%25A1%25E1%2586%25BC%25E1%2584%2582%25E1%2585%25B5%25E1%2586%25B7_%25E1%2584%2587%25E1%2585%25B3%25E1%2586%25AF%25E1%2584%2585%25E1%2585%25A9%25E1%2584%2580%25E1%2585%25B3_%25E1%2584%2591%25E1%2585%25B3%25E1%2584%2585%25E1%2585%25A9%25E1%2584%2591%25E1%2585%25B5%25E1%2586%25AF.jpg?type=s1\" class=\"img\" alt=\"프로파일\"></a></span>\n        <span class=\"nick\"><a href=\"https://blog.naver.com/isuhani\" class=\"link pcol2\" onclick=\"sendClickNlog('pst.username', '');\" target=\"_top\">문학진 나효석 원장</a></span>\n        <span class=\"desc\">\n            <i class=\"dot\"> ・ </i>\n            <span class=\"se_publishDate pcol2\">2018. 5. 9. 12:19</span>\n        </span>\n    </span>\n\n</div>\n<div class=\"blog2_post_function\">\n\t<a href=\"#\" id=\"copyBtn_221271477410\" class=\"url pcol2 _setClipboard _returnFalse _se3copybtn _transPosition\" title=\"https://blog.naver.com/isuhani/221271477410\" style=\"cursor:pointer;\" >URL 복사</a>\n\n            <a href=\"#\" class=\"btn_buddy btn_addbuddy pcol2 _buddy_popup_btn _returnFalse _rosRestrictAll\" onclick=\"sendClickNlog('pst.addnei', '');\"><i class=\"ico\"></i> 이웃추가<i class=\"aline\"></i></a>\n\t<div class=\"overflow_menu\" >\n        <a href=\"#\" class=\"btn_overflow_menu _open_overflowmenu pcol2 _param(221271477410) _returnFalse\" role=\"button\" area-haspopup=\"true\" area-expanded=\"false\"><span class=\"blind\">본문 기타 기능</span></a>\n\t\t<div id=\"overflowmenu-221271477410\" class=\"lyr_overflow_menu _overflowmenu_layer\" area-hidden=\"true\">\n               <a href=\"#\" onclick=\"window.nsc='blog.post';return false;\" id=\"_title_spiButton\" class=\"naver-splugin btn_splugin share _title_share\"\n                  data-style=\"unity\"\n                  data-url=\"https://blog.naver.com/isuhani/221271477410\"\n                  data-oninitialize=\"splugin_oninitialize(1);\"\n                  data-me-display=\"off\"\n                  data-likeServiceId=\"BLOG\"\n                  data-likeContentsId=\"isuhani_221271477410\"\n                  data-spic-cid=\"221271477410\"\n                  data-logDomain=\"https://proxy.blog.naver.com/spi/v1/api/shareLog\"\n                  data-canonical-url=\"https://blog.naver.com/isuhani/221271477410\"\n                  data-option=\"{baseElement:'_title_spiButton', layerPosition:'outside-bottom', align:'right', marginLeft:0, marginTop:4}\">\n                   공유하기\n                <span class=\"ico_share _title_share_icon\"></span>\n               </a>\n                <a href=\"#\" class=\"_report _param(https://srp2.naver.com/report?svc=BLG&exit=close&ctype=AA01&cwriterenc=ol7igIOZzbTS0niXIhFh9TanNPCTWBej0n1Q5cF8svw%3D&ctitle=%5B%EB%82%A8%EC%84%B1%EC%97%AD%EC%97%AC%EC%84%B1%ED%95%9C%EC%9D%98%EC%9B%90%5D%EC%83%9D%EB%A6%AC%20%EC%A0%84%EC%97%90%20%EC%9E%90%EA%BE%B8%20%EC%A7%9C%EC%A6%9D%EC%9D%B4%20%EB%82%98%EC%9A%94&cwriter=isuh***&dark=disable&memtype=Y&env=pc&cnickname=isuh***&vsvc=BLG&cid=isuhani%40%4049462061%40%40mylog%40%40221271477410) _returnFalse\">신고하기<span class=\"ico_report\"></span></a>\n\t\t</div>\n\t</div>\n    <input type=\"text\" value=\"https://blog.naver.com/isuhani/221271477410\" alt=\"url\" class=\"copyTargetUrl\" style=\"display:none;\" title=\"URL 복사\">\n</div>\n<!--\n -->\n        <!-- SE_DOC_HEADER_CONTENTS_END -->\n        <!-- SE_DOC_HEADER_TITLE_BOTTOM-->\n        <div id=\"SEDOC-1525839982503-613646409_se_doc_title_bottom\" class=\"se_doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1525839982503-613646409_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1525839982503-613646409_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span style=\"color: rgb(0, 0, 0); background-color: transparent;\">부인과 진료를 하다보면 생리와 관련된 증상으로 내원하시는 분들이 참 많습니다. 그 중에서 오늘은 생리전 증후군에 대해서 알아보도록 하겠습니다.</span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>생리전 증후군이라는 단어는 들어본 적 있으실 거에요. 생리전 증후군은 premenstrual syndrome라고 하여 약자로 PMS라고 부르기도 합니다. <br></span><span><br></span><span>여성의 약 75-90% 정도가 반복되는 생리전 증후군의 증상을 경험한다고 하는데 이 중에서 40%는 신체적, 심리적 문제를 호소할 정도이고 5%는 월경 전 일정기간동안 아무 것도 하지 못하거나 심하게 괴로움을 겪는다고 합니다. 이 증후군은 20대 후반에서 30대 초반에서 가장 발생률이 높습니다.</span><br> 생리전 증후군의 증상은 집중력 저하, 건망증, 공격성, 우울, <a href=\"https://terms.naver.com/entry.nhn?doc27552&amp;ref=y\"><span lang=\"EN-US\"><span lang=\"EN-US\">불안</span></span></a> 등의 정신적 증상과 <a href=\"https://terms.naver.com/entry.nhn?doc27403&amp;ref=y\"><span lang=\"EN-US\"><span lang=\"EN-US\">부종</span></span></a>, <a href=\"https://terms.naver.com/entry.nhn?doc27471&amp;ref=y\"><span lang=\"EN-US\"><span lang=\"EN-US\">유방통</span></span></a>, 소화장애, <a href=\"https://terms.naver.com/entry.nhn?doc27363&amp;ref=y\"><span lang=\"EN-US\"><span lang=\"EN-US\">두통</span></span></a>, <a href=\"https://terms.naver.com/entry.nhn?doc27536&amp;ref=y\"><span lang=\"EN-US\"><span lang=\"EN-US\">요통</span></span></a> 등의 신체적 증상이 대표적입니다. 그러한 증상들은 <a href=\"https://terms.naver.com/entry.nhn?doc27593&amp;ref=y\"><span lang=\"EN-US\"><span lang=\"EN-US\">배란</span></span></a> 이후(생리 전 2주) 점차 심해지며 생리 시작 1주 전에 가장 심하고 <a href=\"https://terms.naver.com/entry.nhn?doc27592&amp;ref=y\"><span lang=\"EN-US\"><span lang=\"EN-US\">월경</span></span></a>이 시작되면 수일 이내 사라집니다. 그리고 월경 기간부터 다음 배란기까지는 증상이 전혀 없습니다.<!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span><br></span><span><br></span><span>그럼 일단 생리전 증후군을 진단할 수 있는 첫단계인 자가진단표를 살펴볼까요?</span><br> <br> 1) 월경시작 일주일 전 당신이 느끼는 증상은 어떤 것들에 해당됩니까?<br> □ 짜증/예민함<br> □ 긴장/불안<br> □ 급격한 기분의 변화<br> □ 감정을 억제 할 수 없음 : 특히 분노<br> □ 식욕증가<br> □ 의욕 상실<br> □ 유방 압통(breast tenderness)<br> □ 두통<br> □ 체중 증가<br> <br> 2) 업무능력의 감소<br> □ 가사일<br> □ 직장 활동<br> □ 학교성적<br> □ 대인 관계<br> <br> 3) 생리가 시작되면 상기 증상은 없어집니까?<br> □ 예<br> □ 아니오 <br><span class=\"se_fs_T4 se_ff_nanumgothic\"><b></b></span><span class=\"se_fs_T4 se_ff_nanumgothic\"><b>[출처- 차병원 칼럼]</b></span><br> <b><span lang=\"EN-US\">&nbsp;</span></b><br> 이 중 상당수에 체크를 했다면 생리전 증후군일 확률이 높습니다. 물론 정확한 진단을 위해서는 다른 질환일 경우를 제외시키기 위해 검사가 필요할 수도 있습니다. <br> <span lang=\"EN-US\">&nbsp;</span><br><span> <br></span><span>아직까지 생리전 증후군의 원인은 정확히 밝혀져있지 않습니다. 그저 호르몬의 불균형이 원인일 거라고 추측하고 있을 뿐입니다.<br></span><span><br></span> 생리전 증후군을 겪고 있는 여성의 1/3에서 식이요법만으로도 큰 효과를 보인다고 합니다. 염분, 알코올, 카페인, 담배 및 초콜릿 섭취를 제한하고, 정제되지 않은 탄수화물이 풍부한 음식을 소량씩 자주 먹도록 합니다. 스트레스 관리, 운동 등을 권하죠. <!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1525839982503-613646409_image_0_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODA1MDlfMjY3/MDAxNTI1ODM1NjIxMDI2.si7vPzVhNpvsWzZ45E8DjHJ_tLy02WLVD3B5_eli5Sog.p6-3Ai-JAlmyeO0rMfXnFH99CbM1vlyIQBUG5v7ntZQg.JPEG.isuhani/belly-3186730__340.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1525839982503-613646409_image_0_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODA1MDlfMjY3/MDAxNTI1ODM1NjIxMDI2.si7vPzVhNpvsWzZ45E8DjHJ_tLy02WLVD3B5_eli5Sog.p6-3Ai-JAlmyeO0rMfXnFH99CbM1vlyIQBUG5v7ntZQg.JPEG.isuhani/belly-3186730__340.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODA1MDlfMjY3/MDAxNTI1ODM1NjIxMDI2.si7vPzVhNpvsWzZ45E8DjHJ_tLy02WLVD3B5_eli5Sog.p6-3Ai-JAlmyeO0rMfXnFH99CbM1vlyIQBUG5v7ntZQg.JPEG.isuhani/belly-3186730__340.jpg?type=w580\" data-width=\"508\" data-height=\"340\" width=\"508\" height=\"340\" data-attachment-id=\"I3URw7NA81ataQawSbw58pK6XjsA\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->양방병원에서 생리전 증후군의 원인에 대해 정확한 진단을 내리지 못하고 있는 것에 반해, 한의학에서는 생리전 증후군을 간기울결(肝氣鬱結), 기체(氣滯), 어혈(瘀血), 창만(脹滿), 부종(浮腫)이라는 정확한 진단을 내려 치료를 하고 있습니다. 정확한 병리가 보이기 때문에 치료율도 높은 편입니다. <br> <span lang=\"EN-US\">&nbsp;</span><br> 사실 겪어보지 않은 사람들은 '참으면 되지, 죽을 병도 아니고 시간이 지나면 좋아지잖아..' 라고 흘려버릴지 모르지만 이 증후군을 겪고 있는 사람은 그 기간이 두려워질 정도로 힘듭니다. 식습관을 교정해보고도 나아지지 않는 증상이라면 내원하셔서 적극적으로 치료받아보시길 바랍니다. <!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1525839982503-613646409_image_1_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODA1MDlfOTEg/MDAxNTI1ODM1NzE3MTI4.XQMqu3znX5nSo7qHjJi_IY0LRegiakulWAOaXgwz9JIg.LaSvQmxJDwsH0a2ehqWnZEo-2rnDUZla_zyo5ltxtC4g.JPEG.isuhani/KakaoTalk_20180406_112924663.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1525839982503-613646409_image_1_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODA1MDlfOTEg/MDAxNTI1ODM1NzE3MTI4.XQMqu3znX5nSo7qHjJi_IY0LRegiakulWAOaXgwz9JIg.LaSvQmxJDwsH0a2ehqWnZEo-2rnDUZla_zyo5ltxtC4g.JPEG.isuhani/KakaoTalk_20180406_112924663.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODA1MDlfOTEg/MDAxNTI1ODM1NzE3MTI4.XQMqu3znX5nSo7qHjJi_IY0LRegiakulWAOaXgwz9JIg.LaSvQmxJDwsH0a2ehqWnZEo-2rnDUZla_zyo5ltxtC4g.JPEG.isuhani/KakaoTalk_20180406_112924663.jpg?type=w580\" data-width=\"540\" data-height=\"960\" width=\"540\" height=\"960\" data-attachment-id=\"I9IU6DsF-nWmJN0spjtmjrTKEJmE\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\