_bottom\" class=\"se_doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1532152835608--274819348_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1532152835608--274819348_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>드디어 우리 아이들이 한달여의 여름방학에 돌입했습니다. 아직 공부의 부담이 적은 초등생 아이를 둔 학부모들은 여름방학 때 무엇을 하면서 시간을 보내게 할까, 어떤 경험을 하게 해줘야 하나, 어디에 같이 놀러갈까 하는 등의 계획을 짜고 있겠죠.<br></span><span><br></span><span> 하지만 방학이라고 마냥 놀 수 없는 수험생을 두신 부모님들은 방학이 되면서 더욱 신경이 쓰일 수 밖에 없습니다. 뒤떨어진 과목에 대한 공부를 집중적으로 해야 하는 건 아닐까, 이제 입시까지 시간이 얼마남지 않았는데 아이가 더위에 지쳐 열심히 하지 않으면 어떻게 하나 등등 이런저런 걱정을 하게 됩니다. 우리 아이만 방학때 헤이해지면서 성적이 떨어질까봐 불안한 마음을 감출 수 없는 경우가 많습니다. <br></span><span><br></span> 그래서인지 요즘 유난히도 수험생 보약을 지으러 내원하시는 분들이 많습니다. 수험생 본인이 원해서 오는 경우도 있고 옆에서 지켜보는게 안쓰러워서 아이를 데리고 오는 부모님들도 있습니다.<br><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1532152835608--274819348_image_0_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODA3MjFfMjU2/MDAxNTMyMTQzNjA2MTk2.d0tKvEhv57kXyqBndGHvHNROsA90axoTIBqcDWATcnUg.A4DVS889tkNjIzEr7AWDVbMxmAtVMzIwfVmM2O8zqnQg.JPEG.isuhani/%EC%88%98%ED%97%98%EC%83%9D.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1532152835608--274819348_image_0_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODA3MjFfMjU2/MDAxNTMyMTQzNjA2MTk2.d0tKvEhv57kXyqBndGHvHNROsA90axoTIBqcDWATcnUg.A4DVS889tkNjIzEr7AWDVbMxmAtVMzIwfVmM2O8zqnQg.JPEG.isuhani/%EC%88%98%ED%97%98%EC%83%9D.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODA3MjFfMjU2/MDAxNTMyMTQzNjA2MTk2.d0tKvEhv57kXyqBndGHvHNROsA90axoTIBqcDWATcnUg.A4DVS889tkNjIzEr7AWDVbMxmAtVMzIwfVmM2O8zqnQg.JPEG.isuhani/%EC%88%98%ED%97%98%EC%83%9D.jpg?type=w580\" data-width=\"640\" data-height=\"374\" width=\"640\" height=\"374\" data-attachment-id=\"INd_ebl7HaOyi9VSte5pBQbB3Va4\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>수험생 보약을 지으면서 궁금해 하시는 것들 중에 하나는 제가 지어드리는 한약이 총명탕인지 궁금해하십니다. <br></span><span><br></span><span>총명탕은 동의보감에 나와있는 처방으로 “건망을 치료하고 오래 복용하면 하루에 천마디 말을 외울 수 있다” 라고 나와있습니다. 실제로 </span><span style=\"color: rgb(70, 70, 70);\">과거시험을 준비하는 선비들이 복용했다고 알려져 있기도 합니다<span lang=\"EN-US\">.<b> </b><br></span><span lang=\"EN-US\"><b></b><br></span><span lang=\"EN-US\"><b></b></span></span><span style=\"color: rgb(70, 70, 70);\">총명탕의 처방구성은<span lang=\"EN-US\"> '</span>석창포<span lang=\"EN-US\">'</span>와<span lang=\"EN-US\"> '</span>원지<span lang=\"EN-US\">', '</span>백복신<span lang=\"EN-US\">'이 </span>주재료인데 주로 정신을 안정시키고 맑게 하는 효능을 가능 약재들입니다<span lang=\"EN-US\">. </span>실제 처방을 할때는 <span>&nbsp;</span>개개인의 체질과 세부적인 증상에 따라서</span> 추가적으로 약재를 가미하게 됩니다.<br><span> <br></span><span>총명탕은 주로 이런 아이들에게 처방합니다.<br></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n\n<div class=\"se_component se_quotation default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_fs_T2\">\n                <div class=\"se_editView\" >\n                    <div class=\"se_textView\">\n                        <blockquote class=\"se_textarea\"><!-- SE3-TEXT { -->공부하려고 앉아있으면 머리가 멍해요. 집중이 되지 않아요. 안정이 안되고 가만히 앉아있기 힘들어요. <!-- } SE3-TEXT --></blockquote>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1532152835608--274819348_image_1_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODA3MjFfMTcw/MDAxNTMyMTQ0MTcyOTU1.zl8qEgYqPwsxm1TJi8CmdvQg_XL37ygSSAqIJQaYaKkg.91bErAGU10l8cayDUVlmrnmUE7bUSgyuv4qUsQ3KZTYg.JPEG.isuhani/%ED%95%99%EC%83%9D%EB%93%A4.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1532152835608--274819348_image_1_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODA3MjFfMTcw/MDAxNTMyMTQ0MTcyOTU1.zl8qEgYqPwsxm1TJi8CmdvQg_XL37ygSSAqIJQaYaKkg.91bErAGU10l8cayDUVlmrnmUE7bUSgyuv4qUsQ3KZTYg.JPEG.isuhani/%ED%95%99%EC%83%9D%EB%93%A4.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/Mj