-b1a83fbc2f5e\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-f4ac4ee3-5e94-4a55-a442-a93d48d589e8\">카카오톡 상담은 위 링크를 클릭해주세요</span></p><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-dbc4f9ed-4b40-4579-8c41-30eab9f806af\">\n                    <div class=\"se-component-content se-component-content-fit\">\n                        <div class=\"se-section se-section-image se-l-default se-section-align-\" >\n\n                                <div class=\"se-module se-module-image\" style=\"\">\n                                    <a href=\"#\" class=\"se-module-image-link __se_image_link __se_link\" style=\"\" onclick=\"return false;\" data-linktype=\"img\" data-linkdata='{\"id\" : \"SE-dbc4f9ed-4b40-4579-8c41-30eab9f806af\", \"src\" : \"https://postfiles.pstatic.net/MjAyMTA0MjBfMjc0/MDAxNjE4ODkwOTM3OTQ0.amWb0yHEJUrfKh61FvvUeMvl_ntlLCyFP1rewhMXLl8g.vwDV34WE2VX3kX4utNBkRt7lOzJbeVUNXZkR6W3I0WEg.JPEG.isuhani/%EA%B2%BD%ED%9D%AC%EC%9D%B4%EC%88%98%ED%95%9C%EC%9D%98%EC%9B%90Logo-%EC%9B%B9%EC%9A%A9_100k_%EC%9D%B4%ED%95%98.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                                        <img src=\"https://postfiles.pstatic.net/MjAyMTA0MjBfMjc0/MDAxNjE4ODkwOTM3OTQ0.amWb0yHEJUrfKh61FvvUeMvl_ntlLCyFP1rewhMXLl8g.vwDV34WE2VX3kX4utNBkRt7lOzJbeVUNXZkR6W3I0WEg.JPEG.isuhani/%EA%B2%BD%ED%9D%AC%EC%9D%B4%EC%88%98%ED%95%9C%EC%9D%98%EC%9B%90Logo-%EC%9B%B9%EC%9A%A9_100k_%EC%9D%B4%ED%95%98.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAyMTA0MjBfMjc0/MDAxNjE4ODkwOTM3OTQ0.amWb0yHEJUrfKh61FvvUeMvl_ntlLCyFP1rewhMXLl8g.vwDV34WE2VX3kX4utNBkRt7lOzJbeVUNXZkR6W3I0WEg.JPEG.isuhani/%EA%B2%BD%ED%9D%AC%EC%9D%B4%EC%88%98%ED%95%9C%EC%9D%98%EC%9B%90Logo-%EC%9B%B9%EC%9A%A9_100k_%EC%9D%B4%ED%95%98.jpg?type=w580\" data-width=\"500\" data-height=\"122\" alt=\"\" class=\"se-image-resource\" />\n                                    </a>\n                                </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"se-component se-text se-l-default\" id=\"SE-1f49973f-7df6-4919-9160-82ccf4486219\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n\n                                    <!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-e56c93c4-10ad-4cbf-ac9c-357ec35e1f07\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-a86e48a0-ef50-49ec-aae7-427c236bc025\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-f141de17-6304-47d6-8a20-7f0818fc667e\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-0d8e6fbe-8c5a-4f7f-990e-400d8e6ee107\">오늘은 날개뼈주변의 통증에 대해서 알아보겠습니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-3a023be0-a9a1-4d42-badf-5d2d635560e1\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-a2fb7d20-89a0-4296-858c-886fa213e4f0\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-1a3b0b81-08c5-4176-aab9-cc926f14c944\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-c0385dda-c13b-476e-85a3-2372e90b3f32\">목이 아픈것도 아니고, 어깨관절이 아픈것도 아닌데,  이상하게 어깨 뒤쪽 날개뼈 주변이 아팠던 경험이 있으신가요?</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-801d4e6c-5224-44e4-a473-ab0bc56e7fb1\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-f8641d9e-310d-42fd-bc3e-f2129a424a67\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-2e01a66e-27bb-4bc6-a9a7-949fcc971531\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-5fdf0d7b-71ae-46c4-81d2-7b9f14b40f21\">이 부위의 통증은 쑤시는 것 같기도 하고, 많이 뭉친 것 같기도 하다고 표현을 하십니다. 연세가 있으신 분들은 &#x27;어깨죽지가 불편하다&#x27;는 표현으로 그 애매모호함 통증을 호소하기도 합니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-d226cbba-f742-4460-a6a7-55dda671ee8e\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-85394771-357e-49b0-b656-2154f7ae4f14\">등이 아프다고 말씀하시는 분도 계시죠.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-8d8b045c-47f1-428e-b1db-bec752436aa6\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-01626124-d7ce-47f4-96c8-1fe3c05b53d0\">옆으로 누워서 잘때, 어깨가 눌리면 특히 더 아프기도 하죠. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-045b658a-3635-44f9-bba4-1fa1d4a1e253\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-24f327a0-3006-4df9-8201-225d5627eb8b\">오래되면 어깨관절 앞쪽의 통증이 생기는 경우도 있죠. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-0709174a-92ee-4c97-940f-f38641ea1dc1\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-411962f4-15be-446a-87b8-599b9b4e3a0f\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-0146dcb8-b841-42b2-ac8a-dbc29353a8bd\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-4c0dc120-7c50-4cb7-9a72-5c7a4e9a4949\">이런 경우 우선 그 주변 근육을 먼저 진찰해봅니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-0f59dc6f-24d2-48fa-918a-cb1226bc28b6\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-0d3a2776-14e0-4530-abcf-ed3e2ee2efc6\">​</span></p><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-625ca35b-d840-4422-99f2-3a554cdf4446\">\n                    <div class=\"se-component-content se-component-content-normal\">\n                        <div class=\"se-section se-section-image se-l-default se-section-align-\" style=\"max-width:329px;\">\n\n                                <div class=\"se-module se-module-image\" style=\"\">\n                                    <a href=\"#\" class=\"se-module-image-link __se_image_link __se_link\" style=\"\" onclick=\"return false;\" data-linktype=\"img\" data-linkdata='{\"id\" : \"SE-625ca35b-d840-4422-99f2-3a554cdf4446\", \"src\" : \"https://postfiles.pstatic.net/MjAyMTA0MjBfMTcx/MDAxNjE4ODkxMjM3NDY5._p7dTbprvD7xViWgA_JPbLJLFKBFUnqDuflo6xKejqQg.sJaOa6naYqnPvXHy3cC6wGE6CU7POJDzTfOlm4buYpMg.JPEG.isuhani/suprascapular__infraspinatus.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                                        <img src=\"https://postfiles.pstatic.net/MjAyMTA0MjBfMTcx/MDAxNjE4ODkxMjM3NDY5._p7dTbprvD7xViWgA_JPbLJLFKBFUnqDuflo6xKejqQg.sJaOa6naYqnPvXHy3cC6wGE6CU7POJDzTfOlm4buYpMg.JPEG.isuhani/suprascapular__infraspinatus.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAyMTA0MjBfMTcx/MDAxNjE4ODkxMjM3NDY5._p7dTbprvD7xViWgA_JPbLJLFKBFUnqDuflo6xKejqQg.sJaOa6naYqnPvXHy3cC6wGE6CU7POJDzTfOlm4buYpMg.JPEG.isuhani/suprascapular__infraspinatus.jpg?type=w580\" data-width=\"329\" data-height=\"290\" alt=\"\" class=\"se-image-resource\" />\n                                    </a>\n                                </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"se-component se-text se-l-default\" id=\"SE-ea2556c8-bbf1-432c-91e2-9ce4de006d6e\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n\n                                    <!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-69fe55c7-2092-4ee2-818d-5e55c76165d9\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-95371f9f-52df-4e60-a24e-5ec5808a8258\">위 그림에서 빨간색 부위가  날개뼈의 뒷 부분을 채우고 있는 극상근, 극하근, 대원근, 소원근 입니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-ecaee649-1166-418f-8c1e-7918b271e892\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-1537278c-c128-49b7-9d06-50803d0fd778\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-881d3c77-db56-46ea-a250-1f06d4b9f1ab\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-816855fc-49db-4fad-9f8d-26b907b7bf79\">이 근육들에 문제가 생기면 날개뼈 보다는 어깨관절 및 위팔쪽으로 아프다고 느껴지는 경우가 많습니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-8011b975-782d-486b-b259-a8442c6bd598\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-a88759e9-9c16-493a-a329-5dfe8f85dd19\">​</span></p><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-0b6bffbb-c191-44d9-956c-ad1e68119994\">\n                    <div class=\"se-component-content se-component-content-normal\">\n                        <div class=\"se-section se-section-image se-l-default se-section-align-\" style=\"max-width:271px;\">\n\n                                <div class=\"se-module se-module-image\" style=\"\">\n                                    <a href=\"#\" class=\"se-module-image-link __se_image_link __se_link\" style=\"\" onclick=\"return false;\" data-linktype=\"img\" data-linkdata='{\"id\" : \"SE-0b6bffbb-c191-44d9-956c-ad1e68119994\", \"src\" : \"https://postfiles.pstatic.net/MjAyMTA0MjBfMjY3/MDAxNjE4ODkxMzgxODI1.2BxEhJdLRqueF6_dQNr3Xjx7geEVfIg9YwKSuWSPcfIg.D0GLsULHHJbp5XS1qdhIzy09HSouDaaWhgmUbD-oZYAg.JPEG.isuhani/infraspinatus_trp.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                                        <img src=\"https://postfiles.pstatic.net/MjAyMTA0MjBfMjY3/MDAxNjE4ODkxMzgxODI1.2BxEhJdLRqueF6_dQNr3Xjx7geEVfIg9YwKSuWSPcfIg.D0GLsULHHJbp5XS1qdhIzy09HSouDaaWhgmUbD-oZYAg.JPEG.isuhani/infraspinatus_trp.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAyMTA0MjBfMjY3/MDAxNjE4ODkxMzgxODI1.2BxEhJdLRqueF6_dQNr3Xjx7geEVfIg9YwKSuWSPcfIg.D0GLsULHHJbp5XS1qdhIzy09HSouDaaWhgmUbD-oZYAg.JPEG.isuhani/infraspinatus_trp.jpg?type=w580\" data-width=\"271\" data-height=\"271\" alt=\"\" class=\"se-image-resource\" />\n                                    </a>\n                                </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"se-component se-text se-l-default\" id=\"SE-d68318e8-f5ee-446e-93a0-d73becef1200\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n\n                                    <!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-59222f48-3ac1-47ee-b86f-6d49ca9bdb2e\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-7f5b6da6-cacc-499d-a280-730d4f93c871\">이런식이죠.  원인부위 ( X 표시)는 날개뼈지만, 통증부위 (빨간색 표시)는 어깨~팔 쪽으로 느껴지는 경우가 있죠</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-7fe219b5-c952-4e88-b923-478d170b0016\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-e39b9ef4-598b-4894-b27e-79ed40310658\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-f05d45ae-ea7d-4587-96bf-e492f36ebcf4\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-40c68812-47dc-42c9-8101-91f40966bc50\">날개뼈 부위가 쑤신다면 근육 뿐 아니라 신경을 꼭 확인해봐야 합니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-8b14453a-d50f-4245-81bc-676c8e99c1ae\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-027640a8-1117-4097-9637-24bd199fe4c6\">​</span></p><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-0b77cc64-1bbb-4d91-8055-93f5a232859c\">\n                    <div class=\"se-component-content se-component-content-normal\">\n                        <div class=\"se-section se-section-image se-l-default se-section-align-\" style=\"max-width:355px;\">\n\n                                <div class=\"se-module se-module-image\" style=\"\">\n                                    <a href=\"#\" class=\"se-module-image-link __se_image_link __se_link\" style=\"\" onclick=\"return false;\" data-linktype=\"img\" data-linkdata='{\"id\" : \"SE-0b77cc64-1bbb-4d91-8055-93f5a232859c\", \"src\" : \"https://postfiles.pstatic.net/MjAyMTA0MjBfMjAg/MDAxNjE4ODkxNDcyMDEw.r9PfRyGou5wKBxK2DeNEmD3D08R2ihI8K11QlCn_vh4g.OEk0MLEDN3xGWMRbRmulqWBzlQcnF8D6dhYbU9W1Qxsg.JPEG.isuhani/shoulder_-_bone.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                                        <img src=\"https://postfiles.pstatic.net/MjAyMTA0MjBfMjAg/MDAxNjE4ODkxNDcyMDEw.r9PfRyGou5wKBxK2DeNEmD3D08R2ihI8K11QlCn_vh4g.OEk0MLEDN3xGWMRbRmulqWBzlQcnF8D6dhYbU9W1Qxsg.JPEG.isuhani/shoulder_-_bone.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAyMTA0MjBfMjAg/MDAxNjE4ODkxNDcyMDEw.r9PfRyGou5wKBxK2DeNEmD3D08R2ihI8K11QlCn_vh4g.OEk0MLEDN3xGWMRbRmulqWBzlQcnF8D6dhYbU9W1Qxsg.JPEG.isuhani/shoulder_-_bone.jpg?type=w580\" data-width=\"355\" data-height=\"369\" alt=\"\" class=\"se-image-resource\" />\n                                    </a>\n                                </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"se-component se-text se-l-default\" id=\"SE-4eff15f3-5c7b-4d74-9eed-fb0f393d1105\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n\n                                    <!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-c225ff3d-8fb6-48c1-aa98-8bcb5b2a245d\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-0e626767-0bbf-40eb-a8f4-594c45123673\">위 그림에서 노란색 선 보이시죠? 날개뼈로 이어지는 이 신경 (견갑상신경, 견갑하신경)에 문제가 생기면 날개뼈(날개죽지)가 쑤시고 아파집니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-472f582c-756a-482d-aa6b-009b3af6b7f6\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-8bf3df71-0d2a-4740-8518-d1ba1f9b00f4\">​</span></p><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-55cba7ab-4a70-4b63-977f-9f38df675e8c\">\n                    <div class=\"se-component-content se-component-content-fit\">\n                        <div class=\"se-section se-section-image se-l-default se-section-align-\" >\n\n                                <div class=\"se-module se-module-image\" style=\"\">\n                                    <a href=\"#\" class=\"se-module-image-link __se_image_link __se_link\" style=\"\" onclick=\"return false;\" data-linktype=\"img\" data-linkdata='{\"id\" : \"SE-55cba7ab-4a70-4b63-977f-9f38df675e8c\", \"src\" : \"https://postfiles.pstatic.net/MjAyMTA0MjBfNzIg/MDAxNjE4ODkxNjMwMDI4.NPWXnCmXJ4nUqgP-9ttonvwI4i7bczA3YcqMlP7JVYgg.K0wGYdGTrFlxq0RD5KBu11Q8ookUklkyOD5ImjrdGs4g.PNG.isuhani/suprascapular+nerve+backpack.png\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                                        <img src=\"https://postfiles.pstatic.net/MjAyMTA0MjBfNzIg/MDAxNjE4ODkxNjMwMDI4.NPWXnCmXJ4nUqgP-9ttonvwI4i7bczA3YcqMlP7JVYgg.K0wGYdGTrFlxq0RD5KBu11Q8ookUklkyOD5ImjrdGs4g.PNG.isuhani/suprascapular+nerve+backpack.png?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAyMTA0MjBfNzIg/MDAxNjE4ODkxNjMwMDI4.NPWXnCmXJ4nUqgP-9ttonvwI4i7bczA3YcqMlP7JVYgg.K0wGYdGTrFlxq0RD5KBu11Q8ookUklkyOD5ImjrdGs4g.PNG.isuhani/suprascapular+nerve+backpack.png?type=w580\" data-width=\"500\" data-height=\"374\" alt=\"\" class=\"se-image-resource\" />\n                                    </a>\n                                </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"se-component se-text se-l-default\" id=\"SE-aba6984c-20af-47f4-8d36-a4d51f03a84f\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n\n                                    <!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-da1c9f2f-10ca-4972-82cd-9af385164560\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-4230a3f6-069f-457b-8e51-410b0f672467\">위 그림처럼 무거운 가방을 오래 메서 신경이 지나는 길목을 오랫동안 누르게 되면 신경손상이 생기면서 통증이 발생할 수 있어요. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-0ddd71ea-4ab1-4eda-984d-0a213e9367c6\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-b04f8e04-e1b5-4d0f-ac4f-0dcb6eb1ee63\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-97b73fd6-3461-439c-a9e5-fdbfb4a06a50\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-a65d5069-d610-4633-8447-aa894871a5ae\">혹은 거북목, 굽은어깨 자세가 되면 위 신경들이 땡겨지면서 역시 통증이 발생할 수 있어요. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-2f474fe8-a624-442a-bc7e-9a6170625322\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-ae6731e4-fbda-4218-8335-40f95e51a72f\">​</span></p><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-6c5044ef-f70d-4086-acdc-b78f719ead45\">\n                    <div class=\"se-component-content se-component-content-normal\">\n                        <div class=\"se-section se-section-image se-l-default se-section-align-\" style=\"max-width:337px;\">\n\n                                <div class=\"se-module se-module-image\" style=\"\">\n                                    <a href=\"#\" class=\"se-module-image-link __se_image_link __se_link\" style=\"\" onclick=\"return false;\" data-linktype=\"img\" data-linkdata='{\"id\" : \"SE-6c5044ef-f70d-4086-acdc-b78f719ead45\", \"src\" : \"https://postfiles.pstatic.net/MjAyMTA0MjBfMTM4/MDAxNjE4ODkxNzIzNDE0.LI4HhNyOKVLwquRgtZfd84S-6ZSYJHAj-Mz7Xcm6bsMg.8NCGxYtNI4l4uM4QUbk_0Qjfr8Kbus633mFcCGTa4Ggg.JPEG.isuhani/suprascapular_nerve_palsy.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                                        <img src=\"https://postfiles.pstatic.net/MjAyMTA0MjBfMTM4/MDAxNjE4ODkxNzIzNDE0.LI4HhNyOKVLwquRgtZfd84S-6ZSYJHAj-Mz7Xcm6bsMg.8NCGxYtNI4l4uM4QUbk_0Qjfr8Kbus633mFcCGTa4Ggg.JPEG.isuhani/suprascapular_nerve_palsy.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAyMTA0MjBfMTM4/MDAxNjE4ODkxNzIzNDE0.LI4HhNyOKVLwquRgtZfd84S-6ZSYJHAj-Mz7Xcm6bsMg.8NCGxYtNI4l4uM4QUbk_0Qjfr8Kbus633mFcCGTa4Ggg.JPEG.isuhani/suprascapular_nerve_palsy.jpg?type=w580\" data-width=\"337\" data-height=\"256\" alt=\"\" class=\"se-image-resource\" />\n                                    </a>\n                                </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"se-component se-text se-l-default\" id=\"SE-c3e84cc0-be99-4748-b566-99085d6c9a4e\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n\n                                    <!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-6c200941-26a5-41b6-b32f-74b8f83ee373\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-9f061367-9eef-4ebf-99af-10cc859cc62d\">신경 손상이 오래되고 심해지면 위 사진의 오른쪽 날개뼈 처럼, 날개뼈 주변의 근육이 위축되는 현상이 나타날 수도 있죠. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-49b733c0-2596-4bd7-a5bc-7ce9a34590a2\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-0418228b-3cb5-4465-a1db-22ed44c02d79\">​</span></p><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-4e5d4e19-dbb5-4eb4-a089-59830c9efa5b\">\n                    <div class=\"se-component-content se-component-content-fit\">\n                        <div class=\"se-section se-section-image se-l-default se-section-align-\" >\n\n                                <div class=\"se-module se-module-image\" style=\"\">\n                                    <a href=\"#\" class=\"se-module-image-link __se_image_link __se_link\" style=\"\" onclick=\"return false;\" data-linktype=\"img\" data-linkdata='{\"id\" : \"SE-4e5d4e19-dbb5-4eb4-a089-59830c9efa5b\", \"src\" : \"https://postfiles.pstatic.net/MjAyMTA0MjBfMTkx/MDAxNjE4ODkxNzc0OTI0.C6j-VzKbgvDPts0EZdqgD7TDyIeS1A3E4zr4c_3veOEg.pI5Bx3h1U6xuPiNcJzOnlf69dNr5IQK_sySM--Tg3YQg.JPEG.isuhani/%ED%9B%84%EA%B4%80%EC%A0%88_%EC%97%B0%EA%B4%80%ED%86%B5_%EB%B6%80%EC%9C%84.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                                        <img src=\"https://postfiles.pstatic.net/MjAyMTA0MjBfMTkx/MDAxNjE4ODkxNzc0OTI0.C6j-VzKbgvDPts0EZdqgD7TDyIeS1A3E4zr4c_3veOEg.pI5Bx3h1U6xuPiNcJzOnlf69dNr5IQK_sySM--Tg3YQg.JPEG.isuhani/%ED%9B%84%EA%B4%80%EC%A0%88_%EC%97%B0%EA%B4%80%ED%86%B5_%EB%B6%80%EC%9C%84.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAyMTA0MjBfMTkx/MDAxNjE4ODkxNzc0OTI0.C6j-VzKbgvDPts0EZdqgD7TDyIeS1A3E4zr4c_3veOEg.pI5Bx3h1U6xuPiNcJzOnlf69dNr5IQK_sySM--Tg3YQg.JPEG.isuhani/%ED%9B%84%EA%B4%80%EC%A0%88_%EC%97%B0%EA%B4%80%ED%86%B5_%EB%B6%80%EC%9C%84.jpg?type=w580\" data-width=\"500\" data-height=\"555\" alt=\"\" class=\"se-image-resource\" />\n                                    </a>\n                                </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"se-component se-text se-l-default\" id=\"SE-f6eaaa19-6105-4782-a40f-34f88718c1ac\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n\n                                    <!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-e867975d-978f-412d-a88e-d7e245e4c748\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-b24e2506-e7e6-4a8a-a358-617abe720fa0\">목 뼈 관절, 혹은 목 신경의 경막 자극에 의해서도 날개뼈 통증이 발생할 수 있으니, 목에 대한 진찰도 빼놓을 수 없습니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-fe9ded93-d51e-48a7-baae-36a5b73bdd1d\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-b7b7dc6a-a0ec-4e11-bf13-279cd5f519ab\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-3b16b627-73e8-4522-8141-3a1cf4adc20c\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-6e367b04-2960-41e8-9d2e-65ce5544f84f\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-f6bf338d-7900-4aa4-a7bf-e9f56b185b8f\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-4834062e-eea8-47c5-8515-fbbf590de011\">날개뼈가 아플때는 근육, 힘줄, 인대 뿐 아니라 말초신경의 문제와 목뼈 혹은 경추</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-61777e65-4ee2-41f2-9fa5-3b79fd68a701\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-67a3b897-8d95-4d6d-b52e-42c183116782\">신경의 문제까지 점검해봐야 합니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-c71ffa0f-85d5-4adc-9394-64730bcd3eb5\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-8c1e7bfe-1fa7-49db-950d-249b23354f43\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-9f55fa3b-6d4b-4785-bbfc-c8a62eda1701\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-74bae643-203c-44b0-b5d2-54cae68d0765\">남성역 이수한의원에서는 단순한 통증질환에도 다양한 원인을 다각적으로 진찰해서 진짜 원인을 찾고 근본원인까지 치료하고자 최선을 다합니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-dd16b7ea-b770-4f6c-9db0-c3a422058c0a\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-74e5857d-c9eb-451a-9a5f-607c7dd1f0ca\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-dad28d36-2a2e-4fa7-9acb-3a65047cfc7a\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-c43cff46-665a-4b4c-8ffb-5c87325cecc1\">치료는 침치료, 봉침치료, 약침치료, 추나치료, 한약치료 등 다양한 치료방법을 동원해서 치료를 하게 됩니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-ddb503cb-19be-4e39-9a6a-ddc3ea3a43fd\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-81fad891-a88a-4d41-a48c-a5242b47dff0\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-1c480bde-4d25-4dfe-b313-ad763a9f1e37\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-4dfea473-fa3a-495d-a95c-13cb2ac4808d\">단순한 근육의 문제라면 치및료 및 부항, 뜸 치료, 약침치료 등으로 쉽게 치료될 수 있습니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-282c2404-8884-45e6-b3ac-3739aec3dcd9\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-6a384cfa-990d-43f2-a8f7-51c25cb51840\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-da6144b1-1361-4af0-bf4e-041116930c05\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-bab01435-4009-4399-8894-6fa755fe8ebc\">말초신경(견갑상신경, 견갑하신경)이 문제라면 침치료, 부항치료, 봉침 혹은 약침치료와 추나치료 등으로 치료하면 됩니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-970341dd-f7e3-41c5-949c-28199ecaf906\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-f9a4e8c4-7303-4388-a5c0-fa4c075bd7c7\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-28dd2944-01fb-4d3b-b711-c6868ed587e2\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-faa2c0a7-5746-49e4-9bfd-33087b8efa34\">목뼈 혹은 경추신경(경막)의 문제가 원인이라면 침치료 봉침 또는 약침치료, 추나치료와 더불어 한약처방을 병행해야 할 수도 있습니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-34492e32-a6ef-4563-9dc8-f11fa8d316d3\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-575436b9-2da4-4890-811e-249104ef3c02\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-22397942-92c9-443a-90cc-cdf8c9b43926\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-d4cdf981-da04-4366-a74f-a02fee62265e\">남성역 이수한의원에서 진료받으시면 친절히 안내 드릴겁니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-93310731-1873-40ff-bc99-8708a73bfa2a\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-9cd01126-daac-48bf-9555-d9efab478acb\">​</span></p><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-6a4817b9-5fac-4f91-a5fb-1f015d714fa6\">\n                    <div class=\"se-component-content se-component-content-fit\">\n                        <div class=\"se-section se-section-image se-l-default se-section-align-\" >\n\n                                <div class=\"se-module se-module-image\" style=\"\">\n                                    <a href=\"#\" class=\"se-module-image-link __se_image_link __se_link\" style=\"\" onclick=\"return false;\" data-linktype=\"img\" data-linkdata='{\"id\" : \"SE-6a4817b9-5fac-4f91-a5fb-1f015d714fa6\", \"src\" : \"https://postfiles.pstatic.net/MjAyMTA0MjBfMzQg/MDAxNjE4ODkyMzExNjY1.22k0-l3MRz6RMINQD44bLV7Zwwv9798_1I1qYjgPugwg.ZcLBRVJdtMRxOmx7nnSmfNBWu_bOZQRFT3N174N-614g.JPEG.isuhani/image01598.jpeg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                                        <img src=\"https://postfiles.pstatic.net/MjAyMTA0MjBfMzQg/MDAxNjE4ODkyMzExNjY1.22k0-l3MRz6RMINQD44bLV7Zwwv9798_1I1qYjgPugwg.ZcLBRVJdtMRxOmx7nnSmfNBWu_bOZQRFT3N174N-614g.JPEG.isuhani/image01598.jpeg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAyMTA0MjBfMzQg/MDAxNjE4ODkyMzExNjY1.22k0-l3MRz6RMINQD44bLV7Zwwv9798_1I1qYjgPugwg.ZcLBRVJdtMRxOmx7nnSmfNBWu_bOZQRFT3N174N-614g.JPEG.isuhani/image01598.jpeg?type=w580\" data-width=\"500\" data-height=\"391\" alt=\"\" class=\"se-image-resource\" />\n                                    </a>\n                                </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"se-component se-text se-l-default\" id=\"SE-bca2abd0-89f6-45f4-88b8-84bfe7e3eb68\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n\n                                    <!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-b0b6a3a6-90cc-499b-bc8c-a3ef7fe77b22\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-65a2ad8b-2f46-455b-af99-08f041421b82\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-d0b885ab-0fbe-4061-ba30-7799a2c954fb\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-4162dc78-4bb7-4f34-9214-923961537ac4\">어깨 주변을 그린 그림입니다</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-93b7cfd8-e16a-4d41-9acf-e386f1799be6\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-a92d2b03-7275-4076-b935-792879913c1e\">뼈와 관절 주위로 근육(적갈색), 힘줄(흰색), 뼈(살색), 신경(노란색 선)과 혈관(붉은색 선)이 복잡하게 얽혀 있는게 보이시죠. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-8c541314-5eea-4baf-ac97-bd9e72f8cfaa\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-d75b8c52-9af7-4ac8-95f5-a71c9a1b82ab\">그래서 어깨와 날개뼈의 통증은 근육, 힘줄, 인대, 신경, 혈관, 척추 등 그 통증의 원인을 찾아내는게 무엇보다 중요합니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-b10e74c1-a839-4052-9925-8c161f9c1a20\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-da519c09-b106-4a93-a15e-be9a06b5896d\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-fff7fec1-cec6-4f3c-8818-3e46e2e07730\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-23f60046-d2c1-41b2-b365-8d85b6418bf1\">원인을 제대로 찾으면 치료는 훨씬 쉬워지죠!</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-e9d11964-7f98-4ee6-ad16-6493f6f766bc\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-cd9fe2d2-2341-4654-8992-29add0b86953\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-fda62c6c-3687-4c82-996f-1db6295a6fd9\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-b239a56e-509f-457e-a2d5-79df02ca5038\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-c8cff855-50c8-48b4-819f-e4ed41864583\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-74d3d97f-57cc-47e9-a6e9-9393be90c350\">남성역 이수한의원에서 어깨통증, 날개뼈 통증을 치료하세요</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-02ceab70-aa23-4a6e-9984-a0904772cc17\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-25eb2a82-2ba7-4ee9-aa7d-4bc0fdc59d13\">​</span></p><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-8d00a503-72ab-4ecb-a497-e5222fd0509a\">\n                    <div class=\"se-component-content se-component-content-fit\">\n                        <div class=\"se-section se-section-image se-l-default se-section-align-\" >\n\n                                <div class=\"se-module se-module-image\" style=\"\">\n                                    <a href=\"#\" class=\"se-module-image-link __se_image_link __se_link\" style=\"\" onclick=\"return false;\" data-linktype=\"img\" data-linkdata='{\"id\" : \"SE-8d00a503-72ab-4ecb-a497-e5222fd0509a\", \"src\" : \"https://postfiles.pstatic.net/MjAyMTA0MjBfMTI3/MDAxNjE4ODkyNDcwNzIw.aiUQ_y