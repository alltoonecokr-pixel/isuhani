  "body": "<div class=\"se-main-container\">\n                <div class=\"se-component se-text se-l-default\" id=\"SE-15fb150c-bac7-4e5f-bb8b-f45a882c5d1a\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n\n                                    <!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-7e98431f-ad4b-43a9-9025-ce2f4d714ac1\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-f05d99ca-87c1-48e3-a4ce-352f1977ad3c\">안녕하세요.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-4d516cec-be93-4d95-8243-1872424a7686\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-3e33025d-12a3-4461-8a0c-c976a4aeb279\">동작구 사당동, 7호선 남성역 1번출구 앞 이수한의원</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-db8f84c9-3338-4eac-bd83-fd40f1d13c48\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-cfc8b844-b00a-47ae-bf45-37f2b1b0be3d\">문학진 원장입니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-a0985aa9-3aa1-46a5-870e-0bf2158a00cc\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-30706f5d-a8dc-465e-96be-2abdc2ee3a47\">​</span></p><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-oglink se-l-image\" id=\"SE-519c766e-52d3-4b44-b3f8-1f80d6836d1b\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-oglink se-l-image se-section-align-\">\n                            <div class=\"se-module se-module-oglink\">\n                                <a href=\"https://pf.kakao.com/_ZxniJxd