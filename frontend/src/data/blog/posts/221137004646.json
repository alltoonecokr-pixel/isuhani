enu _overflowmenu_layer\" area-hidden=\"true\">\n               <a href=\"#\" onclick=\"window.nsc='blog.post';return false;\" id=\"_title_spiButton\" class=\"naver-splugin btn_splugin share _title_share\"\n                  data-style=\"unity\"\n                  data-url=\"https://blog.naver.com/isuhani/221137004646\"\n                  data-oninitialize=\"splugin_oninitialize(1);\"\n                  data-me-display=\"off\"\n                  data-likeServiceId=\"BLOG\"\n                  data-likeContentsId=\"isuhani_221137004646\"\n                  data-spic-cid=\"221137004646\"\n                  data-logDomain=\"https://proxy.blog.naver.com/spi/v1/api/shareLog\"\n                  data-canonical-url=\"https://blog.naver.com/isuhani/221137004646\"\n                  data-option=\"{baseElement:'_title_spiButton', layerPosition:'outside-bottom', align:'right', marginLeft:0, marginTop:4}\">\n                   공유하기\n                <span class=\"ico_share _title_share_icon\"></span>\n               </a>\n                <a href=\"#\" class=\"_report _param(https://srp2.naver.com/report?svc=BLG&exit=close&ctype=AA01&cwriterenc=wTR4%2BAuG6GQovwl6SvPu7hFGnh5sEYzklsVKdTr3etM%3D&ctitle=%EC%A2%8B%EC%9D%80%20%EB%B8%8C%EB%9E%9C%EB%93%9C&cwriter=isuh***&dark=disable&memtype=Y&env=pc&cnickname=isuh***&vsvc=BLG&cid=isuhani%40%4049462061%40%40mylog%40%40221137004646) _returnFalse\">신고하기<span class=\"ico_report\"></span></a>\n\t\t</div>\n\t</div>\n    <input type=\"text\" value=\"https://blog.naver.com/isuhani/221137004646\" alt=\"url\" class=\"copyTargetUrl\" style=\"display:none;\" title=\"URL 복사\">\n</div>\n<!--\n -->\n        <!-- SE_DOC_HEADER_CONTENTS_END -->\n        <!-- SE_DOC_HEADER_TITLE_BOTTOM-->\n        <div id=\"SEDOC-1510297756324-1320239368_se_doc_title_bottom\" class=\"se_doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1510297756324-1320239368_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1510297756324-1320239368_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>브랜드 전략이라는 말에는 기본적으로 싸워 이긴다는 의미가 내포되어있다. 경쟁 브랜드와의 인식 싸움에서 승리하고 고객의 머릿속에서 우위를 차지한다는 것이다. <br></span><span>그러나 정작 좋은 브랜드는 경쟁 브랜드와 싸우지 않는다. <br></span><span>(ex: 나이키는 리복 아디다스 보다 좋다고 얘기하지 않는다. 대신 사람들에게 운동에 대한 열정을 불러일으키고 그 열정을 지원하기 위해 고민하고 흔쾌히 도와주겠다는 메세지를 던진다)</span><span><br></span><span><br></span><span>~~<br></span><span>좋은 브랜드는 경쟁 브랜드와 싸워 이기는 방법을 궁리하는 대신, 브랜드를 통해 사람들의 라이프 스타일에 가치 있는 변화를 제안하고 그 약속을 잘 지켜나갈 수 있는 방법을 고민한다. <br></span><span>~<br></span><span>브랜드를 만든 목적은 무엇이며 브랜드가 존재하는 이유는 무엇인지, 고객은 누구이며 그들은 어떤 것을 원하는지와 같이 사람들이 브랜드를 선택함으로써 얻을 수 있는 다양한 편익과 가치를 명확히 하고, 이를 통해 오랜 시간이 지나도 변하지 않을 굳건한 관계를 구축하는 것을 가장 중요하게 여기고 있다. <br></span><span><br></span><span><br></span><span>-날마다, 브랜드-&nbsp; 임태수 지음 / 안그라픽스/ 2016<br></span><span></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n</div>\n<!-- SE_DOC_CONTENTS_END -->\n<div class=\"__se_doc_title_end\" id=\"se_doc_contents_end\"></div>\n<div id=\"SEDOC-1510297756324-1320239368_se_doc_footer\" class=\"se_doc_footer\"></div>\n</div></div>\n\t\t\t\t\t\t</div>",
