nent-content\">\n                        <div class=\"se-section se-section-sticker se-section-align-center se-l-default\">\n                            <div class=\"se-module se-module-sticker\">\n                                <a href=\"#\" onclick=\"return false;\" class=\"__se_sticker_link __se_link\" data-linktype=\"sticker\" data-linkdata='{\"src\" : \"\", \"packCode\" : \"motion2d_01\", \"seq\" : \"8\", \"width\" : \"\", \"height\" : \"\"}'>\n                                    <img src=\"https://storep-phinf.pstatic.net/motion2d_01/original_8.png?type=p100_100\" alt=\"\" class=\"se-sticker-image\" />\n                                </a>\n                            </div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-text se-l-default\" id=\"SE-91759ef0-be39-4496-b82e-188776d0c065\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n                                    <!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-b12862ce-79c8-424f-a21f-1d91b0ae6aea\"><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-12ea3598-c0a1-45c7-a829-c7e18bf43dcc\">비만은 단순한 식습관이나 운동 부족만으로 설명할 수 없는 </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-35b91b48-e0fa-4e97-9042-4223e10ddba8\"><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-9fbdd6c0-c555-49e7-978c-cf3bb3c551a7\"><b>복합적인 질환</b></span><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-a83eb132-e76c-4b1d-8232-b65cdd490288\">입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-1b8a8cb3-dde4-4d3b-926e-47e038e364ba\"><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-5a5a3622-fbb5-4e5c-b73d-2c55cf44b466\">한의학에서는 사람의 체질에 따라 </span><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-f3c45e52-f14c-4df8-a716-6de11701869b\"><b>살이 찌는 방식과 원인</b></span><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-7fcaed7b-7f25-4bee-8a1b-dd1ebcab3012\">도 </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-5b16a4ad-3470-4668-ac19-9a8e5e22a110\"><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-ff73d6c3-bb21-433a-92c0-d9c9bb5210a6\">다르다고 보는데요,</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-c10687a9-80c4-4ae3-b892-995bd19f32c9\"><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-aa58f6ff-9f51-40c0-b6ec-b898bc6660e5\">그중에서도 소음인(少陰人)은 체질적으로 </span><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-7b24a1e3-d549-4717-b030-738b4ddb5126\"><b>위장과 대장 기능의 약화로 인해 비만에 노출되기 쉬운 유형</b></span><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-cf1158d9-d2c1-4497-a67e-31cf1959e2a5\">입니다.</span></p><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                    <script type=\"text/data\" class=\"__se_module_data\" data-module-v2='{\"type\": \"v2_text\", \"id\": \"SE-91759ef0-be39-4496-b82e-188776d0c065\", \"data\": {\"ctype\": \"text\"  }}'></script>\n                </div>                <div class=\"se-component se-horizontalLine se-l-line1\" id=\"SE-d35fc7c3-999e-49e9-bd1c-688220c85e8d\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-horizontalLine se-l-line1 se-section-align-center\">\n                            <div class=\"se-module se-module-horizontalLine\">\n                                <hr class=\"se-hr\" />\n                            </div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-38135a0c-8070-4c39-ab18-db9b16c33d4f\">\n                    <div class=\"se-component-content se-component-content-fit\">\n                        <div class=\"se-section se-section-image se-l-default se-section-align-center\" >\n                                <div class=\"se-module se-module-image\" style=\"\">\n                                    <a href=\"#\" class=\"se-module-image-link __se_image_link __se_link\" style=\"\" onclick=\"return false;\" data-linktype=\"img\" data-linkdata='{\"id\" : \"SE-38135a0c-8070-4c39-ab18-db9b16c33d4f\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/a23e1bce415503b3.png\", \"originalWidth\" : \"1600\", \"originalHeight\" : \"1600\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                                        <img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/a23e1bce415503b3.png\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/a23e1bce415503b3.png\" data-width=\"500\" data-height=\"500\" alt=\"\" class=\"se-image-resource\" />\n                                    </a>\n                                </div>\n                        </div>\n                    </div>\n                    <script type=\"text/data\" class=\"__se_module_data\" data-module-v2='{\"type\": \"v2_image\", \"id\": \"SE-38135a0c-8070-4c39-ab18-db9b16c33d4f\", \"data\": {\"ctype\": \"image\", \"ai\": \"false\" }}'></script>\n                </div>\n                <div class=\"se-component se-quotation se-l-quotation_line\" id=\"SE-b3bc3a8a-65cc-40a2-a996-e32718e05540\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-quotation se-l-quotation_line\">\n                            <blockquote class=\"se-quotation-container\">\n                                <div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-ec8d970a-cdd4-4f0d-90c1-fc5ed2fd44ac\"><span style=\"\" class=\"se-fs-fs24 se-ff-   \" id=\"SE-4204d5d0-ea74-4140-9947-e220e36aeffb\"><b>소음인은 어떤 체질인가요?</b></span></p><!-- } SE-TEXT --></div>\n                            </blockquote>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"se-component se-text se-l-default\" id=\"SE-1b8a0945-f1f6-4be0-93ca-a9851eccb950\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n                                    <!-- SE-TEXT { --><ul class=\"se-text-list se-text-list-type-bullet-disc\"><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-e2ff8667-fc77-44e1-b449-6fc880e0c65f\"><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-9729e726-10fb-4b87-aaf3-e2d057fe6e9d\"><b>내향적이고 신중한 성향</b></span></p></li><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-dc94462e-2e63-4bfe-9eb3-74a0f89f7697\"><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-b85d64cb-6629-4103-8920-7bba517a4dde\">위장과 대장의 기능이 약해 소화·흡수가 비효율적임</span></p></li><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-ae9f9a0c-1365-45e3-b777-11825aa418e3\"><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-6b3837cc-ad8b-4e00-9dbe-2c66a86af8ae\"><b>열이 부족하고 몸이 차가운 편</b></span></p></li><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-45f5a201-5170-4e3b-9ed3-b5169e3ec22a\"><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-f8dfe89f-7408-4b46-a848-dd2732dab405\">자율신경계 불균형으로 </span><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-3dbfdb3f-fa82-4e30-b00e-c77ddf226a5a\"><b>기초대사량이 낮음</b></span></p></li><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-fe812356-aa23-4285-b972-7a02a921431d\"><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-2b43d6c6-784c-4f45-9a70-68458fd4e1be\">스트레스나 환경 변화에 민감함</span></p></li></ul><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-0dcac8e5-46a3-4ef7-a9cf-732217007c8a\"><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-c8793f8d-9dda-4f3b-8cea-570201ebb8c2\">이러한 특성으로 인해, 소음인은 에너지 대사 효율이 낮고,</span></p><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-0c3b4c45-9e47-472a-99c0-1a7d20a239ef\"><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-2b6c55a8-7e3b-4713-8185-50475c0aaf7e\">소화기관의 부담이 커져 </span><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-5a3da7fb-5dfb-4912-8ea6-de8d5475ac66\"><b>살이 잘 찌는 구조</b></span><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-ffcdef04-1aa5-454b-8db7-0ef87ed5f6fe\">를 가집니다.</span></p><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                    <script type=\"text/data\" class=\"__se_module_data\" data-module-v2='{\"type\": \"v2_text\", \"id\": \"SE-1b8a0945-f1f6-4be0-93ca-a9851eccb950\", \"data\": {\"ctype\": \"text\"  }}'></script>\n                </div>                <div class=\"se-component se-horizontalLine se-l-line1\" id=\"SE-0bf9f1dc-f8fc-4775-bc76-686dc46c9a09\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-horizontalLine se-l-line1 se-section-align-\">\n                            <div class=\"se-module se-module-horizontalLine\">\n                                <hr class=\"se-hr\" />\n                            </div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-quotation se-l-quotation_line\" id=\"SE-a6cc0177-fb94-44fb-864a-69f77f7f25f9\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-quotation se-l-quotation_line\">\n                            <blockquote class=\"se-quotation-container\">\n                                <div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-9054fa8c-e05b-4d54-8560-ae892d7c1c44\"><span style=\"\" class=\"se-fs-fs24 se-ff-   \" id=\"SE-532a6b23-5de4-4a57-8596-7be57efd705b\"><b>소음인은 왜 비만에 취약할까?</b></span></p><!-- } SE-TEXT --></div>\n                            </blockquote>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"se-component se-text se-l-default\" id=\"SE-38a03c1e-fd1f-414b-8fe5-73be16fcb407\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n                                    <!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-f27ee98b-1cf8-4762-85d3-40f2b05d487e\"><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-cb258d78-c3c1-4cb0-8c2e-38b381e13efd\"><b>1. 위장 기능 저하 → 과식·복부비만</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-07e79ae2-69ab-4973-bbfa-c2dbaaa4e4f5\"><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-a292a708-cd43-482e-8816-b82c9dfc6f07\"><b>2. 대장 기능 이상 → 배변 장애 + 독소 축적</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-9ce84198-55f4-4535-97d8-c779144df325\"><span style=\"\" class=\"se-fs- se-ff-system   \" 