  "body": "<div id=\"post-view220875389525\" class=\" pcol2 _param(1) _postViewArea220875389525\">\n\t\t\t\t\t\t\t<div style=\"font-size:10pt; font-family:'957317_10';\" class=\"view\"><div id=\"SEDOC-1480577876584-1229275981\" class=\"se_doc_viewer se_body_wrap se_theme_transparent \" data-docversion=\"\">\n<div class=\"se_doc_header_start\" id=\"SEDOC-1480577876584-1229275981_se_doc_header_start\"></div>\n<!-- SE_DOC_HEADER_START -->\n<div id=\"SEDOC-1480577876584-1229275981_viewer_head\" class=\"se_viewer_head\"></div>\n<div class=\"se_component_wrap\">\n<div class=\"se_component se_documentTitle documentTitle_blog  is-fill\">\n    <div class=\"se_sectionArea is-fill se_align-left\">\n        <!-- --> \n<div class=\"blog2_series\">\n\t<a href=\"/PostList.naver?blogId=isuhani&categoryNo=43&from=postList\" class=\"pcol2\" onclick=\"sendClickNlog('pst.category','');\">한의원 story</a>\n</div>\n<div class=\"pcol1\"> \n<!--\n -->\n        <!-- SE_DOC_HEADER_TITLE_TOP-->\n     \t<div id=\"SEDOC-1480577876584-1229275981_se_doc_title_top\" class=\"se_doc_title_top\"></div>\n        <div class=\"se_editArea\">\n        \t<div class=\"se_viewArea se_ff_nanumgothic se_fs_D2\">\n\t            <div class=\"se_editView se_title\">\n\t                <div class=\"se_textView\">\n                        <h3 class=\"se_textarea\">\n                            <!-- -->위장(胃腸): 1. 잘 씹어 먹어야 하는 이유 - 위장병, 소화불량<!-- -->\n                            \n                        </h3>\n\t                </div>\n\t            </div>\n\t        </div>\n        </div><!-- SE_DOC_HEADER_TITLE_MIDDLE-->\n        <div id=\"SEDOC-1480577876584-1229275981_se_doc_title_middle\" class=\"se_doc_title_middle\"></div>\n        <!-- SE_DOC_HEADER_CONTENTS_START -->\n        <!-- -->\n</div>\n<div class=\"blog2_container\">\n    <span class=\"writer\">\n        <span class=\"area_profile\"><a href=\"https://blog.naver.com/isuhani\" class=\"link\" onclick=\"sendClickNlog('pst.profile', '');\" target=\"_top\"><img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/9967affe77f2e25b.jpg\" class=\"img\" alt=\"프로파일\"></a></span>\n        <span class=\"nick\"><a href=\"https://blog.naver.com/isuhani\" class=\"link pcol2\" onclick=\"sendClickNlog('pst.username', '');\" target=\"_top\">문학진 나효석 원장</a></span>\n        <span class=\"desc\">\n            <i class=\"dot\"> ・ </i>\n            <span class=\"se_publishDate pcol2\">2016. 12. 1. 15:31</span>\n        </span>\n    </span>\n\n</div>\n<div class=\"blog2_post_function\">\n\t<a href=\"#\" id=\"copyBtn_220875389525\" class=\"url pcol2 _setClipboard _returnFalse _se3copybtn _transPosition\" title=\"https://blog.naver.com/isuhani/220875389525\" style=\"cursor:pointer;\" >URL 복사</a>\n\n            <a href=\"#\" class=\"btn_buddy btn_addbuddy pcol2 _buddy_popup_btn _returnFalse _rosRestrictAll\" onclick=\"sendClickNlog('pst.addnei', '');\"><i class=\"ico\"></i> 이웃추가<i class=\"aline\"></i></a>\n\t<div class=\"overflow_menu\" >\n        <a href=\"#\" class=\"btn_overflow_menu _open_overflowmenu pcol2 _param(220875389525) _returnFalse\" role=\"button\" area-haspopup=\"true\" area-expanded=\"false\"><span class=\"blind\">본문 기타 기능</span></a>\n\t\t<div id=\"overflowmenu-220875389525\" class=\"lyr_overflow_menu _overflowmenu_layer\" area-hidden=\"true\">\n               <a href=\"#\" onclick=\"window.nsc='blog.post';return false;\" id=\"_title_spiButton\" class=\"naver-splugin btn_splugin share _title_share\"\n                  data-style=\"unity\"\n                  data-url=\"https://blog.naver.com/isuhani/220875389525\"\n                  data-oninitialize=\"splugin_oninitialize(1);\"\n                  data-me-display=\"off\"\n                  data-likeServiceId=\"BLOG\"\n                  data-likeContentsId=\"isuhani_220875389525\"\n                  data-spic-cid=\"220875389525\"\n                  data-logDomain=\"https://proxy.blog.naver.com/spi/v1/api/shareLog\"\n                  data-canonical-url=\"https://blog.naver.com/isuhani/220875389525\"\n                  data-option=\"{baseElement:'_title_spiButton', layerPosition:'outside-bottom', align:'right', marginLeft:0, marginTop:4}\">\n                   공유하기\n                <span class=\"ico_share _title_share_icon\"></span>\n               </a>\n                <a href=\"#\" class=\"_report _param(https://srp2.naver.com/report?svc=BLG&exit=close&ctype=AA01&cwriterenc=gPAtMmiqNvq1ihQzMeqFCvqBLl5Jk1dmS8hMIeTDy34%3D&ctitle=%EC%9C%84%EC%9E%A5(%E8%83%83%E8%85%B8)%3A%201.%20%EC%9E%98%20%EC%94%B9%EC%96%B4%20%EB%A8%B9%EC%96%B4%EC%95%BC%20%ED%95%98%EB%8A%94%20%EC%9D%B4%EC%9C%A0%20-%20%EC%9C%84%EC%9E%A5%EB%B3%91%2C%20%EC%86%8C%ED%99%94%EB%B6%88%EB%9F%89&cwriter=isuh***&dark=disable&memtype=Y&env=pc&cnickname=isuh***&vsvc=BLG&cid=isuhani%40%4049462061%40%40mylog%40%40220875389525) _returnFalse\">신고하기<span class=\"ico_report\"></span></a>\n\t\t</div>\n\t</div>\n    <input type=\"text\" value=\"https://blog.naver.com/isuhani/220875389525\" alt=\"url\" class=\"copyTargetUrl\" style=\"display:none;\" title=\"URL 복사\">\n</div>\n<!--\n -->\n        <!-- SE_DOC_HEADER_CONTENTS_END -->\n        <!-- SE_DOC_HEADER_TITLE_BOTTOM-->\n        <div id=\"SEDOC-1480577876584-1229275981_se_doc_title_bottom\" class=\"se_doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1480577876584-1229275981_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1480577876584-1229275981_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>위장병의 원인이 뭘까요?<br></span><span><br></span><span>불규칙한 식습관<br></span><span>과식, 과음<br></span><span>급하게 먹기<br></span><span>맵고 짜게, 자극적인 음식에 대한 선호<br></span><span>뜨거운 국물을 식히지 않고 먹기<br></span><span>스트레스<br></span><span>......<br></span><span><br></span><span>간단히 생각나는 대로 적어봤습니다. 이처럼 위장이 나빠지는 원인은 매우 다양합니다. </span><span>그리고 개개인마다 다 차이가 있죠. <br></span><span><br></span><span>\"나는 평생 식습관이 안좋았는데 위는 항상 건강하데!\"<br></span><span>\"저는요~ 삼시세끼 꼬박꼬박 챙겨먹고, 적게 먹고, 싱겁게 먹는데도 항상 소화가 안되요. 내시경하면 늘 위염있다면서 약을 한아름 처방해줘요\"<br></span><span><br></span><span><br></span><span></span><span></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>진료를 하다보면 위장이 약해서 고생하는 분들을 자주 만납니다. <br></span><span>소화불량, 복통, 설사 등을 치료받으러 오는 경우도 많을 뿐더러, 다른 질환, 질병을 치료받으러 온 환자분들도 '잘 체한다', '늘 소화가 안된다'등 표현은 다르지만 위장이 좋지 않다고 호소하는 분이 많죠.<br></span><span><br></span><span>지금부터 몇 번의 포스팅에 걸쳐 위장(소화기계)에 대해서 알아보고 <br></span><span>위장을 좋아지게하려면 어떻게 해야하는지 함께 생각해보도록 하겠습니다. <br></span><span><br></span><span><br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1480577876584-1229275981_image_0_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/43c9f21860818135.png\", \"linkUse\" : \"false\",\"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/43c9f21860818135.png\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/43c9f21860818135.png\" data-width=\"570\" data-height=\"707\" width=\"570\" height=\"707\" data-attachment-id=\"Ir_TPyMMB8W4T79iHuL2tND8yYjA\" alt=\"\" class=\"se_mediaImage __se_img_el\" id=\"SEDOC-1480577876584-1229275981_image_0_img\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t<div class=\"se_editView\">\n\t\t\t\t\t\t\t\t<div class=\"se_textView se_mediaCaption\">\n\t\t\t\t\t\t\t\t\t<span class=\"se_textarea\">소화기계 (Guyton &amp; Hall의 의학생리학에서 발췌)</span>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->위 그림은 우리몸의&nbsp;위장관을(Gastrointestinal Duct<span>)&nbsp;보여주는 그림입니다. <br></span><span>입에서 시작해서 식도, 위, 십이지장, 소장, 대장을 거쳐 항문까지 이어지는 '관'입니다. 우리가 먹은 음식물은 입을 통해 들어가 이 위장관을&nbsp;순차적으로 거치면서 흡수될 것들이 다 흡수된 후 찌꺼기가 항문을 통해 배출이&nbsp;됩니다. &nbsp;<br></span><span><br></span><span><br></span><span><br></span><span><br></span><span><br></span><span class=\"se_fs_T2\"><b>오</b></span><span class=\"se_fs_T2\"><b></b></span><span class=\"se_fs_T2\"><b>늘은 첫번째 단계인 입!! 을 살펴보겠습니다</b></span><span class=\"se_fs_T2\"></span><span class=\"se_fs_T2\">.</span><span> <br></span><span></span><span></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>자, 거울을 보고 입을 크게 벌려 입 안쪽을 살펴보세요. <br></span><span>뭐가 보이나요?<br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1480577876584-1229275981_image_1_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/399b338f6c65d1af.png\", \"linkUse\" : \"false\",\"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/399b338f6c65d1af.png\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/399b338f6c65d1af.png\" data-width=\"679\" data-height=\"555\" width=\"679\" height=\"555\" data-attachment-id=\"IO1odHrPpFigsZx_CQ2mObex3FWA\" alt=\"\" class=\"se_mediaImage __se_img_el\" id=\"SEDOC-1480577876584-1229275981_image_1_img\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span><br></span><span>입술, 치아, 혀, 입천장, 목젖 등이 보이시나요?<br></span><span>이런 구조물들이 입안을 구성합니다. 단순하죠 ^^<br></span><span><br></span><span>침샘은 살 안쪽에 숨어있어서 보이지 않아요.<br></span><span><br></span><span><br></span><span>배가 고플 때, 맛있는 음식을 보면 입에 침이 고이죠. 음식을 보는 것만으로도 우리의 위장관은 이미 먹고 소화시키고 흡수할 준비를 하고 있는겁니다. 우리는 입에 고이는 침만을 느낄 뿐이지만, 위에서도 위산과 소화액들이 분비되고, 췌장에서는 소화효소를 십이지장으로 분비할 준비를 합니다. <br></span><span>(그래서 배고플 때 음식을 보거나&nbsp;냄새를 맡으면 더 배고파지고 참기 힘들어지죠)<br></span><span><br></span><span></span><span><br></span><span></span><span></span><br><span>먹을 준비가 끝나면 음식을 떠서 입 안에 넣고 씹기 시작합니다. <br></span><span>앞니는 25kg 정도의 힘으로 음식을 절단하거나 찢어내고, 어금니는 90kg!!!의 힘으로 입안에 들어온 음식을 잘게 부숩니다.&nbsp;혀는&nbsp;이런 씹는 작업을 열심히 보조해주죠.<br></span><span><br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1480577876584-1229275981_image_2_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/6f5dfb553387cce3.jpg\", \"linkUse\" : \"false\",\"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/6f5dfb553387cce3.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/6f5dfb553387cce3.jpg\" data-width=\"1000\" data-height=\"667\" width=\"1000\" height=\"667\" data-attachment-id=\"IYjoCRfKClUvlSTCvdQBtbvl8Ez4\" alt=\"\" class=\"se_mediaImage __se_img_el\" id=\"SEDOC-1480577876584-1229275981_image_2_img\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span><br></span><span><br></span><span>\"천천히 꼭꼭 씹어 먹어야 건강하게 잘 큰다~\" <br></span><span>는 부모님 혹은 할머니 할아버지의 조언 (혹은 잔소리)를 들어본 기억이 있으신지요?<br></span><span><span>\"천천히 먹어라, 급하게 먹으면 체한다\"는 말도 들어본 적 있으시죠?</span><br></span><span><br></span><span></span><span>왜 천천히 꼭꼭 씹어먹어야 하는지 생각해보신적 있나요?<br></span><span><br></span><span>식사를 급하게 하는 분들은 잘 씹지 않습니다. 어린 아이들도 잘 그러죠. 입안에 음식을 넣고는 우적우적 몇 번 씹고는 그냥 삼켜버립니다. <br></span><span>(특히 국수, 짜장면 등의 면 요리는 안씹고 삼키는 경우가 많습니다. 어린아이들이 면을 좋아하는 경우에는 치아상태를 꼭 확인해봐야 합니다. 부정교합이 있거나 치아배열이 안좋아서 씹는 행위가 힘들어서 씹지 않아도 쉽게 먹을 수 있는 면 요리를 찾는 것일 수도 있으니까요)</span><span><br></span><span>&nbsp;<br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-left\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:500px\">\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1480577876584-1229275981_image_3_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/c5fb27ce08742a8a.jpg\", \"linkUse\" : \"false\",\"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/c5fb27ce08742a8a.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/c5fb27ce08742a8a.jpg\" data-width=\"500\" data-height=\"309\" width=\"500\" height=\"309\" data-attachment-id=\"IjqhSyqYiVi5v8PT5AvZs6V9g1dw\" alt=\"\" class=\"se_mediaImage __se_img_el\" id=\"SEDOC-1480577876584-1229275981_image_3_img\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t<div class=\"se_editView\">\n\t\t\t\t\t\t\t\t<div class=\"se_textView se_mediaCaption\">\n\t\t\t\t\t\t\t\t\t<span class=\"se_textarea\">이런 치아 구조면 잘 씹기 힘들겠죠?</span>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span><br></span><span><br></span><span></span><span><br></span><span>잘 씹어 먹어야 하는 이유가 몇 가지 있습니다. <br></span><span>1. 야채과 과일 등 식물성 음식에 있는 영양분을 잘 소화흡수 시키기 위해서입니다.&nbsp;&nbsp;<br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1480577876584-1229275981_image_4_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/acf8a9035f35e2f5.jpg\", \"linkUse\" : \"false\",\"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/acf8a9035f35e2f5.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/acf8a9035f35e2f5.jpg\" data-width=\"960\" data-height=\"720\" width=\"960\" height=\"720\" data-attachment-id=\"IY242ShehgotSnbEXbZ24DH8NCnY\" alt=\"\" class=\"se_mediaImage __se_img_el\" id=\"SEDOC-1480577876584-1229275981_image_4_img\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>&nbsp;&nbsp;&nbsp;우리는 동식물을 먹은 후 그&nbsp;세포를 파괴시켜 그 세포 속의 영양분을 흡수하는 겁니다. 동물의 세포를 둘러싼 세포막은 위장의 소화효소에 의해 잘 분해가 됩니다. 그.런.데! 식물의 세포를 둘러싼 세포막은 셀룰로오스막(Cellulose membrane)으로 우리 위장관에서는 셀룰로오스막을 소화분해시킬 수 있는 효소가 없습니다. 그래서 씹어서 그 막을 파괴시킨 후 삼켜야 위장에서 소화, 흡수시킬 수 있는거죠. (야채를 믹서에 갈아서 먹는 방법도 있습니다)<br></span><span><br></span><span><br></span><span><br></span><span><br></span><span>2. 음식을 삼킬 수 있는 크기로 만들어야 합니다.&nbsp;</span><span><br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1480577876584-1229275981_image_5_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/692dac20ba386e48.jpg\", \"linkUse\" : \"false\",\"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/692dac20ba386e48.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/692dac20ba386e48.jpg\" data-width=\"2250\" data-height=\"631\" width=\"2250\" height=\"631\" data-attachment-id=\"INvL13_Kd0HemVGD1HQYu0WCglF8\" alt=\"\" class=\"se_mediaImage __se_img_el\" id=\"SEDOC-1480577876584-1229275981_image_5_img\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t<div class=\"se_editView\">\n\t\t\t\t\t\t\t\t<div class=\"se_textView se_mediaCaption\">\n\t\t\t\t\t\t\t\t\t<span class=\"se_textarea\">삼키는 음식물을 bolus 하고 합니다</span>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>&nbsp; 입안 가득 머금은 음식을 잘개잘개 부수어 조그만 덩어들로 만들어야 삼킬 수 있습니다. 목젖과 이어진 편도기둥이라는 구조물은 입에서 목구멍으로 들어가는 '관문'의 역할을 합니다. 이 편도기둥은 우리가 꿀꺽 삼킬 때, 틈새를 좁게 조여서 커다란 음식덩어리가 목으로 넘어가는 것을 막는 역할도 합니다. (어린아이들이 알약을 삼키기 힘들어하는 이유 중 하나이기도 합니다) 그러니 꿀꺽 삼킬 때 관문을 통과할 수 있는 크기로 줄여주는 과정이 필요하죠. <br></span><span><br></span><span><br></span><span><br></span><span><br></span><span>3. 입안의 음식을 분비된 침과 골고루 섞어줘야 합니다.<br></span><span> </span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-left\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:208px\">\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1480577876584-1229275981_image_6_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/6b8a30c5d68b5159.jpg\", \"linkUse\" : \"false\",\"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/6b8a30c5d68b5159.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/6b8a30c5d68b5159.jpg\" data-width=\"208\" data-height=\"242\" width=\"208\" height=\"242\" data-attachment-id=\"IpMxqd8ag9FFwafVQTO0w8EEH2rg\" alt=\"\" class=\"se_mediaImage __se_img_el\" id=\"SEDOC-1480577876584-1229275981_image_6_img\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>&nbsp; 침은 다양한 역할을 하는데, 소화효소의 역할도 합니다. 탄수화물을 소화시키는 아밀라아제가 들어있죠. 그래서 침과 음식물이 잘 혼합되어야 더 소화가 잘 될 수 있습니다. 그렇게 침과 잘 혼합되어 걸쭉한 죽의 형태로 삼켜야죠.<br></span><span><br></span><span><br></span><span><br></span><span><br></span><span><br></span><span>4. 음식물이 최대한 잘게 분쇄돼야 위장의 소화효소와 잘 섞이게 됩니다.&nbsp;<br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1480577876584-1229275981_image_7_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/b5188e2401fe8738.jpg\", \"linkUse\" : \"false\",\"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/b5188e2401fe8738.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/b5188e2401fe8738.jpg\" data-width=\"906\" data-height=\"679\" width=\"906\" height=\"679\" data-attachment-id=\"IsMW-SsBc2e_vi6botzFTiCqfoqY\" alt=\"\" class=\"se_mediaImage __se_img_el\" id=\"SEDOC-1480577876584-1229275981_image_7_img\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>&nbsp;&nbsp; 음식물은 소화효소에 닿은 부위만 소화됩니다. 위장에 머무르는 동안 소화효소가 닿지&nbsp;못한 부분이 있다면 대장을 통해 대변으로 배출 되버리죠. 작은 얼음을 꺼내놓으면 공기에 닿아서 금새 녹지만, 커다란 얼음은 한참 걸리죠. 커다란 얼음이 빨리 녹게 하려면 잘게 부수면 됩니다.&nbsp;음식이 잘 소화되게 하려면? 네! 잘게 부수면 됩니다. <br></span><span><br></span><span><br></span><span><br></span><span><br></span><span>5. 위장 점막을 보호하기 위해서도 잘 씹어야 합니다.<br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n<div class=\"se_component se_imageStrip imageStrip2 default \">\n    <div class=\"se_sectionArea se_align-extend\">\n        <div class=\"se_viewArea\">\n            <div class=\"se_editArea\">\n\n                <div class=\"se_imageStripView\">\n                    <div class=\"se_mediaArea\">\n                                                <div class=\"se_imageStripArea\" style=\"width:56.164383561643824%;\">\n                        \t<a href=\"#\" onclick=\"return false;\" class=\"__se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1480577876584-1229275981_image_8_img_0\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/cecad8112c5c627c.jpg\"}'>\n\t\t\t\t\t\t\t\t<img alt=\"\" class=\"se_mediaImage __se_img_el\" data-attachment-id=\"IdhmbJu8fA8z9RnKhiBSanukAfsI\" src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/cecad8112c5c627c.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/cecad8112c5c627c.jpg\" data-width=\"200\" data-height=\"160\" id=\"SEDOC-1480577876584-1229275981_image_8_img_0\">\n\t\t\t\t\t\t\t</a>                  \n\t\t\t\t\t\t</div>\n                                                <div class=\"se_imageStripArea\" style=\"width:43.83561643835616%;\">\n                        \t<a href=\"#\" onclick=\"return false;\" class=\"__se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1480577876584-1229275981_image_9_img_1\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/af373fa4ac03d266.jpg\"}'>\n\t\t\t\t\t\t\t\t<img alt=\"\" class=\"se_mediaImage __se_img_el\" data-attachment-id=\"IbYZA0r1V-NV1U9x1-IQBpOdC4RE\" src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/af373fa4ac03d266.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/af373fa4ac03d266.jpg\" data-width=\"200\" data-height=\"205\" id=\"SEDOC-1480577876584-1229275981_image_9_img_1\">\n\t\t\t\t\t\t\t</a>                  \n\t\t\t\t\t\t</div>\n                    </div>\n                    <div class=\"se_editView\" >\n                        <div class=\"se_textView se_mediaCaption\">\n                            <span class=\"se_textarea\">거친 땅콩 부스러기                      vs             곱게 분쇄된 땅콩 가루</span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>&nbsp; 잘게 분쇄돼지 않은 음식알갱이를 삼켜서 위로 들어가면 위장 점막을 손상시킵니다. 땅콩을 예로 들어보죠. 땅콩을 제대로 씹지 않고 삼키면, 뾰족한 땅콩 부스러기들이 위로 들어가서 약하디 약한 위벽에 스크레치를 남기게 되는겁니다. 스크레치는 몇일 지나면 다 회복되긴 하지만, 그 몇일간 스크레치 부위에 위산이 침투해서 위벽을 손상시키게 되요. 그게 위염으로 진행될 수도 있죠. (알다시피, 위 속은 위산으로 가득합니다. 위산은 강한 산성의 용액이어서 닿기만 하면 뭐든지 녹여버립니다. 그런 위산이 위벽을 녹이지 못하는 이유는 위벽에는 위산에 견딜 수 있는 점액이 항상 칠해져 있기 때문이예요. 잘게 부서지지 않은 딱딱한 음식 알갱이는 이 점막층을 손상시켜 위산이 위벽을 녹이게 만들어요)<br></span><span></span><span><br></span><span>이러한 이유들로 우리는 천천히 잘 씹어 먹어야 합니다. <br></span><span>특히 평소에 소화가 잘 안된다는 분들은 꼭 실천해보도록 하세요. <br></span><span><br></span><span>잘 씹어 먹었을 뿐인데 위장이 날로 건강해지고 튼튼해지는 기쁜 경험을 하게 될 수도 있어요!<br></span><span><br></span><span>여기까지 위장관 중 입 부위에 대해 간단히 알아본 후<br></span><span>잘 씹어먹어야 하는 이유를 열심히 알아봤습니다. <br></span><span><br></span><span>오늘은 이만~~~~~~~~<br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1480577876584-1229275981_image_10_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/4b0cd4375e93e000.jpg\", \"linkUse\" : \"false\",\"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/4b0cd4375e93e000.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/4b0cd4375e93e000.jpg\" data-width=\"642\" data-height=\"157\" width=\"642\" height=\"157\" data-attachment-id=\"IIWfclO05dmgDYg-38orcq5tj_lE\" alt=\"\" class=\"se_mediaImage __se_img_el\" id=\"SEDOC-1480577876584-1229275981_image_10_img\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n</div>\n<!-- SE_DOC_CONTENTS_END -->\n<div class=\"__se_doc_title_end\" id=\"se_doc_contents_end\"></div>\n<div id=\"SEDOC-1480577876584-1229275981_se_doc_footer\" class=\"se_doc_footer\"></div>\n</div></div>\n\t\t\t\t\t\t</div>",
