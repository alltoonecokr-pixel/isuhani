  "body": "<div id=\"post-view221352828172\" class=\" pcol2 _param(1) _postViewArea221352828172\">\n\t\t\t\t\t\t\t<div style=\"font-size:10pt; font-family:'957317_10';\" class=\"view\"><div id=\"SEDOC-1536113635702--613157381\" class=\"se_doc_viewer se_body_wrap se_theme_transparent \" data-docversion=\"1.0\">\n<div class=\"se_doc_header_start\" id=\"SEDOC-1536113635702--613157381_se_doc_header_start\"></div>\n<!-- SE_DOC_HEADER_START -->\n<div id=\"SEDOC-1536113635702--613157381_viewer_head\" class=\"se_viewer_head\"></div>\n<div class=\"se_component_wrap\">\n<div class=\"se_component se_documentTitle documentTitle_blog  is-fill\">\n    <div class=\"se_sectionArea is-fill se_align-left\">\n        <!-- --> \n<div class=\"blog2_series\">\n\t<a href=\"/PostList.naver?blogId=isuhani&categoryNo=39&from=postList\" class=\"pcol2\" onclick=\"sendClickNlog('pst.category','');\">소아</a>\n</div>\n<div class=\"pcol1\"> \n<!--\n -->\n        <!-- SE_DOC_HEADER_TITLE_TOP-->\n     \t<div id=\"SEDOC-1536113635702--613157381_se_doc_title_top\" class=\"se_doc_title_top\"></div>\n        <div class=\"se_editArea\">\n        \t<div class=\"se_viewArea se_ff_nanumgothic se_fs_D2\">\n\t            <div class=\"se_editView se_title\">\n\t                <div class=\"se_textView\">\n                        <h3 class=\"se_textarea\">\n                            <!-- -->열감기 유행 [급성 인후염, 급성 편도선염, 급성 후두염]<!-- -->\n                            \n                        </h3>\n                        \n                        \n\t                </div>\n\t            </div>\n\t        </div>\n        </div><!-- SE_DOC_HEADER_TITLE_MIDDLE-->\n        <div id=\"SEDOC-1536113635702--613157381_se_doc_title_middle\" class=\"se_doc_title_middle\"></div>\n        <!-- SE_DOC_HEADER_CONTENTS_START -->\n        <!-- -->\n</div>\n<div class=\"blog2_container\">\n    <span class=\"writer\">\n        <span class=\"area_profile\"><a href=\"https://blog.naver.com/isuhani\" class=\"link\" onclick=\"sendClickNlog('pst.profile', '');\" target=\"_top\"><img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/9967affe77f2e25b.jpg\" class=\"img\" alt=\"프로파일\"></a></span>\n        <span class=\"nick\"><a href=\"https://blog.naver.com/isuhani\" class=\"link pcol2\" onclick=\"sendClickNlog('pst.username', '');\" target=\"_top\">문학진 나효석 원장</a></span>\n        <span class=\"desc\">\n            <i class=\"dot\"> ・ </i>\n            <span class=\"se_publishDate pcol2\">2018. 9. 5. 11:13</span>\n        </span>\n    </span>\n\n</div>\n<div class=\"blog2_post_function\">\n\t<a href=\"#\" id=\"copyBtn_221352828172\" class=\"url pcol2 _setClipboard _returnFalse _se3copybtn _transPosition\" title=\"https://blog.naver.com/isuhani/221352828172\" style=\"cursor:pointer;\" >URL 복사</a>\n\n            <a href=\"#\" class=\"btn_buddy btn_addbuddy pcol2 _buddy_popup_btn _returnFalse _rosRestrictAll\" onclick=\"sendClickNlog('pst.addnei', '');\"><i class=\"ico\"></i> 이웃추가<i class=\"aline\"></i></a>\n\t<div class=\"overflow_menu\" >\n        <a href=\"#\" class=\"btn_overflow_menu _open_overflowmenu pcol2 _param(221352828172) _returnFalse\" role=\"button\" area-haspopup=\"true\" area-expanded=\"false\"><span class=\"blind\">본문 기타 기능</span></a>\n\t\t<div id=\"overflowmenu-221352828172\" class=\"lyr_overflow_menu _overflowmenu_layer\" area-hidden=\"true\">\n               <a href=\"#\" onclick=\"window.nsc='blog.post';return false;\" id=\"_title_spiButton\" class=\"naver-splugin btn_splugin share _title_share\"\n                  data-style=\"unity\"\n                  data-url=\"https://blog.naver.com/isuhani/221352828172\"\n                  data-oninitialize=\"splugin_oninitialize(1);\"\n                  data-me-display=\"off\"\n                  data-likeServiceId=\"BLOG\"\n                  data-likeContentsId=\"isuhani_221352828172\"\n                  data-spic-cid=\"221352828172\"\n                  data-logDomain=\"https://proxy.blog.naver.com/spi/v1/api/shareLog\"\n                  data-canonical-url=\"https://blog.naver.com/isuhani/221352828172\"\n                  data-option=\"{baseElement:'_title_spiButton', layerPosition:'outside-bottom', align:'right', marginLeft:0, marginTop:4}\">\n                   공유하기\n                <span class=\"ico_share _title_share_icon\"></span>\n               </a>\n                <a href=\"#\" class=\"_report _param(https://srp2.naver.com/report?svc=BLG&exit=close&ctype=AA01&cwriterenc=Kt4IemXfU7By6axTfeNNRlx2Rbu4Nb4bLU6eOX0lCFk%3D&ctitle=%EC%97%B4%EA%B0%90%EA%B8%B0%20%EC%9C%A0%ED%96%89%20%5B%EA%B8%89%EC%84%B1%20%EC%9D%B8%ED%9B%84%EC%97%BC%2C%20%EA%B8%89%EC%84%B1%20%ED%8E%B8%EB%8F%84%EC%84%A0%EC%97%BC%2C%20%EA%B8%89%EC%84%B1%20%ED%9B%84%EB%91%90%EC%97%BC%5D&cwriter=isuh***&dark=disable&memtype=Y&env=pc&cnickname=isuh***&vsvc=BLG&cid=isuhani%40%4049462061%40%40mylog%40%40221352828172) _returnFalse\">신고하기<span class=\"ico_report\"></span></a>\n\t\t</div>\n\t</div>\n    <input type=\"text\" value=\"https://blog.naver.com/isuhani/221352828172\" alt=\"url\" class=\"copyTargetUrl\" style=\"display:none;\" title=\"URL 복사\">\n</div>\n<!--\n -->\n        <!-- SE_DOC_HEADER_CONTENTS_END -->\n        <!-- SE_DOC_HEADER_TITLE_BOTTOM-->\n        <div id=\"SEDOC-1536113635702--613157381_se_doc_title_bottom\" class=\"se_doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1536113635702--613157381_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1536113635702--613157381_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1536113635702--613157381_image_0_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/c03f6ab18c32b52e.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1536113635702--613157381_image_0_img\" class=\"se_mediaImage __se_img_el\" src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/c03f6ab18c32b52e.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/c03f6ab18c32b52e.jpg\" data-width=\"510\" data-height=\"340\" width=\"510\" height=\"340\" data-attachment-id=\"I32n6HyMXwyma3W4bZdNI53FztEY\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->안녕하세요<span lang=\"EN-US\">. </span>이수한의원 나효석 원장입니다<span lang=\"EN-US\">. <br></span><span lang=\"EN-US\"></span><br> 올해 여름은 유난히 더웠죠<span lang=\"EN-US\">? 111</span>년만의 더위였다고 하니까 정말 모두들 더위에 힘드셨을 거 같아요<span lang=\"EN-US\">. </span>끝날 것 같지 않던 더위가 끝나가면서 최근<span lang=\"EN-US\"> 1-2</span>주 사이에는 아침 저녁으로 선선한 바람이 불어옵니다<span lang=\"EN-US\">. </span>시원한 바람과 쾌청한 하늘을 보면서 이제 좀 살만 해졌다고 하시는 분들이 많습니다<span lang=\"EN-US\">.</span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->저는 이런 날씨 변화를 보고 <span lang=\"EN-US\">‘</span>어린 아이들이 열감기에 시달리기 쉬운 날씨구나<span lang=\"EN-US\">’ </span>하고 생각했었습니다<span lang=\"EN-US\">. </span>아니나 다를까 정말 열감기로 고생하는 아이들이 내원하는 빈도가 늘어나고 있어요<span lang=\"EN-US\">.<br></span><span lang=\"EN-US\"><br></span><span lang=\"EN-US\"><span>왜 요즘 같은 날씨에 열감기가 유행하는 걸까요<span lang=\"EN-US\">? </span>한의학적인 이야기일 수는 있겠지만 어려운 내용은 아니니 간단히 설명드려 보겠습니다<span lang=\"EN-US\">. </span></span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n\n<div class=\"se_component se_quotation quotation_underline\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_fs_T2\">\n                <div class=\"se_editView\" >\n                    <div class=\"se_textView\">\n                        <blockquote class=\"se_textarea\"><!-- SE3-TEXT { -->더운 날씨가 서서히 시원해지지 않고 갑자기 선선해지니 몸 속의 뜨거운 기운과 밖의 한기(寒氣)가 인후부에서 만나게 되면서 충격이 나게 됩니다. 그 결과로 인후부에 염증이 생기게 되고 그로 인해 열이 오르게 되는 거죠.<br><br><!-- } SE3-TEXT --></blockquote>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1536113635702--613157381_image_1_img\", \"src\" : \"https://postfiles.pstatic.net/MjAxODA5MDVfNDIg/MDAxNTM2MTEyODg0NDI4.b1Yv_9q4bd4lOA5wMbywgQqJttfVUnNQTqGXuL7FN_cg.lP3fwt1VusjhoM18IhHP_cnFWavpiElMzJd4wPwKQjIg.JPEG.isuhani/%EC%B2%B4%EC%98%A8%EA%B3%84.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1536113635702--613157381_image_1_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/MjAxODA5MDVfNDIg/MDAxNTM2MTEyODg0NDI4.b1Yv_9q4bd4lOA5wMbywgQqJttfVUnNQTqGXuL7FN_cg.lP3fwt1VusjhoM18IhHP_cnFWavpiElMzJd4wPwKQjIg.JPEG.isuhani/%EC%B2%B4%EC%98%A8%EA%B3%84.jpg?type=w80_blur\" data-lazy-src=\"https://postfiles.pstatic.net/MjAxODA5MDVfNDIg/MDAxNTM2MTEyODg0NDI4.b1Yv_9q4bd4lOA5wMbywgQqJttfVUnNQTqGXuL7FN_cg.lP3fwt1VusjhoM18IhHP_cnFWavpiElMzJd4wPwKQjIg.JPEG.isuhani/%EC%B2%B4%EC%98%A8%EA%B3%84.jpg?type=w580\" data-width=\"544\" data-height=\"340\" width=\"544\" height=\"340\" data-attachment-id=\"IH8LpjVo1M6-Zj97C60xkNcAkRFU\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span lang=\"EN-US\">&nbsp;</span><br> 보통 열이 나면 엄마들은 긴장하게 됩니다<span lang=\"EN-US\">. </span>저 또한 아이들이 어렸을 적 열이 나면 밤새 체온계를 쥐고 간호를 했던 기억이 나네요<span lang=\"EN-US\">. </span><br> <span lang=\"EN-US\">&nbsp;</span><br> 아이가 열이 날때 해열제가 아이에게 좋지 않다는 생각으로 해열제를 최대한 주지 않으려는 엄마들이 있는가 하면<span lang=\"EN-US\">, </span>열이 오르면 아이 머리가 나빠질 거라 생각해서 열이 조금만 올라도 해열제를 주는 엄마들이 있습니다<span lang=\"EN-US\">.</span><br><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->이 두 가지 생각 다&nbsp;정답이 아니라고 생각합니다<span lang=\"EN-US\">. </span>그래서 저는 해열제를 주는 기준을 엄마들에게 이렇게 설명드립니다<span lang=\"EN-US\">.</span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n\n<div class=\"se_component se_quotation quotation_underline\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_fs_T2\">\n                <div class=\"se_editView\" >\n                    <div class=\"se_textView\">\n                        <blockquote class=\"se_textarea\"><!-- SE3-TEXT { -->1.&#9;38-38.5도 사이의 열이 나면 아이의 상태를 면밀히 관찰해 봅니다. 열이 나도 잘 노는 아이들의 경우에는 바로 해열제를 주지 마시고 미지근한 물을 자주 먹이고 옷을 얇게 입히세요. 이 경우에도 너무 짧은 옷을 입히는 것은 좋지 않습니다. 얇지만 피부를 적당히 덮을 수 있는 옷이 좋습니다. <br><br>해열제를 주지 않고 아이의 상태를 관찰하는 경우에는 최소한 30분에 한번 체온을 체크해주세요. <br><br>2.&#9;38도 근방의 열이라도 아이가 자려고 하거나 쳐져있으면 해열제를 먹이는 것을 권합니다. <br><br>3.&#9;열이 나면서 손발이 차거나 변을 잘 보지 못하는 경우에는 열이 좀 더 오를 수 있으니 더욱 면밀히 아이를 관찰하시는 것이 필요합니다.<br><br>4.&#9;열이 38.5도 이상의 고열이 만 3일 이상 오르락내리락 하는 경우에는 열감기가 아닌 다른 발열성 질환의 징후일 수 있으니 꼭 소아과 진료를 받길 바랍니다. <br><br><br><!-- } SE3-TEXT --></blockquote>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->열이 나는 것은 우리 몸이 바이러스나 세균의 감염에 대항하기 위해서 면역을 올리는 과정에서 나타나는 증상입니다<span lang=\"EN-US\">. </span>다시 말해 적당히 열이 나는게 바이러스나 세균과의 전쟁에서 이길 수 있는 길입니다<span lang=\"EN-US\">. </span>다만 이 과정에서 아이가 지치게 되면 오히려 안 좋은 결과를 불러 올 수 있으니 고열이 오래 가는 경우에는 해열제를 쓰는 것이 좋습니다<span lang=\"EN-US\">.<br></span><span lang=\"EN-US\"></span><br> 열이 조금 오르기 시작할<span lang=\"EN-US\"><span>&nbsp; </span></span>바로 해열제<span lang=\"EN-US\">, </span>소염제<span lang=\"EN-US\">, </span>항생제를 쓰게 되면 당장의 전쟁에서는 이기는 듯 해 해보이지만 아이의 면역이 스스로 이겨낼 수 있는 기회를 뺏게 됩니다<span lang=\"EN-US\">. </span><br> <span lang=\"EN-US\">&nbsp;</span><br> 제 경험상 열이 올랐을 때 해열제를 많이 쓴 경우에는 이후의 콧물이나 기침<span lang=\"EN-US\">, </span>가래와 같은 감기증상이 오래 가는 경향이 있습니다<span lang=\"EN-US\">. </span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->저희 이수한의원에는 인후염으로 인한 열감기를 치료할 수 있는 여러가지 한약이 준비되어 있습니다<span lang=\"EN-US\">. </span>우리 아이가 감기에 걸렸을 때 해열제와 항생제를 최소한만 쓰면서 감기를 이겨낼 수 있도록 도와드리겠습니다<span lang=\"EN-US\">. </span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1536113635702--613157381_image_2_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/1ca52cbfa03e4a02.png\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1536113635702--613157381_image_2_img\" class=\"se_mediaImage __se_img_el\" src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/1ca52cbfa03e4a02.png\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/1ca52cbfa03e4a02.png\" data-width=\"732\" data-height=\"242\" width=\"732\" height=\"242\" data-attachment-id=\"Ie4tSYSb8xV57o0W9z1yyunVSIZc\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div clas