  "body": "<div class=\"se-main-container\">\n                <div class=\"se-component se-text se-l-default\" id=\"SE-2341fd67-c212-45d2-b36e-18c176a4fba6\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n                                    <!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-0a9094ca-ae49-4fe4-8e4b-1b0af59f5635\"><span style=\"\" class=\"se-fs- se-ff-system se-weight-unset  \" id=\"SE-46e169ee-06dc-48d7-b85f-7e5323417789\">안녕하세요.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-785cc334-5a62-4841-b6d0-fee8ab80aca2\"><span style=\"\" class=\"se-fs- se-ff-system se-weight-unset  \" id=\"SE-a9fe9114-e402-4642-a79e-e6d824b48f0f\">남성역에 위치한 </span><span style=\"background-color:#ffef34;\" class=\"se-fs- se-ff-system   \" id=\"SE-999e1190-8d77-4d59-86af-1a5e16595ef0\"><b>이수한의원</b></span><span style=\"\" class=\"se-fs- se-ff-system se-weight-unset  \" id=\"SE-3106f7a7-ec94-409a-a882-df636cdf0f0c\"> 입니다!</span></p><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                    <script type=\"text/data\" class=\"__se_module_data\" data-module-v2='{\"type\": \"v2_text\", \"id\": \"SE-2341fd67-c212-45d2-b36e-18c176a4fba6\", \"data\": {\"ctype\": \"text\"  }}'></script>\n                </div>                <div class=\"se-component se-sticker se-l-default\" id=\"SE-92f0e3a0-0379-4417-9f0f-b22919d6d48d\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-sticker se-section-align-center se-l-default\">\n                            <div class=\"se-module se-module-sticker\">\n                                <a href=\"#\" onclick=\"return fa