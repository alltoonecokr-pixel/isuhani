  "body": "<div id=\"post-view110152219185\" class=\"post-view pcol2 _param(1) _postViewArea110152219185\">\n\t\t\t\t\t\t\t<p style=\"MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><font size=\"2\"><font face=\"맑은 고딕\"><img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/a25c9cbde2a57595.jpg\" width=\"230\" height=\"219\" style=\"cursor: pointer; rwidth: 230px; rheight: 219px\" id=\"20121119_228/isuhani_1353288104137Ba88q_JPEG/%BA%F1%BF%B0.jpg\" onclick=\"popview(this, '90000003_0000000000000019A5957A31')\" alt=\"\" class=\"_photoImage\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/a25c9cbde2a57595.jpg\"><br style=\"CLEAR: both\" /><br style=\"CLEAR: both\" /></font></font></p>\r\n<p style=\"MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><font size=\"2\"><font face=\"맑은 고딕\"></font></font>&nbsp;</p>\r\n<p style=\"MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><font size=\"2\"><font face=\"맑은 고딕\">삼출성중이염은 고막이 함몰되고<span lang=\"EN-US\">, </span>추골병이 강조되고<span lang=\"EN-US\">, </span>담황색이다<span lang=\"EN-US\">.</span></font></font></p>\r\n<p style=\"MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><font size=\"2\"><font face=\"맑은 고딕\">화농성중이염은 고막이 팽창되고<span lang=\"EN-US\">, </span>추골병이 숨게되고<span lang=\"EN-US\">, </span>급성기는 붉다가 심하면 천공되어 피썩인 물이 나온다<span lang=\"EN-US\">. </span></font></font></p>\r\n<p style=\"MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><span lang=\"EN-US\"><!-- Removed Tag Filtered (o:p) --><font size=\"2\" face=\"맑은 고딕\">&nbsp;</font></span></p>\r\n<p style=\"MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><font size=\"2\" face=\"맑은 고딕\">주 증상은</font></p>\r\n<p style=\"MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><font size=\"2\"><font face=\"맑은 고딕\">이관의 기능장애로 전음성 난청<span lang=\"EN-US\">, </span>귀 충만감<span lang=\"EN-US\">, </span>이명이 오고<span lang=\"EN-US\">.</span></font></font></p>\r\n<p style=\"MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><font size=\"2\"><font face=\"맑은 고딕\"><span lang=\"EN-US\"></span></font></font>&nbsp;</p>\r\n<p style=\"MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><font size=\"2\"><font face=\"맑은 고딕\"><span lang=\"EN-US\"></span></font></font>&nbsp;</p>\r\n<p style=\"MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><span lang=\"EN-US\"><!-- Removed Tag Filtered (o:p) --><font size=\"2\" face=\"맑은 고딕\">&nbsp;<img src=\"https://postfiles.pstatic.net/20121119_237/isuhani_1353288104527xrWHG_JPEG/otititis_media.jpg?type=w80_blur\" width=\"251\" height=\"201\" style=\"cursor: pointer;BORDER-BOTTOM-COLOR: rgb(0,0,0); BORDER-TOP-COLOR: rgb(0,0,0); BORDER-RIGHT-COLOR: rgb(0,0,0); BORDER-LEFT-COLOR: rgb(0,0,0); rwidth: 251px; rheight: 201px\" id=\"20121119_237/isuhani_1353288104527xrWHG_JPEG/otititis_media.jpg\" onclick=\"popview(this, '90000003_0000000000000019A5957A31')\" alt=\"\" class=\"_photoImage\" data-lazy-src=\"https://postfiles.pstatic.net/20121119_237/isuhani_1353288104527xrWHG_JPEG/otititis_media.jpg?type=w3\"></font></span></p>\r\n<p style=\"MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><span lang=\"EN-US\"><!-- Removed Tag Filtered (o:p) --><font size=\"2\" face=\"맑은 고딕\"></font></span>&nbsp;</p>\r\n<p style=\"MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><span lang=\"EN-US\"><!-- Removed Tag Filtered (o:p) --></span>&nbsp;</p>\r\n<p style=\"MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><font size=\"2\"><font face=\"맑은 고딕\">만성화되거나 장시간 방치하면 고막이 유착되어 영구적인 청력장애를 유발한다<span lang=\"EN-US\">. </span></font></font></p>\r\n<p style=\"MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><span lang=\"EN-US\"><!-- Removed Tag Filtered (o:p) --><font size=\"2\" face=\"맑은 고딕\">&nbsp;</font></span></p>\r\n<p style=\"MARGIN: 0cm 0cm 0pt\" class=\"MsoNormal\"><font size=\"2\"><font face=\"맑은 고딕\">급성이든지 만성이든지<span lang=\"EN-US\">. </span>한방이 우수하다<span lang=\"EN-US\">. </span></font></font></p>\n\t\t\t\t\t\t</div>",
