       data-canonical-url=\"https://blog.naver.com/isuhani/221220207020\"\n                  data-option=\"{baseElement:'_title_spiButton', layerPosition:'outside-bottom', align:'right', marginLeft:0, marginTop:4}\">\n                   공유하기\n                <span class=\"ico_share _title_share_icon\"></span>\n               </a>\n                <a href=\"#\" class=\"_report _param(https://srp2.naver.com/report?svc=BLG&exit=close&ctype=AA01&cwriterenc=RvnzkqSKhl6kz9OgFjPnG6CbWC%2FzSBU5kaew6j7Hans%3D&ctitle=%EB%B9%84%EC%97%BC%EC%9D%98%20%EC%A7%84%EB%8B%A8%20%5B%EB%82%A8%EC%84%B1%EC%97%AD%20%EB%B9%84%EC%97%BC%EC%B9%98%EB%A3%8C%20%EC%9D%B4%EC%88%98%ED%95%9C%EC%9D%98%EC%9B%90%5D&cwriter=isuh***&dark=disable&memtype=Y&env=pc&cnickname=isuh***&vsvc=BLG&cid=isuhani%40%4049462061%40%40mylog%40%40221220207020) _returnFalse\">신고하기<span class=\"ico_report\"></span></a>\n\t\t</div>\n\t</div>\n    <input type=\"text\" value=\"https://blog.naver.com/isuhani/221220207020\" alt=\"url\" class=\"copyTargetUrl\" style=\"display:none;\" title=\"URL 복사\">\n</div>\n<!--\n -->\n        <!-- SE_DOC_HEADER_CONTENTS_END -->\n        <!-- SE_DOC_HEADER_TITLE_BOTTOM-->\n        <div id=\"SEDOC-1519975963105-647445227_se_doc_title_bottom\" class=\"se_doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1519975963105-647445227_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1519975963105-647445227_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->요즘 미세먼지가 많은 날씨들이 이어지고 일교차가 벌어지기 시작하면서 콧물이나 코막힘 등 코 증상을 호소하는 환자들이 늘어나고 있습니다. <!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-left\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:500px\">\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1519975963105-647445227_image_0_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/699bf28a0a692bec.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1519975963105-647445227_image_0_img\" class=\"se_mediaImage __se_img_el\" src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/699bf28a0a692bec.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/699bf28a0a692bec.jpg\" data-width=\"500\" data-height=\"313\" width=\"500\" height=\"313\" data-attachment-id=\"IuOPmSo5shluvt99jhf8KAdWg87c\" alt=\"\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->한의원에 내원하는 환자들의 대부분은 비염일까 걱정해서 내원하는 경우가 많은데요. 그래서인지 저희 아이가 비염인가요? 라는 질문을 진료실에서 많이 듣습니다. 사실 처음 아이의 상태를 보고 비염이 있는지 정확하게 진단을 내릴 방법은 없습니다. 다만 코 점막의 상태를 보고, 그동안 아이가 앓아왔던 이야기를 들어보면 비염이 있을거라 예측해 볼 수 있습니다. <br> <span lang=\"EN-US\">&nbsp;</span><br> 그럼 비염이란 무엇인지에 대해서 알아보도록 하겠습니다. 비염인 아이 중에 단순히 코감기가 오래 가는 줄만 알았다고 하는 경우가 많습니다. 비염은 임상적으로 코 점막의 염증으로 인해 소양증, 재채기, 콧물 및 코막힘 등이 2주 이상 지속되는 경우에 진단할 수 있습니다. <span lang=\"EN-US\" style=\"color: black;\">&nbsp;</span><span style=\"color: black;\">평균적으로</span><span lang=\"EN-US\" style=\"color: black;\">&nbsp; </span><span style=\"color: black;\">감기는</span><span style=\"color: black;\"> <span lang=\"EN-US\">&nbsp;7~14</span></span><span style=\"color: black;\">일</span><span lang=\"EN-US\" style=\"color: black;\">&nbsp;</span><span style=\"color: black;\">이내</span><span lang=\"EN-US\" style=\"color: black;\">&nbsp; </span><span style=\"color: black;\">증상이</span><span lang=\"EN-US\" style=\"color: black;\">&nbsp; </span><span style=\"color: black;\">호전되니</span><span style=\"color: black;\"> </span><span style=\"color: black;\">구분이</span><span style=\"color: black;\"> </span><span style=\"color: black;\">가능할</span><span style=\"color: black;\"> </span><span style=\"color: black;\">듯</span><span style=\"color: black;\"> </span><span style=\"color: black;\">하지만</span><span style=\"color: black;\"> </span><span style=\"color: black;\">실제로</span><span style=\"color: black;\"> </span><span style=\"color: black;\">진료실에서</span><span style=\"color: black;\"> </span><span style=\"color: black;\">보는</span><span style=\"color: black;\"> </span><span style=\"color: black;\">아이들은</span><span style=\"color: black;\"> </span><span style=\"color: black;\">면역이</span><span style=\"color: black;\"> </span><span style=\"color: black;\">약한</span><span style=\"color: black;\"> </span><span style=\"color: black;\">경우에</span><span style=\"color: black;\"> </span><span style=\"color: black;\">감기의</span><span style=\"color: black;\"> </span><span style=\"color: black;\">반복으로</span><span style=\"color: black;\"> </span><span style=\"color: black;\">인해</span><span style=\"color: black;\"> </span><span style=\"color: black;\">코</span><span style=\"color: black;\"> </span><span style=\"color: black;\">증상이</span><span lang=\"EN-US\" style=\"color: black;\"> 1-2</span><span style=\"color: black;\">달</span><span style=\"color: black;\"> </span><span style=\"color: black;\">이상</span><span style=\"color: black;\"> </span><span style=\"color: black;\">가는</span><span style=\"color: black;\"> </span><span style=\"color: black;\">경우도</span><span style=\"color: black;\"> </span><span style=\"color: black;\">있으니</span><span style=\"color: black;\"> </span><span style=\"color: black;\">정확한</span><span style=\"color: black;\"> </span><span style=\"color: black;\">진단은</span><span style=\"color: black;\"> </span><span style=\"color: black;\">여러</span><span style=\"color: black;\"> </span><span style=\"color: black;\">번의</span><span style=\"color: black;\"> </span><span style=\"color: black;\">진찰을</span><span style=\"color: black;\"> </span><span style=\"color: black;\">통해</span><span style=\"color: black;\"> </span><span style=\"color: black;\">내리는</span><span style=\"color: black;\"> </span><span style=\"color: black;\">것이</span><span style=\"color: black;\"> </span><span style=\"color: black;\">좋겠습니다</span><span lang=\"EN-US\" style=\"color: black;\">.</span><br> <span lang=\"EN-US\">&nbsp;</span><br> 진료실에서는 황사나 미세먼지, 꽃가루, 새집 증후군 등 알레르기를 일으키는 원인 물질이 호흡기로 흡입되어 과민반응을 통해 나타나는 알러지비염 환자가 제일 많이 보입니다. 일반적으로 부모님의 비염성향의 유전을 받아 발생하는 경우가 많습니다. 또한 면역력 약화로 감기가 지속되어 비염이 되는 경우도 있습니다. <br> <br><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-center\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:320px\">\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1519975963105-647445227_image_1_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/eb3693e10ed2ca21.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1519975963105-647445227_image_1_img\" class=\"se_mediaImage __se_img_el\" src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/eb3693e10ed2ca21.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/eb3693e10ed2ca21.jpg\" data-width=\"320\" data-height=\"239\" width=\"320\" height=\"239\" data-attachment-id=\"I88NvjQO_eq6AnTXBtxjjJlFmPD8\" alt=\"\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->이수한의원에서는 비내시경을 통해서 직접 환자의 비점막을 관찰하고 인후부와 이강의 상태도 관찰합니다. 과거력에 대한 문진도 실시하여 정확하게 진단하고 치료합니다.<br> <span lang=\"EN-US\">&nbsp;</span><br> 다음 시간에는 비염의 한의학적인 진단과 치료에 대해서 알아보도록 하겠습니다. <!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n</div>\n<!-- SE_DOC_CONTENTS_END -->\n<div class=\"__se_doc_title_end\" id=\"se_doc_contents_end\"></div>\n<div id=\"SEDOC-1519975963105-647445227_se_doc_footer\" class=\"se_doc_footer\"></div>\n</div></div>\n\t\t\t\t\t\t</div>",
