er\" >\n                                <div class=\"se-module se-module-image\" style=\"\">\n                                    <a href=\"#\" class=\"se-module-image-link __se_image_link __se_link\" style=\"\" onclick=\"return false;\" data-linktype=\"img\" data-linkdata='{\"id\" : \"SE-b7e07c4b-5936-4b7a-84f2-5e3bd195a030\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/2399c8192b9b5fef.png\", \"originalWidth\" : \"1080\", \"originalHeight\" : \"1920\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                                        <img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/2399c8192b9b5fef.png\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/2399c8192b9b5fef.png\" data-width=\"500\" data-height=\"888\" alt=\"\" class=\"se-image-resource\" />\n                                    </a>\n                                </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"se-component se-text se-l-default\" id=\"SE-c54227c3-f9b2-419d-9f50-3a15a7c00215\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n                                    <!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-b55afbc4-02cd-4f7b-9351-31e82536403b\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-b7dc9de6-fe22-495d-8c05-9181da558409\">사상 체질별 주요 특징</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-57e0cd5b-a21d-4b7d-8c3c-5cbbc79512cb\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-c981d30f-b170-4a9a-a3e8-4376bedfdde1\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-fe369f0e-137b-4e03-8cca-47db7a01ca2d\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-96564fb1-eee9-442c-b4ff-781769daa79e\">각자 체질별 특징을 살펴본 후</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-9a79ce51-0d02-4489-b0d2-4f826b65a024\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-decfdfe2-55bc-4b87-9b74-3562359d26b2\">자신의 체질을 가늠해 보세요.</span></p><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-ec0a2651-fde9-44b0-aa4e-d9fbf3c7349c\">\n                    <div class=\"se-component-content se-component-content-fit\">\n                        <div class=\"se-section se-section-image se-l-default se-section-align-center\" >\n                                <div class=\"se-module se-module-image\" style=\"\">\n                                    <a href=\"#\" class=\"se-module-image-link __se_image_link __se_link\" style=\"\" onclick=\"return false;\" data-linktype=\"img\" data-linkdata='{\"id\" : \"SE-ec0a2651-fde9-44b0-aa4e-d9fbf3c7349c\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/399e6ecc67a187a8.png\", \"originalWidth\" : \"1080\", \"originalHeight\" : \"1920\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                                        <img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/399e6ecc67a187a8.png\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/399e6ecc67a187a8.png\" data-width=\"500\" data-height=\"888\" alt=\"\" class=\"se-image-resource\" />\n                                    </a>\n                                </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"se-component se-quotation se-l-quotation_line\" id=\"SE-74596aa1-99ae-4b93-a0a1-1d8f49a17d11\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-quotation se-l-quotation_line\">\n                            <blockquote class=\"se-quotation-container\">\n                                <div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-60b9178a-28d1-4104-a781-7a084f1e12c8\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-c79bf0e4-c29c-4c7c-8015-b2305b10b8e3\">태양인의 성격과 체형</span></p><!-- } SE-TEXT --></div>\n                            </blockquote>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"se-component se-text se-l-default\" id=\"SE-176c41e2-46c1-4dd1-8465-f398f19bc920\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n                                    <!-- SE-TEXT { --><ul class=\"se-text-list se-text-list-type-bullet-disc\"><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-a9c7ed67-d42c-4df6-94cf-37d9e71ba474\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-f42da240-731c-4369-91ff-3552f6c2b35b\">인간관계에 적극적이고 앞으로 나아가며 물러서지 않음</span></p></li><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-fa32b2b7-23af-4a23-bd26-bb9b73f19f7e\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-92eed7b0-05d7-4be6-9e94-5cba7047a76f\">적극적이고 남성적인 성격, 자기 멋대로 하는 경향</span></p></li><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-d4f73e96-f6ee-42c9-a23a-e10133e92e6d\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-3c954ca1-b29f-41b8-a8ea-a795b3109bb8\">리더십이 있고 간섭을 싫어함</span></p></li><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-b0aba2c4-f9f8-49ca-b454-868799c33b24\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-13999a03-be75-4575-85e7-06d05b5623e9\">건강상으로는 소변이 잘 나오고, 침이 많이 고이면 좋음</span></p></li><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-de9efe56-16e1-465a-946a-b6afe7d09643\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-5d4739da-8194-465e-ad8e-d38b9491b69e\">외형적으로는 목덜미가 굵고 머리가 크며 엉덩이는 작고 하체가 약함</span></p></li></ul><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-85375c09-49c2-40d3-9993-2669e24c2d0e\">\n                    <div class=\"se-component-content se-component-content-fit\">\n                        <div class=\"se-section se-section-image se-l-default se-section-align-center\" >\n                                <div class=\"se-module se-module-image\" style=\"\">\n                                    <a href=\"#\" class=\"se-module-image-link __se_image_link __se_link\" style=\"\" onclick=\"return false;\" data-linktype=\"img\" data-linkdata='{\"id\" : \"SE-85375c09-49c2-40d3-9993-2669e24c2d0e\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/7572611e56c4368a.png\", \"originalWidth\" : \"1080\", \"originalHeight\" : \"1920\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                                        <img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/7572611e56c4368a.png\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/7572611e56c4368a.png\" data-width=\"500\" data-height=\"888\" alt=\"\" class=\"se-image-resource\" />\n                                    </a>\n                                </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"se-component se-quotation se-l-quotation_line\" id=\"SE-2a267235-d890-4848-8371-18ac8db58b83\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-quotation se-l-quotation_line\">\n                            <blockquote class=\"se-quotation-container\">\n                                <div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-cf48f599-7dfd-46f4-b381-de474e679659\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-cc05033b-4557-4b82-85db-e7cc097d89cd\">소양인 성격과 체형</span></p><!-- } SE-TEXT --></div>\n                            </blockquote>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"se-component se-text se-l-default\" id=\"SE-cc533eb9-16e0-4ccc-9a87-3789fe54a2ab\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n                                    <!-- SE-TEXT { --><ul class=\"se-text-list se-text-list-type-bullet-disc\"><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align-justify \" style=\"\" id=\"SE-0b3fee70-eece-4f91-a98a-341d013224ab\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-452f831c-48d2-4367-95d4-e0ae407e8bb9\">일을 만들고 추진하는 능력이 좋으나 마무리는 서투름</span></p></li><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align-justify \" style=\"\" id=\"SE-88edc29a-ae32-40f4-b96c-68ec7d3e65bc\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-c77d7410-d3f9-4465-96f5-041689e366d2\">밖에서 칭찬받고 이름이 알려지는 걸 좋아함</span></p></li><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align-justify \" style=\"\" id=\"SE-9bf5f7ca-a148-4825-b0a2-ff30e8205494\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-abbe8889-aaef-4a2a-a1e6-1d19fdf9d951\">의협심과 봉사 정신이 강하다.</span></p></li><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align-justify \" style=\"\" id=\"SE-657d4c24-7444-4cb9-9337-3a278b830d4f\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-33685764-c5a9-4f2e-881b-519b175954f1\">건강상으로는 변이 잘 나옴</span></p></li><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align-justify \" style=\"\" id=\"SE-a74ef8ee-6029-4af1-8e5d-217908e73cb7\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-7e718441-b460-4009-8422-7a51eaad43d9\">외형적으로 가슴 부위가 발달하고 엉덩이 아래로 약함</span></p></li></ul><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-3334bb20-0bd0-4d0b-8a1f-3a45e1b16c4f\">\n                    <div class=\"se-component-content se-component-content-fit\">\n                        <div class=\"se-section se-section-image se-l-default se-section-align-center\" >\n                                <div class=\"se-module se-module-image\" style=\"\">\n                                    <a href=\"#\" class=\"se-module-image-link __se_image_link __se_link\" style=\"\" onclick=\"return false;\" data-linktype=\"img\" data-linkdata='{\"id\" : \"SE-3334bb20-0bd0-4d0b-8a1f-3a45e1b16c4f\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/a7cf959be08cf70b.png\", \"originalWidth\" : \"1080\", \"originalHeight\" : \"1920\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                                        <img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/a7cf959be08cf70b.png\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/a7cf959be08cf70b.png\" data-width=\"500\" data-height=\"888\" alt=\"\" class=\"se-image-resource\" />\n                                    </a>\n                                </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"se-component se-quotation se-l-quotation_line\" id=\"SE-d678ab08-24ae-4d86-bb68-724758ce8c7b\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-quotation se-l-quotation_line\">\n                            <blockquote class=\"se-quotation-container\">\n                                <div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-a612f783-1140-487b-ba94-b6754692f997\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-23a0a531-c1ca-4571-9b80-d75ad9e72435\">태음인 성격과 체형</span></p><!-- } SE-TEXT --></div>\n                            </blockquote>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"se-component se-text se-l-default\" id=\"SE-4c8a6e6b-8d1f-464f-aefe-42c0a540c78c\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n                                    <!-- SE-TEXT { --><ul class=\"se-text-list se-text-list-type-bullet-disc\"><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-a5a6a4e1-baab-497e-9fad-425f018c31d2\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-ecc10df8-1e66-4e2a-9d47-63b529d845e4\">침착한 성격으로 묵묵히 일을 하고 마무리까지 함</span></p></li><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-6a77f4a7-852c-494c-8e6d-2f4f8188c364\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-dc0856aa-5d6c-45ba-a672-3346a0fdd238\">매사에 조심스러움, 가정에 충실함</span></p></li><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-8c0a88d2-5c3f-42df-8221-27e1575fa1b3\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-f675790a-12ba-4be9-891d-3ffbda23ad26\">예의 바르고 믿음직스럽지만 의심과 욕심이 많음</span></p></li><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-a2e4a895-a812-4911-a0ef-1a45a1ba5354\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-be96ad3f-345d-487d-a937-cf7ca36cf21f\">건강상으로는 땀이 잘 나오면 좋음</span></p></li><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-3534c9a9-b45a-4d1b-b571-0d172e382284\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-31b564a2-b895-4dfc-b303-387f8cb9c4fc\">외형적으로 체격이 좋고 허리가 굵고 통나무처럼 실하며 키가 큼</span></p></li></ul><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-7c460e66-898a-4994-8dcb-aa1b7d14008e\">\n                    <div class=\"se-component-content se-component-content-fit\">\n                        <div class=\"se-section se-section-image se-l-default se-section-align-center\" >\n                                <div class=\"se-module se-module-image\" style=\"\">\n                                    <a href=\"#\" class=\"se-module-image-link __se_image_link __se_link\" style=\"\" onclick=\"return false;\" data-linktype=\"img\" data-linkdata='{\"id\" : \"SE-7c460e66-898a-4994-8dcb-aa1b7d14008e\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/8e71a34b2b03d322.png\", \"originalWidth\" : \"1080\", \"originalHeight\" : \"1920\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                                        <img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/8e71a34b2b03d322.png\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/8e71a34b2b03d322.png\" data-width=\"500\" data-height=\"888\" alt=\"\" class=\"se-image-resource\" />\n                                    </a>\n                                </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"se-component se-quotation se-l-quotation_line\" id=\"SE-b9c55843-5cc1-4883-98f3-95765407a4e8\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-quotation se-l-quotation_line\">\n                            <blockquote class=\"se-quotation-container\">\n                                <div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-68321a7c-4750-47cf-914c-674de5e18494\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-f026cb61-0e5d-4bb4-9a3b-9928bba608c3\">소음인 성격과 체형</span></p><!-- } SE-TEXT --></div>\n                            </blockquote>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"se-component se-text se-l-default\" id=\"SE-78576d9f-01f5-49f7-bbb9-d08e0aad3f95\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n                                    <!-- SE-TEXT { --><ul class=\"se-text-list se-text-list-type-bullet-disc\"><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-f5a20661-0d53-4282-b20e-bc688ca182d2\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-76ee4851-442e-4075-8823-7dbb244b6d77\">부드럽고 계획적인 성격, 사람을 모으는 재주가 있음</span></p></li><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-fb6c4878-9fa0-4bed-801a-d85a27131b68\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-2f22f4ed-ed32-4411-b572-095b82584e83\">세심하지만 불안함, 감정보다 이성적인 판단을 선호함</span></p></li><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-1c5ab62b-b653-43df-aca7-840d9a2dc615\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-189c44f5-65e6-44ba-b293-d5e92d306017\">적극성과 추진력이 약하며 안일한 마음을 먹기 쉬움</span></p></li><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-ab1bf740-40f2-409e-be50-908a14cbadbc\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-15d1082e-843a-44c3-95ea-a9e89bb747b1\">건강상으로는 소화가 잘 되면 좋고, 땀을 많이 흘리면 몸에 무리가 있다는 신호</span></p></li><li class=\"se-text-list-item\" ><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-f65167aa-d4f1-404b-a940-70f986cb7b4f\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-a4700f8f-cc4f-4aea-8936-88359e905f9c\">외형적으로 체격이 작고 약해 보이며 엉덩이는 크지만 상체가 약하고 하체비만형일 수 있음</span></p></li></ul><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-7e133eb5-388d-4730-b964-28a38719e37e\">\n                    <div class=\"se-component-content se-component-content-fit\">\n                        <div class=\"se-section se-section-image se-l-default se-section-align-center\" >\n                                <div class=\"se-module se-module-image\" style=\"\">\n                                    <a href=\"#\" class=\"se-module-image-link __se_image_link __se_link\" style=\"\" onclick=\"return false;\" data-linktype=\"img\" data-linkdata='{\"id\" : \"SE-7e133eb5-388d-4730-b964-28a38719e37e\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northe