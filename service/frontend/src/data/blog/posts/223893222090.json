rizontalLine se-l-line1\" id=\"SE-43232cf4-71d3-4248-9e1d-eadf3072b07f\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-horizontalLine se-l-line1 se-section-align-\">\n                            <div class=\"se-module se-module-horizontalLine\">\n                                <hr class=\"se-hr\" />\n                            </div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-13d8fb54-00f3-41ec-a821-7d3db9afed0c\">\n                    <div class=\"se-component-content se-component-content-fit\">\n                        <div class=\"se-section se-section-image se-l-default se-section-align-center\" >\n                                <div class=\"se-module se-module-image\" style=\"\">\n                                    <a href=\"#\" class=\"se-module-image-link __se_image_link __se_link\" style=\"\" onclick=\"return false;\" data-linktype=\"img\" data-linkdata='{\"id\" : \"SE-13d8fb54-00f3-41ec-a821-7d3db9afed0c\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/e65d80b6089cabb2.png\", \"originalWidth\" : \"1500\", \"originalHeight\" : \"1500\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                                        <img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/e65d80b6089cabb2.png\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/e65d80b6089cabb2.png\" data-width=\"500\" data-height=\"500\" alt=\"\" class=\"se-image-resource\" />\n                                    </a>\n                                </div>\n                        </div>\n                    </div>\n                    <script type=\"text/data\" class=\"__se_module_data\" data-module-v2='{\"type\": \"v2_image\", \"id\": \"SE-13d8fb54-00f3-41ec-a821-7d3db9afed0c\", \"data\": {\"ctype\": \"image\", \"ai\": \"false\" }}'></script>\n                </div>\n                <div class=\"se-component se-quotation se-l-quotation_line\" id=\"SE-36f1bffa-b635-40c4-b6de-3a03a474dd3c\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-quotation se-l-quotation_line\">\n                            <blockquote class=\"se-quotation-container\">\n                                <div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-d28669cf-ed36-4968-986c-3070f604b742\"><span style=\"\" class=\"se-fs-fs24 se-ff-   \" id=\"SE-a53a1270-a74a-4194-bf44-282c267eed9b\"><b>부항이란?</b></span></p><!-- } SE-TEXT --></div>\n                            </blockquote>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"se-component se-text se-l-default\" id=\"SE-1543efac-6541-4187-bdbf-3f91f547c7ff\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n                                    <!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-556ed0a0-1a9b-4fcc-a9b4-90c981a61450\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-82360be6-976b-4e98-a743-7083ab4faf8a\">부항(附缸)은 특수한 컵 모양의 기구를 피부에 부착하여 </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-f781b518-c98a-4842-bae5-b44bdfbbfcc5\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-ca85a07e-0346-47f3-bed3-180ff1a662a1\"><b>피부와 피하 조직의 순환을 촉진하는 한방 치료법</b></span><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-b26e228e-4cc8-492e-a24c-f1f300966491\">입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-111e10e9-61cc-4aad-85fa-0a0f2bf7f97e\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-b2c2fa51-0d46-47a9-9b95-d6837b2cc1ec\">진공상태를 만들어 음압(吸引)으로 피부를 당김으로써 </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-b9949eec-0747-4a7a-87e5-a0213144ac0e\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-7ebf30f1-f48f-4dfe-93bb-c90a0827407e\"><b>어혈 제거, 혈액순환 개선, 통증 완화</b></span><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-2179fced-7b69-4e42-850f-b657f4d153ed\"> 등에 효과가 있습니다.</span></p><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                    <script type=\"text/data\" class=\"__se_module_data\" data-module-v2='{\"type\": \"v2_text\", \"id\": \"SE-1543efac-6541-4187-bdbf-3f91f547c7ff\", \"data\": {\"ctype\": \"text\"  }}'></script>\n                </div>                <div class=\"se-component se-horizontalLine se-l-line1\" id=\"SE-56259553-ba61-4263-aa7c-dffacdd00d01\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-horizontalLine se-l-line1 se-section-align-\">\n                            <div class=\"se-module se-module-horizontalLine\">\n                                <hr class=\"se-hr\" />\n                            </div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-quotation se-l-quotation_line\" id=\"SE-e77e609d-db14-4ad4-81e2-b63f46b206b5\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-quotation se-l-quotation_line\">\n                            <blockquote class=\"se-quotation-container\">\n                                <div class=\"se-module se-module-text se-quote\"><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-8a92c32d-815f-46fe-af33-27bfad527819\"><span style=\"\" class=\"se-fs-fs24 se-ff-   \" id=\"SE-e98f4913-2f55-49a8-b60e-cd40ac57f048\"><b>어떤 증상에 도움이 될까?</b></span></p><!-- } SE-TEXT --></div>\n                            </blockquote>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"se-component se-text se-l-default\" id=\"SE-b48a476c-ed4d-479c-8b44-2dc741ba5bad\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n                                    <!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-69f4c526-c1bb-49c0-88ad-7f580024e108\"><span style=\"\" class=\"se-fs-fs15 se-ff-system   \" id=\"SE-43626a03-e30d-49f9-9ff6-da7f99669300\"><b>​</b></span><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-edf7cf0c-2f6d-46c8-81d7-2a5c2c5f7525\"><b>등과 어깨가 뻐근하고 피로가 쌓였을 때</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-03928e5b-fc74-44ce-9d05-5481837ebe23\"><span style=\"color:#333333;background-color:#ffffff;\" class=\"se-fs-fs15 se-ff-system  se-style-unset \" id=\"SE-e12418c1-0bb7-476b-a1c9-86fd733f29ec\"><b>✔️ </b></span><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-87f7e424-8bda-4428-bbf1-3a361c6ea14d\"><b>근육통, 요통, 담 결림 등 통증 완화가 필요할 때</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-26f6d261-9f79-42b9-8ce6-e78cd290f106\"><span style=\"color:#333333;background-color:#ffffff;\" class=\"se-fs-fs15 se-ff-system  se-style-unset \" id=\"SE-a638e8f3-9006-4005-9e52-32fc1963ef81\"><b>✔️ </b></span><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-c2ac4394-bf3a-4891-b0dd-9d3952bcc615\"><b>스트레스로 인해 몸이 무겁고 불편할 때</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-cdeec72d-2526-44d8-a917-8ba9bb9566d5\"><span style=\"color:#333333;background-color:#ffffff;\" class=\"se-fs-fs15 se-ff-system  se-style-unset \" id=\"SE-c7ce469e-dc3e-4313-9e63-64f6473ace72\"><b>✔️ </b></span><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-b6465e1a-21a0-4b75-b4fb-2b25a21b7eff\"><b>감기 초기나 면역력 저하 시, 한방적인 몸 상태 정리용</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-a90faa90-e7af-461c-8e8a-46673198f103\"><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-b5f172e5-e9c6-4ff4-b50c-ea3a20e94331\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-8cbea9a9-8dc8-4727-bf7c-5a8552d71589\"><span style=\"\" class=\"se-fs- se-ff-system   \" id=\"SE-2258798a-7a75-4172-9363-f87115720e51\">실제로 많은 환자분들이 “부항 받고 나면 몸이 한결 가벼워진다”고 이야기하세요.</span></p><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                    <script type=\"text/data\" class=\"__se_module_data\" data-module-v2='{\"type\": \"v2_text\", \"id\": \"SE-b48a476c-ed4d-479c-8b44-2dc741ba5bad\", \"data\": {\"ctype\": \"text\"  }}'></script>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-8a7ada47-b28d-4d58-869b-d704dea618c9\">\n                    <div class=\"se-component-content se-component-content-normal\">\n                        <div class=\"se-section se-section-image se-l-default se-section-align-center\" style=\"max-width:344px;\">\n                                <div class=\"se-module se-module-image\" style=\"\">\n                                    <a href=\"#\" class=\"se-module-image-link __se_image_link __se_link\" style=\"\" onclick=\"return false;\" data-linktype=\"img\" 