  "body": "<div id=\"post-view220819163388\" class=\" pcol2 _param(1) _postViewArea220819163388\">\n\t\t\t\t\t\t\t<div style=\"font-size:10pt; font-family:'957317_10';\" class=\"view\"><div id=\"SEDOC-1474619155903-1789561614\" class=\"se_doc_viewer se_body_wrap se_theme_transparent \" data-docversion=\"1.0\">\n<div class=\"se_doc_header_start\" id=\"SEDOC-1474619155903-1789561614_se_doc_header_start\"></div>\n<!-- SE_DOC_HEADER_START -->\n<div id=\"SEDOC-1474619155903-1789561614_viewer_head\" class=\"se_viewer_head\"></div>\n<div class=\"se_component_wrap\">\n<div class=\"se_component se_documentTitle documentTitle_blog  is-fill\">\n    <div class=\"se_sectionArea is-fill se_align-left\">\n        <!-- --> \n<div class=\"blog2_series\">\n\t<a href=\"/PostList.naver?blogId=isuhani&categoryNo=12&from=postList\" class=\"pcol2\" onclick=\"sendClickNlog('pst.category','');\">통증질환</a>\n</div>\n<div class=\"pcol1\"> \n<!--\n -->\n        <!-- SE_DOC_HEADER_TITLE_TOP-->\n     \t<div id=\"SEDOC-1474619155903-1789561614_se_doc_title_top\" class=\"se_doc_title_top\"></div>\n        <div class=\"se_editArea\">\n        \t<div class=\"se_viewArea se_ff_nanumgothic se_fs_D2\">\n\t            <div class=\"se_editView se_title\">\n\t                <div class=\"se_textView\">\n                        <h3 class=\"se_textarea\">\n                            <!-- -->부신기능저하증 [남성역 이수한의원]<!-- -->\n                            \n                        </h3>\n\t                </div>\n\t            </div>\n\t        </div>\n        </div><!-- SE_DOC_HEADER_TITLE_MIDDLE-->\n        <div id=\"SEDOC-1474619155903-1789561614_se_doc_title_middle\" class=\"se_doc_title_middle\"></div>\n        <!-- SE_DOC_HEADER_CONTENTS_START -->\n        <!-- -->\n</div>\n<div class=\"blog2_container\">\n    <span class=\"writer\">\n        <span class=\"area_profile\"><a href=\"https://blog.naver.com/isuhani\" class=\"link\" onclick=\"sendClickNlog('pst.profile', '');\" target=\"_top\"><img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/9967affe77f2e25b.jpg\" class=\"img\" alt=\"프로파일\"></a></span>\n        <span class=\"nick\"><a href=\"https://blog.naver.com/isuhani\" class=\"link pcol2\" onclick=\"sendClickNlog('pst.username', '');\" target=\"_top\">문학진 나효석 원장</a></span>\n        <span class=\"desc\">\n            <i class=\"dot\"> ・ </i>\n            <span class=\"se_publishDate pcol2\">2016. 9. 23. 17:25</span>\n        </span>\n    </span>\n\n</div>\n<div class=\"blog2_post_function\">\n\t<a href=\"#\" id=\"copyBtn_220819163388\" class=\"url pcol2 _setClipboard _returnFalse _se3copybtn _transPosition\" title=\"https://blog.naver.com/isuhani/220819163388\" style=\"cursor:pointer;\" >URL 복사</a>\n\n            <a href=\"#\" class=\"btn_buddy btn_addbuddy pcol2 _buddy_popup_btn _returnFalse _rosRestrictAll\" onclick=\"sendClickNlog('pst.addnei', '');\"><i class=\"ico\"></i> 이웃추가<i class=\"aline\"></i></a>\n\t<div class=\"overflow_menu\" >\n        <a href=\"#\" class=\"btn_overflow_menu _open_overflowmenu pcol2 _param(220819163388) _returnFalse\" role=\"button\" area-haspopup=\"true\" area-expanded=\"false\"><span class=\"blind\">본문 기타 기능</span></a>\n\t\t<div id=\"overflowmenu-220819163388\" class=\"lyr_overflow_menu _overflowmenu_layer\" area-hidden=\"true\">\n               <a href=\"#\" onclick=\"window.nsc='blog.post';return false;\" id=\"_title_spiButton\" class=\"naver-splugin btn_splugin share _title_share\"\n                  data-style=\"unity\"\n                  data-url=\"https://blog.naver.com/isuhani/220819163388\"\n                  data-oninitialize=\"splugin_oninitialize(1);\"\n                  data-me-display=\"off\"\n                  data-likeServiceId=\"BLOG\"\n                  data-likeContentsId=\"isuhani_220819163388\"\n                  data-spic-cid=\"220819163388\"\n                  data-logDomain=\"https://proxy.blog.naver.com/spi/v1/api/shareLog\"\n                  data-canonical-url=\"https://blog.naver.com/isuhani/220819163388\"\n                  data-option=\"{baseElement:'_title_spiButton', layerPosition:'outside-bottom', align:'right', marginLeft:0, marginTop:4}\">\n                   공유하기\n                <span class=\"ico_share _title_share_icon\"></span>\n               </a>\n                <a href=\"#\" class=\"_report _param(https://srp2.naver.com/report?svc=BLG&exit=close&ctype=AA01&cwriterenc=Wrla0wnJSHIpt9CAvle63oXtlBnPL0AYLwT8NCsdcBg%3D&ctitle=%EB%B6%80%EC%8B%A0%EA%B8%B0%EB%8A%A5%EC%A0%80%ED%95%98%EC%A6%9D%20%5B%EB%82%A8%EC%84%B1%EC%97%AD%20%EC%9D%B4%EC%88%98%ED%95%9C%EC%9D%98%EC%9B%90%5D&cwriter=isuh***&dark=disable&memtype=Y&env=pc&cnickname=isuh***&vsvc=BLG&cid=isuhani%40%4049462061%40%40mylog%40%40220819163388) _returnFalse\">신고하기<span class=\"ico_report\"></span></a>\n\t\t</div>\n\t</div>\n    <input type=\"text\" value=\"https://blog.naver.com/isuhani/220819163388\" alt=\"url\" class=\"copyTargetUrl\" style=\"display:none;\" title=\"URL 복사\">\n</div>\n<!--\n -->\n        <!-- SE_DOC_HEADER_CONTENTS_END -->\n        <!-- SE_DOC_HEADER_TITLE_BOTTOM-->\n        <div id=\"SEDOC-1474619155903-1789561614_se_doc_title_bottom\" class=\"se_doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1474619155903-1789561614_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1474619155903-1789561614_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n<div class=\"se_component se_image default\">\n    <div class=\"se_sectionArea se_align-justify\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea\" >\n                <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1474619155903-1789561614_image_0_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/f43d5b480e3c2e4b.jpg\", \"linkUse\" : \"false\",\"link\" : \"\"}'>\n                    <img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/f43d5b480e3c2e4b.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/f43d5b480e3c2e4b.jpg\" data-width=\"525\" data-height=\"669\" width=\"525\" height=\"669\" data-attachment-id=\"I4h-ZCbpQnnyOCwB25NFUuu-5Evw\" alt=\"\" class=\"se_mediaImage __se_img_el\" id=\"SEDOC-1474619155903-1789561614_image_0_img\">\n                </a>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->부신은 스트레스와 밀접한 관련이 있는 내분비기관입니다. 양쪽 신장(kidney)의 위에 위치해 있는 부신에서는 항스트레스호르몬인 코티졸(cortisol)을 생산해서 분비하는데, 코티솔의 양이 부족하게 되면 우리 몸은 각종 스트레스에 저항하는 힘이 약해지게 되어 무기력해지게 됩니다. 이러한&nbsp;부신기능의 저하는 전신상태에도 영향을 미치게 되어 공포, 불안, 우울, 무기력증을 보이고 집중력장애와 단기 기억력쇠퇴를 유발하기도 합니다.&nbsp;우리몸을 만성피로의 상태로 몰고 갑니다. <!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n    \n\n\n<div class=\"se_component se_image default\">\n    <div class=\"se_sectionArea se_align-left\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea\" style=\"max-width:297px\">\n                <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1474619155903-1789561614_image_1_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/41fcb8acadf654ca.jpg\", \"linkUse\" : \"false\",\"link\" : \"\"}'>\n                    <img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/41fcb8acadf654ca.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/41fcb8acadf654ca.jpg\" data-width=\"297\" data-height=\"170\" width=\"297\" height=\"170\" data-attachment-id=\"IbMuOU70g1_p-RLOTkEPvSptajFQ\" alt=\"\" class=\"se_mediaImage __se_img_el\" id=\"SEDOC-1474619155903-1789561614_image_1_img\">\n                </a>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>우리가 스트레스에 노출되면 부신은 그 스트레스에 반응하여 과항진됩니다. 코티솔을 많이 생산하고 분비하게 되죠. 이 단계를 스트레스의 경고기(alarm stage)라고 합니다. <br></span><span>스트레스가 단기간에 해소되지 않고 계속 이어지게되면 부신의 기능은 항진과 저하를 반복하는 경향을 보이게 되는데, 이 시기를&nbsp;저항기(resistance stage)라고 합니다. <br></span><span>만성적인 스트레스는 부신의 기능저하를 초래하고 부신에서의 코티솔 생산과 분비가 저하되어 체내 코티솔 양이 부족하게 됩니다. 고갈기(exhaustion stage)라 부르는 이 단계가 되면 다양한 증상들이 나타나게 됩니다. <br></span><span>부신기능저하 시 나타나는 특징들을 살펴보겠습니다. </span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n    \n\n\n<div class=\"se_component se_image default\">\n    <div class=\"se_sectionArea se_align-left\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea\" style=\"max-width:203px\">\n                <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1474619155903-1789561614_image_2_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/bc08e547d3b2a168.jpg\", \"linkUse\" : \"false\",\"link\" : \"\"}'>\n                    <img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/bc08e547d3b2a168.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/bc08e547d3b2a168.jpg\" data-width=\"203\" data-height=\"248\" width=\"203\" height=\"248\" data-attachment-id=\"IN6VCO3OK8NQTPLq0GJSmSYRKX9A\" alt=\"\" class=\"se_mediaImage __se_img_el\" id=\"SEDOC-1474619155903-1789561614_image_2_img\">\n                </a>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>1. 다양한 근육들의 압통이 심해집니다(우리 몸 여기저기를 누르면 통증을 심하게 느끼게 됩니다)<br></span><span>2. 기립성 현훈(앉아있다가 갑자기 일어설 때 생기는 어지럼증)을 유발합니다. <br></span><span>3. 체내수분이 부족해지면서 입안이 건조해지기도 합니다<br></span><span>4. 전중혈(가슴뼈 가운데)를 누르면 매우 아픈 반응이 나타납니다<br></span><span>5. 만성적인 피로감을 느끼게 됩니다. <br></span><span></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n    \n\n\n<div class=\"se_component se_image default\">\n    <div class=\"se_sectionArea se_align-left\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea\" style=\"max-width:500px\">\n                <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1474619155903-1789561614_image_3_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/d6902993c9d5d205.jpg\", \"linkUse\" : \"false\",\"link\" : \"\"}'>\n                    <img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/d6902993c9d5d205.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/d6902993c9d5d205.jpg\" data-width=\"500\" data-height=\"333\" width=\"500\" height=\"333\" data-attachment-id=\"IfE3dulfE8PVr-Da5aubp_lDPzCs\" alt=\"\" class=\"se_mediaImage __se_img_el\" id=\"SEDOC-1474619155903-1789561614_image_3_img\">\n                </a>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>오랜기간 스트레스를 참으면서 생활하다보니 늘 피곤하고, 우울하고, 의욕없고, 여기저기 아프면서 어지럽기도 하는 등의 증상이 생겨서 '맨날 피곤해 주겠다'라고 여겨진다면 부신기능저하를 고려해봐야 하겠습니다. 부신기능저하는 한의학적 접근과 치료가 아주 효과적입니다. 또한 구부정한 자세와 틀어진 척추를 교정해주는 추나요법을 병행하면 더 좋은 효과를 볼 수 있습니다. <br></span><span><br></span><span>남성역 경희이수한의원<br></span><span>02-584-1075</span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n</div>\n<!-- SE_DOC_CONTENTS_END -->\n<div class=\"__se_doc_title_end\" id=\"se_doc_contents_end\"></div>\n<div id=\"SEDOC-1474619155903-1789561614_se_doc_footer\" class=\"se_doc_footer\"></div>\n</div></div>\n\t\t\t\t\t\t</div>",
