97-4eee-9205-74910ed1c15d\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-b9016c96-e412-4553-8b3b-5c9f86060afa\">이 신경들이 손상되면 신경이 분포하는 부위로 통증이 생길 수 있습니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-7f5cb050-66c1-4a1f-a5db-c3242ca3b7fc\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-54cfd1c5-0094-44bd-bd39-8101a3a68d3e\">​</span></p><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-bf8f928b-5847-41e2-a65e-2c56557c22e4\">\n                    <div class=\"se-component-content se-component-content-fit\">\n                        <div class=\"se-section se-section-image se-l-default se-section-align-\" >\n                                <div class=\"se-module se-module-image\" style=\"\">\n                                    <a href=\"#\" class=\"se-module-image-link __se_image_link __se_link\" style=\"\" onclick=\"return false;\" data-linktype=\"img\" data-linkdata='{\"id\" : \"SE-bf8f928b-5847-41e2-a65e-2c56557c22e4\", \"src\" : \"https://max-website20-images.s3.ap-south-1.amazonaws.com/shoulder_pain_what_could_be_reason_1_8273180275.jpg\", \"originalWidth\" : \"6000\", \"originalHeight\" : \"3375\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                                        <img src=\"https://max-website20-images.s3.ap-south-1.amazonaws.com/shoulder_pain_what_could_be_reason_1_8273180275.jpg\" alt=\"\" class=\"se-image-resource\" />\n                                    </a>\n                                </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"se-component se-text se-l-default\" id=\"SE-9e323b50-43d7-4e89-a146-2035850c68c2\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n                                    <!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-cf9eff3f-7d9d-40ea-bf7e-973a9b5dfb94\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-34a66ab7-26f0-4dd8-9e39-04e590231f8a\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-8d45d43d-a732-4b1a-8868-6b96c9dde0e2\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-728f1713-b327-433c-b139-faf7c9fa6050\">빨갛게 표시된 어깨 윗 라인이 아플 때,</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-5facd030-c0f7-4303-a3e0-7f20b63d6fb2\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-b6f55b6c-4c32-4fed-be84-2bf20bc6373d\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-4f6ab1ba-d4cc-4b8e-9bcf-7bf4e1ff5d2e\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-59cda954-0978-4906-9730-7246ebd9673f\">경막통증이 원인이면 목을 치료해야합니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-0c848f44-ce0b-498c-971d-10c65ca64363\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-ae2b8695-58be-47e3-8eed-16006575c0f8\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-bae6aebc-ebbc-495f-9758-1b5c291b253c\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-812830eb-be1d-4987-8e0f-2800ad53e8da\">근육이 문제라면 해당부위 근육을 치료해야 합니다. 그런데 그 근육이 목에서 연결되는 근육입니다. 그래서 목도 치료를 해야해요. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-ddd1a375-7420-4c73-912b-542e3df59d85\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-1d8abc2e-7399-4951-9963-d8f83c088b33\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-994b9bca-c3ca-430c-a231-2ef108ae2cfd\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-6582db1a-3ed4-42fb-8320-3b721cca428e\">신경이 원인이라면 신경이 출발하는 목을 치료해야겠죠?</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-aa73068b-39e7-4360-be5c-d853b39d2f28\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-d3823356-8f29-4557-9ede-f8fb32e6e188\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-6bde7348-5ea1-4cb3-b37f-c6d25afea910\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-99a12994-b581-4c90-989c-0031041ba0a0\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-7ddecde6-b081-41d4-b295-4979648711e3\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-b461dab1-aa11-47e9-a2cb-5e42e53a67ae\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-8a148cb8-bb54-41c0-bff6-1014f5d0fc6c\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-c4424707-81f9-40b3-a9f9-d71894fe4be0\">통증이 있을 때, 통증부위에만 집중하면 안됩니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-86043488-7962-4ea7-913f-883654008956\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-9717ac07-7113-4c0f-b852-e8626f6ffad9\">해당 부위에 통증을 유발할 수 있는 여러가지 원인들을 고려하고, </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-d4c42aed-7cf1-40f6-8ec9-ecc8a63c95cf\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-5908b03b-dafa-4efd-8a0a-02a535fec53c\">이학적 검사와 정확한 진찰을 통해 </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\