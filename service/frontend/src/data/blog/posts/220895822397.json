/isuhani/220895822397\"\n                  data-option=\"{baseElement:'_title_spiButton', layerPosition:'outside-bottom', align:'right', marginLeft:0, marginTop:4}\">\n                   공유하기\n                <span class=\"ico_share _title_share_icon\"></span>\n               </a>\n                <a href=\"#\" class=\"_report _param(https://srp2.naver.com/report?svc=BLG&exit=close&ctype=AA01&cwriterenc=uYGXcfJ4cONRG%2Fsgx%2B%2BtfqrS%2FitVYP%2BqjX%2Bjz0x8QBQ%3D&ctitle=%EB%B0%94%EB%A5%B8%20%EC%9E%90%EC%84%B8%20-%20%EC%B2%B4%ED%98%95(%EC%9E%90%EC%84%B8)%EA%B5%90%EC%A0%95%EC%9D%98%20%ED%95%84%EC%9A%94%EC%84%B1&cwriter=isuh***&dark=disable&memtype=Y&env=pc&cnickname=isuh***&vsvc=BLG&cid=isuhani%40%4049462061%40%40mylog%40%40220895822397) _returnFalse\">신고하기<span class=\"ico_report\"></span></a>\n\t\t</div>\n\t</div>\n    <input type=\"text\" value=\"https://blog.naver.com/isuhani/220895822397\" alt=\"url\" class=\"copyTargetUrl\" style=\"display:none;\" title=\"URL 복사\">\n</div>\n<!--\n -->\n        <!-- SE_DOC_HEADER_CONTENTS_END -->\n        <!-- SE_DOC_HEADER_TITLE_BOTTOM-->\n        <div id=\"SEDOC-1482804986205-46647741_se_doc_title_bottom\" class=\"se_doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1482804986205-46647741_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1482804986205-46647741_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>바른 자세의 정의 </span><span>1974년 미국정형외과 학회에서 일상생활습관 교육을 위한 바른 자세에 대해 내린 정의는 \"자세란 인체 각 부분의 적절한 정렬로 좋은자세(바른 일상생활습관)라 함은 서 있거나 앉아 있거나 몸가짐과는 관계없이 손상 또는 진행성 변형을 방지하기 위하여 인체의 지지구조를 보호하는 근골격의 균형상태를 뜻한다\"고 하였다<br></span><span><br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1482804986205-46647741_image_0_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/2155a3b717cb66ba.jpg\", \"linkUse\" : \"false\",\"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/2155a3b717cb66ba.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/2155a3b717cb66ba.jpg\" data-width=\"806\" data-height=\"1077\" width=\"806\" height=\"1077\" data-attachment-id=\"I2kJZpQ_nmcpu1XvVtz8qkQqvJYI\" alt=\"\" class=\"se_mediaImage __se_img_el\" id=\"SEDOC-1482804986205-46647741_image_0_img\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->바른 일상생활습관, 즉 좋은자세 유지는 근육이나 관절에 부당한 스트레스를 가하지 않으며 균형을 잡거나 운동시에도 최소한의 에너지 소모로 운동을 용이하고 세련되게 만든다. 그러나 나쁜자세(나쁜 일상생활습관)란 인체 각 부분의 결함있는 관계로 인하여 지지구조의 긴장이 증가하게 되며 인체의 균형이 불충분한 상태로, 이는 단순히 심리적 문제뿐 아니라 불편, 동통 변형의 원인이 된다는 것을 알아야 한다. 각 자세가 중요하지만 가장 중요한 자세는 서있는 자세로 선자세를 바르게 유지하기 위해서는 항중력근의 근력과 지구력이 충분하고 자세반사기전이 정상이어야 한다. 이러한 자세유지는 거의 의식하지 않는 차원에서 이루어지며 바른 생활자세를 습관화한 결과로서 생겨난다. <!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-left\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:350px\">\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1482804986205-46647741_image_1_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/31705fe46e82e0db.png\", \"linkUse\" : \"false\",\"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/31705fe46e82e0db.png\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/31705fe46e82e0db.png\" data-width=\"350\" data-height=\"353\" width=\"350\" height=\"353\" data-attachment-id=\"I2rUF2B3R-WOn-NTFcgTF28rlLRA\" alt=\"\" class=\"se_mediaImage __se_img_el\" id=\"SEDOC-1482804986205-46647741_image_1_img\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>따라서 좋은자세를 갖는다는 것은 여러면에서 중요하다. <br></span><span><br></span><span><br></span><span>(요통의 진단과 치료 - 대학서림 -에서 발췌<span>)<br></span><span><br></span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n</div>\n<!-- SE_DOC_CONTENTS_END -->\n<div class=\"__se_doc_title_end\" id=\"se_doc_contents_end\"></div>\n<div id=\"SEDOC-1482804986205-46647741_se_doc_footer\" class=\"se_doc_footer\"></div>\n</div></div>\n\t\t\t\t\t\t</div>",
