68-8962-71701679ecbb\"><span style=\"color:#000000;background-color:#ffffff;\" class=\"se-fs- se-ff-  se-style-unset \" id=\"SE-c1deb1e4-fc75-4865-8987-b668cdeb5558\"><b>저희 </b></span><span style=\"color:#000000;background-color:#fff593;\" class=\"se-fs- se-ff-  se-style-unset \" id=\"SE-61df1a8a-6b27-4d33-915a-e00466663482\"><b>이수한의원</b></span><span style=\"color:#000000;background-color:#ffffff;\" class=\"se-fs- se-ff-  se-style-unset \" id=\"SE-240773a0-0b00-4edf-9cac-f39ff00ac3a7\"><b>에서는 </b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-1431d11b-e084-4abc-982f-4f2bb399c067\"><span style=\"color:#000000;background-color:#ffffff;\" class=\"se-fs- se-ff-  se-style-unset \" id=\"SE-a0b4abc2-9ca9-47ac-9d70-bd274a7fe227\"><b>정품 한약재만을 사용하여 경옥고를 정성껏 조제해드립니다.</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-e4bbd62d-705d-4dc6-b6af-df86f14703e1\"><span style=\"color:#000000;background-color:#ffffff;\" class=\"se-fs- se-ff-  se-style-unset \" id=\"SE-7b8d6b58-21a1-43d6-9d79-2aa5b94758eb\"><b>시중에 판매되는 공장형 제품과 달리, </b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-a130f618-c6b8-47ca-8b80-ac722cc040ca\"><span style=\"color:#000000;background-color:#ffffff;\" class=\"se-fs- se-ff-  se-style-unset \" id=\"SE-1ae0245f-f267-41d5-a82b-826adb6c5aab\"><b>저희는 환자 개개인의 체질과 건강 상태에 맞는 </b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-ba98e61c-d836-4e3e-8a1b-0fd0cc0b8954\"><span style=\"color:#000000;background-color:#ffffff;\" class=\"se-fs- se-ff-  se-style-unset \" id=\"SE-3b218ac9-c27e-4123-99b9-725af4023d5b\"><b>맞춤형 경옥고를 직접 조제하기 때문에</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-2f1deeff-81f8-4710-b1a9-35e9c2635f19\"><span style=\"color:#000000;background-color:#ffffff;\" class=\"se-fs- se-ff-  se-style-unset \" id=\"SE-898d51c9-464d-4125-960b-dfd7973eb5fc\"><b>더 안전하고, 더 효과적인 복용이 가능합니다.</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-38f292a7-c5e1-44d2-ab4f-a3ad5ea24042\"><span style=\"color:#000000;\" class=\"se-fs- se-ff-  se-style-unset \" id=\"SE-6de1fb69-f58c-4ea8-aaf9-977d1af874ce\"><b>​</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-523e5b28-1b79-4c41-bda0-e83e9c44552f\"><span style=\"color:#000000;background-color:#ffffff;\" class=\"se-fs- se-ff-  se-style-unset \" id=\"SE-125a1dcb-10d7-4824-b047-ec880cc96355\"><b>또한, 단순히 경옥고를 처방하는 것에 그치지 않고</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-3238d7f2-68c2-4dc4-bf5c-9562dddfa48b\"><span style=\"color:#000000;background-color:#ffffff;\" class=\"se-fs- se-ff-  se-style-unset \" id=\"SE-68676232-33a3-4ff9-b9fc-ed5df8f7c836\"><b>생활 습관, 식습관, 수면 상태까지 함께 점검하여 건강한 몸으로 회복할 수 있도록 도와드립니다.</b></span></p><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                    <script type=\"text/data\" class=\"__se_module_data\" data-module-v2='{\"type\": \"v2_text\", \"id\": \"SE-99468198-20ce-411e-80f3-96f2df15d19c\", \"data\": {\"ctype\": \"text\"  }}'></script>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-d3bd60a4-9c6f-4f13-87da-354115793664\">\n                    <div class=\"se-component-content se-component-content-fit\">\n                        <div class=\"se-section se-section-image se-l-default se-section-align-\" >\n                                <div class=\"se-module se-module-image\" style=\"\">\n                   