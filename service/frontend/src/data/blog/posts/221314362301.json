in share _title_share\"\n                  data-style=\"unity\"\n                  data-url=\"https://blog.naver.com/isuhani/221314362301\"\n                  data-oninitialize=\"splugin_oninitialize(1);\"\n                  data-me-display=\"off\"\n                  data-likeServiceId=\"BLOG\"\n                  data-likeContentsId=\"isuhani_221314362301\"\n                  data-spic-cid=\"221314362301\"\n                  data-logDomain=\"https://proxy.blog.naver.com/spi/v1/api/shareLog\"\n                  data-canonical-url=\"https://blog.naver.com/isuhani/221314362301\"\n                  data-option=\"{baseElement:'_title_spiButton', layerPosition:'outside-bottom', align:'right', marginLeft:0, marginTop:4}\">\n                   공유하기\n                <span class=\"ico_share _title_share_icon\"></span>\n               </a>\n                <a href=\"#\" class=\"_report _param(https://srp2.naver.com/report?svc=BLG&exit=close&ctype=AA01&cwriterenc=uiUCDRCSqKfP7Db0NYh9LccRkSCamzu%2B54T3BRb36Bc%3D&ctitle=%EC%97%AC%EB%A6%84%EC%97%90%EB%8A%94%20%EB%B3%B4%EC%95%BD%EC%9D%84%20%EB%A8%B9%EB%8A%94%20%EA%B2%8C%20%EC%95%84%EB%8B%88%EB%9D%BC%EA%B5%AC%EC%9A%94%3F&cwriter=isuh***&dark=disable&memtype=Y&env=pc&cnickname=isuh***&vsvc=BLG&cid=isuhani%40%4049462061%40%40mylog%40%40221314362301) _returnFalse\">신고하기<span class=\"ico_report\"></span></a>\n\t\t</div>\n\t</div>\n    <input type=\"text\" value=\"https://blog.naver.com/isuhani/221314362301\" alt=\"url\" class=\"copyTargetUrl\" style=\"display:none;\" title=\"URL 복사\">\n</div>\n<!--\n -->\n        <!-- SE_DOC_HEADER_CONTENTS_END -->\n        <!-- SE_DOC_HEADER_TITLE_BOTTOM-->\n        <div id=\"SEDOC-1530941071062-1622698172_se_doc_title_bottom\" class=\"se_doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1530941071062-1622698172_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1530941071062-1622698172_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>여름에는 보약을 먹으면 땀으로 나오니 보약을 먹는 게 아니라고 알고 계신 분들이 종종 있습니다<span lang=\"EN-US\">. </span>하지만 이것은 과학적으로 말이 안 되는 내용입니다<span lang=\"EN-US\">. </span></span><br> <span lang=\"EN-US\">&nbsp;</span><br> <span>보약은 말 그대로 몸의 허한 부분을 보하는 한약입니다<span lang=\"EN-US\">. </span>다시말해 계절에 상관없이 몸이 허할 때 먹어야 효과도 볼 수 있습니다<span lang=\"EN-US\">.<br></span><span lang=\"EN-US\"></span></span><br> <span>체질적으로 여름이 힘든 사람들이 있습니다<span lang=\"EN-US\">. </span>또한 여름에도 기운내서 공부를 해야 하는 수험생이나 일을 해야하는 직장인들도 있습니다<span lang=\"EN-US\">. </span>땀을 많이 흘리고 체력소모가 많은 여름철의 건강관리는 다른 계절 이상으로 필요합니다<span lang=\"EN-US\">. <br></span><span lang=\"EN-US\"></span></span><br> <span>또한 요즘에는 어디를 가든 시원한 냉방을 가동하고 찬 음식을 많이 먹게 되면서 여름에 한기에 상하게 되는 경우가 많습니다<span lang=\"EN-US\">. </span>속에는 열이 있는데 겉의 한기로 인해 발산이 되지 못하면 두통이나 식욕부진<span lang=\"EN-US\">, </span>권태<span lang=\"EN-US\">, </span>수면장애<span lang=\"EN-US\">, </span>두드러기 등이 생길 수 있습니다<span lang=\"EN-US\">. </span>당장은 시원하게 여름을 보낸 것 같지만 오히려 건강을 해치는 일이 되는 겁니다<span lang=\"EN-US\">.<br></span><span lang=\"EN-US\"><br></span><span lang=\"EN-US\"></span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>여름보약은 </span><span style=\"background-color: rgb(197, 221, 156);\"></span><span style=\"background-color: rgb(197, 221, 156);\">더위에 지쳐 체력이 떨어진 경우</span><span style=\"background-color: rgb(197, 221, 156);\"></span><span>와 </span><span style=\"background-color: rgb(197, 221, 156);\"></span><span style=\"background-color: rgb(171, 208, 114);\"><span style=\"background-color: rgb(197, 221, 156);\">에어컨이나 찬음식의 한기에 상한 경우</span></span><span><span lang=\"EN-US\">, </span></span><span style=\"background-color: rgb(197, 221, 156);\"><span lang=\"EN-US\"><span lang=\"EN-US\" style=\"background-color: rgb(197, 221, 156);\"></span><span style=\"background-color: rgb(197, 221, 156);\">눅눅한 습기에 여기저기 아픈 경우 </span></span></span><span>등 다양한 경우에 처방을 합니다<span lang=\"EN-US\">. </span>각각의 원인과 체질에 맞게 처방이 가능하기 때문에 지치고 힘든 부분을 잘 찾아내 고쳐주고 보해줄 수 있습니다<span lang=\"EN-US\">.</span></span><br><span><br></span><span>여름이 힘든 분들은 여름에 꼭 여름보약을 챙겨 드세요<span lang=\"EN-US\">. </span>다른 해의 여름보다 훨씬 건강하고 활기차게 보낼 수 있고 가을<span lang=\"EN-US\">, </span>겨울의 건강을 미리 예약할 수 있습니다<span lang=\"EN-US\">. </span></span><br><br><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1530941071062-1622698172_image_0_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/1177d70f1c77c4fe.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SED