 \"id\": \"SE-4bdc8c14-5c9a-4ee5-829b-5e06fe1d53d0\", \"data\": {\"ctype\": \"table\", \"columnCount\": \"3\"  }}'></script>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-037f7077-ef8a-41a2-9e87-5d706146ae70\">\n                    <div class=\"se-component-content se-component-content-normal\">\n                        <div class=\"se-section se-section-image se-l-default se-section-align-\" style=\"max-width:251px;\">\n                                <div class=\"se-module se-module-image\" style=\"\">\n                                    <a href=\"#\" class=\"se-module-image-link __se_image_link __se_link\" style=\"\" onclick=\"return false;\" data-linktype=\"img\" data-linkdata='{\"id\" : \"SE-037f7077-ef8a-41a2-9e87-5d706146ae70\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/40dc7ab8bbcefb25.jpg\", \"originalWidth\" : \"251\", \"originalHeight\" : \"201\", \"linkUse\" : \"false\", \"link\" : \"\", \"fileSize\": \"6567\" }'>\n                                        <img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/40dc7ab8bbcefb25.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/40dc7ab8bbcefb25.jpg\" data-width=\"251\" data-height=\"201\" alt=\"\" class=\"se-image-resource\" />\n                                    </a>\n                                </div>\n                        </div>\n                    </div>\n                    <script type=\"text/data\" class=\"__se_module_data\" data-module-v2='{\"type\": \"v2_image\", \"id\": \"SE-037f7077-ef8a-41a2-9e87-5d706146ae70\", \"data\": {\"ctype\": \"image\", \"ai\": \"false\", \"fileSize\": \"6567\" }}'></script>\n                </div>\n                <div class=\"se-component se-text se-l-default\" id=\"SE-91cdf0e1-635e-4390-97f9-91c8a14fb270\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n                                    <!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-496c6c94-8fcf-4169-86f6-9d1680adcc39\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-f59b5eb8-4962-471f-a4a8-cd0aa9f73bdc\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-be01476d-ecff-4782-acef-967064459db0\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-6decd006-3e95-46a0-bc99-fda197440703\"> </span><span style=\"color:#003366;\" class=\"se-fs-fs19 se-ff-system   \" id=\"SE-55781736-000a-4689-8838-6399a805d861\"><b>3. 치료 및 관리법</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-560f4c28-596c-4586-9f30-bcd4ff7a748c\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-c01bb8e0-bf77-4929-8c54-eeddab450f42\">기질적 원인이 있다면 기저 질환(예: 혈당 조절) 관리가 최우선이며, 증상 완화와 미주신경 톤(Vagal tone) 회복을 목표로 접근합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-e9f73e3e-fdb9-4c90-b440-df05add0fd57\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-b38aa929-3182-4dff-8536-526bb4ca7547\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-d1e38a80-d4cf-4f35-be76-887ef7f0fffb\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-269105f9-406c-456f-939f-0a98b8a85d6b\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-b834c4ab-f14a-4c59-94f9-0cca860a3aa9\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-99075283-886d-4a58-b21e-65d1f8373d65\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-09084072-37bb-43e0-8759-8252e6523c70\"><span style=\"color:#006699;\" class=\"se-fs-fs19 se-ff-system   \" id=\"SE-96e266a5-8032-4d14-854d-53742f74a2a1\"><b>증상 치료</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-408f7362-dde9-4b6a-a5ce-e1773c439792\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-22a6bf8f-b784-43bc-9ba5-d333640dbbc8\">·    위장관 운동 촉진제: </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-cf8480d5-2be0-4429-a4d3-a5a97cf3a92c\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-bf417c9f-50b6-4f5d-bd09-88fb8424fd85\">위마비 증상 개선을 위해 도파민 수용체 길항제(Metoclopramide 등)나 5-HT4 수용체 작용제를 제한적으로 사용합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-be957a18-8812-4c23-a857-3eae93fe2eb8\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-432cb7eb-bcb5-4310-a6ee-0a8b595a575b\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-7b759507-842d-409c-ab1f-7de848b6ff12\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-4486f1d1-2531-42f7-80f0-1d53375ef215\">·    변비/설사 조절: </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-4ab67e3d-47e2-4bd3-8fee-b347c1d84077\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-9fc999cb-2174-408d-975b-bfa7fb386342\">삼투성 하제, 지사제, 항경련제 등을 증상에 맞게 투여합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-94ffd184-3198-40e3-a742-235b350f1e34\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-7a469e04-2a9e-4d24-a175-7af0dfd5cf07\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-2870c429-6dad-49fa-8699-1fd2d97d6f0b\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-ef534764-f6be-4e19-822e-bd968390be5e\">·    침구 및 한약 치료: </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-6d455ed8-e323-4066-b3a7-ccdb5c6b070e\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-c19afed2-da26-4642-923b-77aa0e9f2be3\">반하사심탕, 육군자탕 등의 처방과 내관(PC6), 족삼리(ST36) 등의 자침이 미주신경을 자극하고 위장관 운동을 조절하는 데 유효하게 활용됩니다.</span></p><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                    <script type=\"text/data\" class=\"__se_module_data\" data-module-v2='{\"type\": \"v2_text\", \"id\": \"SE-91cdf0e1-635e-4390-97f9-91c8a14fb270\", \"data\": {\"ctype\": \"text\"  }}'></script>\n                </div>                <div class=\"se-component se-image se-l-default\" id=\"SE-788c2663-87fc-4cc2-9e85-d0ecb65b50eb\">\n                    <div class=\"se-component-content se-component-content-normal\">\n                        <div class=\"se-section se-section-image se-l-default se-section-align-\" style=\"max-width:224px;\">\n                                <div class=\"se-module se-module-image\" style=\"\">\n                                    <a href=\"#\" class=\"se-module-image-link __se_image_link __se_link\" style=\"\" onclick=\"return false;\" data-linktype=\"img\" data-linkdata='{\"id\" : \"SE-788c2663-87fc-4cc2-9e85-d0ecb65b50eb\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/4ec459d302b3ed85.jpg\", \"originalWidth\" : \"224\", \"originalHeight\" : \"225\", \"linkUse\" : \"false\", \"link\" : \"\", \"fileSize\": \"11804\" }'>\n                                        <img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/4ec459d302b3ed85.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/4ec459d302b3ed85.jpg\" data-width=\"224\" data-height=\"225\" alt=\"\" class=\"se-image-resource\" />\n                                    </a>\n                                </div>\n                        </div>\n                    </div>\n                    <script type=\"text/data\" class=\"__se_module_data\" data-module-v2='{\"type\": \"v2_image\", \"id\": \"SE-788c2663-87fc-4cc2-9e85-d0ecb65b50eb\", \"data\": {\"ctype\": \"image\", \"ai\": \"false\", \"fileSize\": \"11804\" }}'></script>\n                </div>\n                <div class=\"se-component se-text se-l-default\" id=\"SE-79c16a05-192d-4b70-a118-23660e7eaa92\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n                                    <!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-6c2fcbb9-f00d-41f8-84c8-08fc03d492d6\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-66d490ee-aab8-4212-a187-02571b043dbf\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-e2deb760-ca2b-4b20-91c2-e500a1cb2be1\"><span style=\"color:#006699;\" class=\"se-fs-fs19 se-ff-system   \" id=\"SE-04533dc7-bae1-4231-a02f-8636686c91e3\"><b>식이 및 생활 습관 관리</b></span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-4195b3e5-7afa-4ddb-96ee-48635bbf8aa1\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-e0235208-dee2-4e3c-b133-43d65ad1b77d\">1.     식단 조절: </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-34d7bccd-cd86-4ebc-b9ec-73f7e647c56e\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-5232d7f2-3aef-448a-bc39-3d8cad03165e\">위 배출이 지연되므로 소량씩 자주 섭취하는 것이 중요합니다. 지방과 불용성 식이섬유는 위 정체 시간을 늘리므로 피하고, 소화가 잘 되는 액상이나 반고형식 위주로 구성합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-c117eedc-d786-455c-a085-72a9e90bd538\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-bbb1de6a-272c-4138-96b3-7ce0f803b45a\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-850c655f-5221-4068-be2f-2320f95b81e9\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-f3875caf-bf16-41b6-b32b-2d877d9c11ce\">2.     미주신경 자극 훈련:</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-fa6760ab-7aa2-4ad4-8e72-e3b03915829d\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-5f281339-d141-46bb-8072-e67a2e9c7452\"> - 심호흡(횡격막 호흡): 내쉬는 숨을 길게 하는 호흡법은 부교감신경을 직접적으로 활성화합니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-2b94f610-b3fc-42b9-92f7-4db8aea24026\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-550629f5-af71-461f-aada-2bc572354f65\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-9428ec8d-bb62-4625-9313-e65a731b9e28\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-5848c072-bdd7-49f4-9d16-b83d491a120f\"> - 규칙적인 유산소 운동: 달리기, 마라톤과 같은 규칙적인 지구력 운동은 장기적으로 안정 시 심박수를 낮추고 심박변이도(HRV)를 높여 자율신경의 탄력성을 크게 개선합니다. 단, 급성기나 체력 저하가 심할 때는 강도 조절이 필수적입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-9f1b00ed-fbd1-48d3-8885-076f4389e40a\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-fb35649f-ba69-4309-a0d1-7b78c5d489ee\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-f98e62c1-5d8b-44e2-b857-c86ef4df23a3\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-b4b0ae8a-970e-4e18-b5fc-65559d904565\">3.     스트레스 및 수면 관리: 교감신경 억제를 위해 수면 사이클을 일정하게 유지하는 것이 필수적입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-85875ff3-53e0-4712-9079-8960caa3a5aa\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-4737509b-6a75-4827-99b0-88f2368430d1\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-1a730d3f-ff63-4398-ad69-9a32d908eadc\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-3d2d8955-6aff-40ff-8101-9ed3ceea3c42\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-211325e4-a88b-44a0-bc99-f7214bac83c0\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-e044c9e6-a42b-4794-8a63-fef2f1f20144\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align- \" style=\"\" id=\"SE-5d91fe5e-47a5-434b-a7b1-ee70f4dcc095\"><span style=\"\" class=\"se-fs-fs19 se-ff-   \" id=\"SE-e6489818-cb34-4cef-8dae-a77eebc4436e\"><a href=\"https://booking.naver.com/booking/13/bizes/331349?area&#x3D;pll\" class=\"se-link __se_link\" data-linktype=\"text\" data-linkdata='{\"id\": \"SE-e6489818-cb34-4cef-8dae-a77eebc4436e\", \"link\": \"https://booking.naver.com/booking/13/bizes/331349?area&#x3D;pll\"}' target=\"_blank\">https://booking.naver.com/booking/13/bizes/331349?area&#x3D;pll</a></span></p><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                    <script type=\"text/data\" class=\"__se_module_data\" data-module-v2='{\"type\": \"v2_text\", \"id\": \"SE-79c16a05-192d-4b70-a118-23660e7eaa92\", \"data\": {\"ctype\": \"text\"  }}'></script>\n                </div>                <div class=\"se-component se-oglink se-l-large_image\" id=\"SE-9987d50c-4862-459b-8dbc-511c756b520f\">\n                    <div class=\"se-component-c