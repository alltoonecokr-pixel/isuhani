4-ace6-c732735f610b\">\n                    <div class=\"se-component-content\">\n                        <div class=\"se-section se-section-text se-l-default\">\n                            <div class=\"se-module se-module-text\">\n                                    <!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-3ae10c69-5eb3-4377-9b45-3695908bf373\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-49ca4dba-23f7-4394-9c97-f2ad8478328d\">식습관과 생활습관을 바꾸는 것이 가장 큰 예방책입니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-a0170861-167c-41de-9a94-916b4b3e5d78\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-5bfcaf40-82be-4ae2-bf9f-9a83760594e9\">무엇보다 부모가 먼저 실천할 때 아이도 자연스럽게 변할 수 있습니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-92e62170-901c-424c-924e-336523e0dbe0\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-fd54549f-f5aa-4551-9b78-3887c2a04a66\">작은 습관의 변화가 아이의 평생 건강을 지키는 첫걸음입니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-4c62e3ca-0797-4a71-8655-605914144bfa\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-d0a162bd-bdc4-4a61-93e3-793c6c6b7a8e\">​</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-dd072537-86ef-4154-be95-2366c6b5098c\"><span style=\"background-color:#ffef34;\" class=\"se-fs- se-ff-   \" id=\"SE-c51be70c-6d52-4e66-8783-1a93fc2d4fff\">이수한의원</span><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-13730a78-f3c6-4a53-a23a-c36af1d4ec7f\">은 성장기 아이들의 건강을 위해 </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-56b37cb7-85d9-4d47-a3a4-d8d9f049825f\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-af024ce7-2cdc-4685-a279-8e1519fe53cf\"><b>체중 관리와 교정 치료, 생활 습관 상담</b></span><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-f1e8e65f-681a-4107-820d-97ba54cd6936\">을 함께 진행하고 있습니다. </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-793e44a8-5a88-400c-a03f-6b46b4a73320\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-cde9f33e-433c-4ffe-bec2-e7bae7a5562f\">단순한 체중 감량이 아닌, 올바른 성장과 건강한 미래를 위한 치료가 필요하다면 </span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-f59f7e23-bcd6-476d-bdc9-cbbd1756af37\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-13d9d07e-4feb-4e75-bc4a-a9ecb5a214d8\">전문가의 도움을 받아보시길 권장드립니다.</span></p><!-- } SE-TEXT --><!-- SE-TEXT { --><p class=\"se-text-paragraph se-text-paragraph-align-center \" style=\"\" id=\"SE-8be25de8-4177-4c29-9d47-03d524f95845\"><span style=\"\" class=\"se-fs- se-ff-   \" id=\"SE-3a3b45f0-d089-4ce4-84b6-174d49063d45\">​</span></p><!-- } SE-TEXT -->\n                            </div>\n                        </div>\n                    </div>\n                    <script type=\"text/data\" class=\"__se_module_data\" data-module-v2='{\"type\": \"v2_text\", \"id\": \"SE-542f6309-fc67-4dd4-ace6-c732735f610b\", \"data\": {\"ctype\": \"text\"  }}'></script>\n                </div>                <div class=\"se-component se-video se-l-default\">\n                    <div class=\"se-component-content se-component-content-fit\">\n                        <div class=\"se-section se-section-video se-section-align-center se-l-default\" >\n                            <div class=\"se-module se-module-video\" id=\"SE-a06237df-ac6e-4276-ab00-285a2c835196\">\n                            </div>\n                        </div>\n                    </div>\n                    <script type=\"text/data\" class=\"__se_module_data\" data-module='{\"type\":\"v2_video\", \"id\" :\"SE-a06237df-a