0236--1868313106_image_0_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/74aab947f134ba47.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1541560500236--1868313106_image_0_img\" class=\"se_mediaImage __se_img_el\" src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/74aab947f134ba47.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/74aab947f134ba47.jpg\" data-width=\"299\" data-height=\"168\" width=\"299\" height=\"168\" data-attachment-id=\"IUUC7Yns12iwlaIfNuL0NQkwSaoA\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>오늘은 산후보약에 대해서 궁금해 하시는 내용들을 간단히 정리해보려고 합니다. <br></span><span><br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n\n<div class=\"se_component se_quotation quotation_bubble\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_fs_T3\">\n                <div class=\"se_editView\" >\n                    <div class=\"se_textView\">\n                        <blockquote class=\"se_textarea\"><!-- SE3-TEXT { -->1.&#9;출산후 한약복용은 왜 필요한가요?<!-- } SE3-TEXT --></blockquote>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>&nbsp;</span>임신과 출산을 겪으면서 변화된 <span style=\"background-color: rgb(255, 245, 153);\">자궁의 회복</span>과 <span style=\"background-color: rgb(255, 245, 153);\">오로 배출</span>에 도움이 되어 출산 전의 몸으로 빨리 돌아갈 수 있도록 도와줍니다<span lang=\"EN-US\">. </span>또한 출산 후 생기기 쉬운 기혈부족을 보해 줌으로써 <span style=\"background-color: rgb(255, 245, 153);\">산모의 체력과 면역력을 회복</span>시키는 데 도움이 됩니다<span lang=\"EN-US\">. </span>산모의 기혈상태에 맞춰 맞춤처방을 하여 출산 후에 생길 수 있는 관절통<span lang=\"EN-US\">, </span>시림<span lang=\"EN-US\">, </span>저림이 일어나는 산후풍 예방과 혈액순환과 체액순환을 원활하게 하여 산후부종을 줄여줍니다<span lang=\"EN-US\">. </span>또한<span lang=\"EN-US\">, </span>모유의 양이 부족하지 않게 하는 등 환자의 증상과 체력에 따라 가미해서 처방할 수 있습니다<span lang=\"EN-US\">. <br></span><span lang=\"EN-US\"><br></span><span lang=\"EN-US\"><br></span><span lang=\"EN-US\"><br></span><span lang=\"EN-US\"><br></span><span lang=\"EN-US\"></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n\n<div class=\"se_component se_quotation quotation_bubble\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_fs_T3\">\n                <div class=\"se_editView\" >\n                    <div class=\"se_textView\">\n                        <blockquote class=\"se_textarea\"><!-- SE3-TEXT { -->2.&#9;한약 복용은 출산후 언제부터 시작해야 좋은가요?<!-- } SE3-TEXT --></blockquote>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->여건이 된다면 출산 직후부터 복용하시는 것이 좋습니다<span lang=\"EN-US\">. </span>일반적으로는 초기에는 오로배출과 자궁회복에 초점이 맞추어진 처방을 <span lang=\"EN-US\">10</span>일간 복용하고<span lang=\"EN-US\">, </span>그 뒤로는 산모의 회복에 초점을 두고 <span lang=\"EN-US\">20</span>일 정도 더 처방합니다<span lang=\"EN-US\">. </span>물론 기혈이 많이 부족하고 산후풍 증상이 걱정되는 경우에는 좀더 길게 처방하는 경우도 있습니다<span lang=\"EN-US\">. <span>&nbsp;<br></span><span><br></span><span><br></span><span><br></span><span><br></span><span></span><span></span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n\n<div class=\"se_component se_quotation quotation_bubble\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_fs_T3\">\n                <div class=\"se_editView\" >\n                    <div class=\"se_textView\">\n                        <blockquote class=\"se_textarea\"><!-- SE3-TEXT { -->3.&#9;모유수유 중인데 한약복용이 아기에게  문제가 되지는 않는지요?<!-- } SE3-TEXT --></blockquote>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->모체가 복용한 한약의 기운이 미미한 양이지만 모유수유를 통해 아기에게도 전달이 됩니다<span lang=\"EN-US\">. </span>하지만 출산후 한약은 전통적으로 출산후의 산모에게 특화된 한약처방이며<span lang=\"EN-US\">, </span>모유수유에도 지장이 없도록 구성이 됩니다<span lang=\"EN-US\">. </span>오히려 아이의 성장과 발달에 도움이 되는 성분들이니 걱정하지 마시고 복용하세요<span lang=\"EN-US\">. </span>한약은 수유후에 복용하시는 방법을 권합니다<span lang=\"EN-US\">. <br></span><span lang=\"EN-US\"><span>&nbsp;<br></span><span><br></span><span><br></span><span></span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n\n<div class=\"se_component se_quotation quotation_bubble\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_fs_T3\">\n                <div class=\"se_editView\" >\n                    <div class=\"se_textView\">\n                        <blockquote class=\"se_textarea\"><!-- SE3-TEXT { -->4.&#9;출산 후 가물치즙이나 호박즙, 붕어즙이 산후회복에 <br>도움이 된다는 말이 있던데 정말인가요?<!-- } SE3-TEXT --></blockquote>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span lang=\"EN-US\">&nbsp;</span>흔히 알고 있는 호박즙<span lang=\"EN-US\">, </span>가물치<span lang=\"EN-US\">, </span>붕어즙 등은 성질이 차가워서 부기를 빼는 데는 도움이 되지만 체질에 맞지 않거나 냉한 사람에게는 오히려 독이 될 수 있습니다<span lang=\"EN-US\">. </span>정확한 진료를 받고 산후회복약<span lang=\"EN-US\">, </span>보약을 처방받으시길 바랍니다<span><span lang=\"EN-US\">. <br></span><span lang=\"EN-US\"><br></span><span lang=\"EN-US\"><br></span><span lang=\"EN-US\"><br></span><span lang=\"EN-US\"></span><br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n\n<div class=\"se_component se_quotation quotation_bubble\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_fs_T3\">\n                <div class=\"se_editView\" >\n                    <div class=\"se_textView\">\n                        <blockquote class=\"se_textarea\"><!-- SE3-TEXT { -->5.&#9;산후보약을 먹으면 살이 찔까요? 걱정되요.<!-- } SE3-TEXT --></blockquote>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->실제로 보약을 먹고 살이 찔까봐 걱정하는 분들이 많은데<span lang=\"EN-US\">, </span>기혈과 자궁의 회복을 돕고 순환을 촉진시켜 부종을 치료하므로 임신 전 체중으로 더 빨리 돌아갈 수 있도록 도와줍니다<span lang=\"EN-US\">. <br></span><span lang=\"EN-US\"><br></span><span lang=\"EN-US\"><br></span><span lang=\"EN-US\"></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span><br></span><span><br></span><span>진료를 하다보면 <span lang=\"EN-US\">20</span>대 중후반의 분들임에도 불구하고 출산을 하고나서 관절통<span lang=\"EN-US\">, </span>요통으로 힘들어하는 분들이 많습니다<span lang=\"EN-US\">. </span>이런 분들의 특징은 산후에 몸이 특별히 힘들지 않아 산후조리약<span lang=\"EN-US\">, </span>보약을 복용하지 않았다고 하시는 분들이 많습니다<span lang=\"EN-US\">. </span>이런 증상들이 생기고 난 이후에는 편하게 쉴 수 없는 상황들과 맞물리면서 치료가 좀더 힘듭니다. 산후보약 처방받아서 미리 예방하고 건강한 육아하시길 바랍니다.</span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1541560500236--1868313106_image_1_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/ee34aab458b9b14d.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1541560500236--1868313106_image_1_img\" class=\"se_mediaImage __se_img_el\" src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/ee34aab458b9b14d.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/ee34aab458b9b14d.jpg\" data-width=\"768\" data-height=\"512\" width=\"768\" height=\"512\" data-attachment-id=\"IHG5IR2sXhMy7k1XPGSVvlf6K4ik\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n</div>\n<!-- SE_DOC_CONTENTS_END -->\n<div class=\"__se_doc_title_end\" id=\"se_doc_contents_end\"></div>\n<div id=\"SEDOC-1541560500236--1868313106_se_doc_footer\" class=\"se_doc_footer\"></div>\n</div></div>\n\t\t