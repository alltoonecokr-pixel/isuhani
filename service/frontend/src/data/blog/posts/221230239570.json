                 data-canonical-url=\"https://blog.naver.com/isuhani/221230239570\"\n                  data-option=\"{baseElement:'_title_spiButton', layerPosition:'outside-bottom', align:'right', marginLeft:0, marginTop:4}\">\n                   공유하기\n                <span class=\"ico_share _title_share_icon\"></span>\n               </a>\n                <a href=\"#\" class=\"_report _param(https://srp2.naver.com/report?svc=BLG&exit=close&ctype=AA01&cwriterenc=GK0AZUWUGrFET6Avq5hwbvNxYPJMztY8jwORz6BVhLk%3D&ctitle=%EC%9D%B4%EC%88%98%ED%95%9C%EC%9D%98%EC%9B%90%EC%9D%98%20%EC%A4%91%EC%9D%B4%EC%97%BC%20%EC%B9%98%EB%A3%8C%20%5B%EB%82%A8%EC%84%B1%EC%97%AD%ED%95%9C%EC%9D%98%EC%9B%90%5D&cwriter=isuh***&dark=disable&memtype=Y&env=pc&cnickname=isuh***&vsvc=BLG&cid=isuhani%40%4049462061%40%40mylog%40%40221230239570) _returnFalse\">신고하기<span class=\"ico_report\"></span></a>\n\t\t</div>\n\t</div>\n    <input type=\"text\" value=\"https://blog.naver.com/isuhani/221230239570\" alt=\"url\" class=\"copyTargetUrl\" style=\"display:none;\" title=\"URL 복사\">\n</div>\n<!--\n -->\n        <!-- SE_DOC_HEADER_CONTENTS_END -->\n        <!-- SE_DOC_HEADER_TITLE_BOTTOM-->\n        <div id=\"SEDOC-1521183779400--2049165633_se_doc_title_bottom\" class=\"se_doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1521183779400--2049165633_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1521183779400--2049165633_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><br>&nbsp;<br><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1521183779400--2049165633_image_0_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/c969a1d1bde860c8.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1521183779400--2049165633_image_0_img\" class=\"se_mediaImage __se_img_el\" src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/c969a1d1bde860c8.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/c969a1d1bde860c8.jpg\" data-width=\"550\" data-height=\"422\" width=\"550\" height=\"422\" data-attachment-id=\"IfJlKMttklN0UCiCbmLfwYFMjxVc\" alt=\"\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->&nbsp;<br>&nbsp;<b><span style=\"color: rgb(64, 64, 64);\">삼출성 중이염</span></b><br><i><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\">Otitis media with effusion</span></i><br><i><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\"><span>&nbsp;</span></span></i><br><b><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\"><span>&nbsp;</span></span></b><span style=\"color: rgb(64, 64, 64);\">삼출성 중이염이란 통증이나 발열 등의 급성 증상이 없이<span lang=\"EN-US\">, </span>중이강 내에 삼출액이 고이는 중이염의 일종으로 이는 장액성 중이염<i><span lang=\"EN-US\">serous otitis media</span></i><span lang=\"EN-US\">, </span>점액성 중이염<i><span lang=\"EN-US\">mucoid otitis media</span></i><span lang=\"EN-US\">, Glue ear, Middle ear diffusion </span>등의 동의어로 불리기도 한다.</span><br><span style=\"color: rgb(64, 64, 64);\">항생제의 사용이 빈번한 최근에 오히려 그 빈도는 높아져 유소아에서의 가장 흔한 청력장애의 원인이 되고 있다.</span><br><span style=\"color: rgb(64, 64, 64);\">삼출액이 중이강 안에 고여 있는 기간이 약<span lang=\"EN-US\"> 12 </span>주를 경과하면 만성<i><span lang=\"EN-US\">chronic</span></i>으로 생각한다. <span lang=\"EN-US\">(Bluestone, 1984). </span>소아의<span lang=\"EN-US\"> 20~50%</span>가<span lang=\"EN-US\"> 3~10</span>세 사이에 한 번쯤은 이환되는 것으로 많은 연구들에서 보고하고 있다.<span lang=\"EN-US\">(Fiellau-Nikolajsen, 1983). </span></span><br><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\"><span>&nbsp;</span></span><br><b><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\"><span>1.<span>&nbsp;&nbsp; </span></span></span></b><b><span style=\"color: rgb(64, 64, 64);\">병 인 </span></b><br>&nbsp;<br><span><span style=\"color: rgb(64, 64, 64);\">이관의 기능장애가 중이강의 환기 장애를 일으켜 중이강은 음압상태로 되고<span lang=\"EN-US\">, </span>이 음압상태가 지속되면 고막은 내측으로 함몰되고 중이점막에서는 삼출액이 분비되어 고이게 된다<span lang=\"EN-US\">. </span></span></span><br><span><span style=\"color: rgb(64, 64, 64);\">이러한 이관 기능의 장애를 일으키는 원인으로는 </span></span><br><span><span style=\"color: black;\">① 급성 상기도염<span lang=\"EN-US\">, </span></span></span><br><span><span style=\"color: black;\">② 알레르기<span lang=\"EN-US\">, </span></span></span><br><span><span style=\"color: black;\">③ 아데노이드 증식증<span lang=\"EN-US\">,</span></span></span><br><span><span style=\"color: black;\">④ 만성 부비동염<span lang=\"EN-US\">, </span></span></span><br><span><span style=\"color: black;\">⑤ 구개열 등으로 인한 이관개방의 장애<span lang=\"EN-US\">, </span></span></span><br><span><span style=\"color: black;\">⑥ 종양<span lang=\"EN-US\">, </span></span></span><br><span><span style=\"color: black;\">⑦ 재발성 화농성 중이염<span lang=\"EN-US\">,</span></span></span><br><span><span style=\"color: black;\">⑧ 급격한 기압의 변화<span lang=\"EN-US\"> (barotraumas), </span></span></span><br><span><span style=\"color: black;\">⑨ 전신적 요소<span lang=\"EN-US\"> (</span>갑상선 기능저하증<span lang=\"EN-US\">, </span>당뇨병<span lang=\"EN-US\">) </span>등이 있다<span lang=\"EN-US\">.</span></span></span><br><span lang=\"EN-US\" style=\"color: black;\"><span>&nbsp;</span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-left\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:316px\">\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1521183779400--2049165633_image_1_img\", \"src\" : \"http://blogfiles.naver.net/20110325_294/isuhani_1301032726424gknWd_JPEG/otitis_media_with_effusion__narmal.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1521183779400--2049165633_image_1_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/20110325_294/isuhani_1301032726424gknWd_JPEG/otitis_media_with_effusion__narmal.jpg?type=w580\" width=\"316\" height=\"159\" data-attachment-id=\"\" alt=\"\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->&nbsp;<br>&nbsp;<b><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\"><span>2.<span>&nbsp;&nbsp; </span></span></span></b><b><span style=\"color: rgb(64, 64, 64);\">진 단</span></b><br><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\"><span>&nbsp;</span></span><br><span style=\"color: rgb(64, 64, 64);\">삼출성 중이염은 급성 증상이 없으므로 조기 진단이 어려울 수 있다<span lang=\"EN-US\">. </span>난청 증상과 고막소견<span lang=\"EN-US\">, </span>그리고 청력검사 등으로 진단한다<span lang=\"EN-US\">.</span></span><br><b><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\"><span>&nbsp;</span></span></b><br><b><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\"><span><span>(1)</span><span>&nbsp; </span></span></span></b><span><b><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\"><span>&nbsp;</span></span></b><b><span style=\"color: rgb(64, 64, 64);\">임상양상</span></b></span><br><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\"><span>&nbsp;</span></span><br><span><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\">TV </span><span style=\"color: rgb(64, 64, 64);\">소리를 크게 높여 듣는다든지<span lang=\"EN-US\">, </span>수업 중 주의산만 등의 청력장애의 신호가 될 수 있으며<span lang=\"EN-US\">, </span>학교에서의 정기 신체검사에서 우연히 발견되기도 한다<span lang=\"EN-US\">. </span></span></span><br><b><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\"><span>&nbsp;</span></span></b><br><b><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\"><span><span>(2)</span><span>&nbsp; </span></span></span></b><span><b><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\"><span>&nbsp;</span></span></b><b><span style=\"color: rgb(64, 64, 64);\">이학적 검사</span></b></span><br><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\"><span>&nbsp;</span></span><br><span style=\"color: rgb(64, 64, 64);\">이학적 검사로는<span lang=\"EN-US\"> pneumatic otoscopy </span>가 가장 중요하게 이용되며 고막의 가동성 감소와 다음과 같은 특징적인 고막소견을 관찰할 수 있다<span lang=\"EN-US\">. </span></span><br><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\"><span>&nbsp;</span></span><br><span lang=\"EN-US\" style=\"color: black;\"><span><span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; </span></span></span><span><span style=\"color: black;\">① 내함<i><span lang=\"EN-US\">retraction</span></i>되어 광택소실</span></span><br><span lang=\"EN-US\" style=\"color: black;\"><span><span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; </span></span></span><span><span style=\"color: black;\">② 황갈색<i><span lang=\"EN-US\">amber color</span></i>이나 회백색 혼탁<span lang=\"EN-US\">, </span>석회 침착<span lang=\"EN-US\">, </span>반흔성 비후</span></span><br><span lang=\"EN-US\" style=\"color: black;\"><span><span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; </span></span></span><span><span style=\"color: black;\">③ 추골 단돌기의 돌출</span></span><br><span lang=\"EN-US\" style=\"color: black;\"><span><span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; </span></span></span><span><span style=\"color: black;\">④ 추골병이 짧아져 보임 </span></span><br><span lang=\"EN-US\" style=\"color: black;\"><span><span>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; </span></span></span><span><span style=\"color: black;\">⑤ 삼출액선<i><span lang=\"EN-US\">fluid level</span></i>이나 기포</span></span><br><span lang=\"EN-US\" style=\"color: black;\"><span>&nbsp;</span></span><br><span style=\"color: black;\">성인에서 특히 일측성 삼출성 중이염이 있는 경우에는 비인강검사<span lang=\"EN-US\">, </span>경부촉진 등을 반드시 시행하여 이관의 구강 입구부 주위의 종괴 유무를 확인하여야 한다<span lang=\"EN-US\">.</span></span><br><span lang=\"EN-US\" style=\"color: black;\"><span>&nbsp;</span></span><br><b><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\"><span><span>(3)</span><span>&nbsp; </span></span></span></b><span><b><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\"><span>&nbsp;</span></span></b><b><span style=\"color: rgb(64, 64, 64);\">청력 검사</span></b></span><br><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\"><span>&nbsp;</span></span><br><span style=\"color: rgb(64, 64, 64);\">청력검사상 초기에는 유동적이고<span lang=\"EN-US\">, </span>고음역의 장애가 크나 점차 수평형으로<span lang=\"EN-US\"> 10~40 dB</span>의 전음성 난청소견을 보인다<span lang=\"EN-US\">. </span>임피던스 청력검사<i><span lang=\"EN-US\">impedance audiometry</span></i><span lang=\"EN-US\"> </span>상 저항의 증가 및 고실도에서<span lang=\"EN-US\"> tympanogram B </span>혹은<span lang=\"EN-US\"> C</span>형을 나타낸다<span lang=\"EN-US\">. </span>대부분의 소아 중이염 환아에서 정상적인 와우기능을 가지고 있는 경우가 많으며 기초적인 확인 자료로서 청력검사가 필요하다<span lang=\"EN-US\">. </span>재발성<span lang=\"EN-US\">, </span>지속성의 중이염이나 청력감소가 의심되는 경우에는 조기에 검사 및 처치를 필요로 한다<span lang=\"EN-US\">. </span></span><br><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\"><span>&nbsp;</span></span><br><b><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\"><span><span>(4)</span><span>&nbsp; </span></span></span></b><b><span style=\"color: rgb(64, 64, 64);\">고막천자 </span></b><br><span lang=\"EN-US\" style=\"color: rgb(64, 64, 64);\"><span>&nbsp;</span></span><br><span style=\"color: rgb(64, 64, 64);\">고막천자를 통한 삼출액의 확인으로 진단하기도 한다<span lang=\"EN-US\">. </span>또한 삼출성 중이염에서는 급성 중이염과 유사한 원인균을 발견할 수 있으며 삼출액 모두에서 균 동정이 가능하지만 농성인 경우가 다른 경우보다 확률이 높다<span lang=\"EN-US\">. </span></span><br>&nbsp;<br>: 이상 '일차진료를 위한 이비인후과학임상' 에서 발췌<br>&nbsp;<br>&nbsp;&nbsp;<br><span><br></span><span>이수한의원에 내원하는 아이들 중에는 삼출성 중이염으로 2달 이상 소아과 치료를 받다가</span><span>, 좋아지지 않아서 수술을 하자는 얘기를 듣고 수술을 피해보고자 </span><span>내원하는 경우가 있습니다.</span><span><br><br></span><span>삼출성 중이염은 한방치료로 효과를 잘 보는 질환 중 하나입니다.</span><br><span>한방치료를 하면 짧게는 2-3주 안에, 자꾸 재발했었거나 면역력이 약해 스스로의 치유력이 많이 떨어진 소아의 경우에는 3개월 정도에 깨끗하게 치료가 됩니다. </span><br><span>&nbsp;<br></span><span></span><span>중이염이 1년에 몇차례 재발하거나, 한번 생긴 중이염이 잘 없어지지 않을 </span><span>때엔 </span><span>이수한의원으로 문의하세요.</span><br>&nbsp;<!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-left\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:193px\">\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1521183779400--2049165633_image_2_img\", \"src\" : \"http://blogfiles.naver.net/20110325_210/isuhani_1301033735296xMov5_JPEG/%B0%E6%C8%F1%C0%CC%BC%F6%C7%D1%C0%C7%BF%F8Logo-%C0%A5%BF%EB_%BB%E7%C0%CC%C1%EE_%C3%E0%BC%D2.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1521183779400--2049165633_image_2_img\" class=\"se_mediaImage __se_img_el\" src=\"https://postfiles.pstatic.net/20110325_210/isuhani_1301033735296xMov5_JPEG/%B0%E6%C8%F1%C0%CC%BC%F6%C7%D1%C0%C7%BF%F8Logo-%C0%A5%BF%EB_%BB%E7%C0%CC%C1%EE_%C3%E0%BC%D2.jpg?type=w580\" width=\"193\" height=\"48\" data-attachment-id=\"\" alt=\"\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n</div>\n<!-- SE_DOC_CONTENTS_END -->\n<div class=\"__se_doc_title_end\" id=\"se_doc_contents_end\"></div>\n<div id=\"SEDOC-1521183779400--2049165633_se_doc_footer\" class=\"se_doc_footer\"></div>\n</div></div>\n\t\t\t\t\t\t</div>",
