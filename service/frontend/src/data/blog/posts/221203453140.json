  "body": "<div id=\"post-view221203453140\" class=\" pcol2 _param(1) _postViewArea221203453140\">\n\t\t\t\t\t\t\t<div style=\"font-size:10pt; font-family:'957317_10';\" class=\"view\"><div id=\"SEDOC-1518065622545-1702553035\" class=\"se_doc_viewer se_body_wrap se_theme_transparent \" data-docversion=\"\">\n<div class=\"se_doc_header_start\" id=\"SEDOC-1518065622545-1702553035_se_doc_header_start\"></div>\n<!-- SE_DOC_HEADER_START -->\n<div id=\"SEDOC-1518065622545-1702553035_viewer_head\" class=\"se_viewer_head\"></div>\n<div class=\"se_component_wrap\">\n<div class=\"se_component se_documentTitle documentTitle_blog  is-fill\">\n    <div class=\"se_sectionArea is-fill se_align-left\">\n        <!-- --> \n<div class=\"blog2_series\">\n\t<a href=\"/PostList.naver?blogId=isuhani&categoryNo=24&from=postList\" class=\"pcol2\" onclick=\"sendClickNlog('pst.category','');\">불임, 임신과출산</a>\n</div>\n<div class=\"pcol1\"> \n<!--\n -->\n        <!-- SE_DOC_HEADER_TITLE_TOP-->\n     \t<div id=\"SEDOC-1518065622545-1702553035_se_doc_title_top\" class=\"se_doc_title_top\"></div>\n        <div class=\"se_editArea\">\n        \t<div class=\"se_viewArea se_ff_nanumgothic se_fs_D2\">\n\t            <div class=\"se_editView se_title\">\n\t                <div class=\"se_textView\">\n                        <h3 class=\"se_textarea\">\n                            <!-- -->습관성 유산 [이수한의원 남성역한의원 사당동한의원]<!-- -->\n                            \n                        </h3>\n                        \n                        \n\t                </div>\n\t            </div>\n\t        </div>\n        </div><!-- SE_DOC_HEADER_TITLE_MIDDLE-->\n        <div id=\"SEDOC-1518065622545-1702553035_se_doc_title_middle\" class=\"se_doc_title_middle\"></div>\n        <!-- SE_DOC_HEADER_CONTENTS_START -->\n        <!-- -->\n</div>\n<div class=\"blog2_container\">\n    <span class=\"writer\">\n        <span class=\"area_profile\"><a href=\"https://blog.naver.com/isuhani\" class=\"link\" onclick=\"sendClickNlog('pst.profile', '');\" target=\"_top\"><img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/9967affe77f2e25b.jpg\" class=\"img\" alt=\"프로파일\"></a></span>\n        <span class=\"nick\"><a href=\"https://blog.naver.com/isuhani\" class=\"link pcol2\" onclick=\"sendClickNlog('pst.username', '');\" target=\"_top\">문학진 나효석 원장</a></span>\n        <span class=\"desc\">\n            <i class=\"dot\"> ・ </i>\n            <span class=\"se_publishDate pcol2\">2018. 2. 7. 18:12</span>\n        </span>\n    </span>\n\n</div>\n<div class=\"blog2_post_function\">\n\t<a href=\"#\" id=\"copyBtn_221203453140\" class=\"url pcol2 _setClipboard _returnFalse _se3copybtn _transPosition\" title=\"https://blog.naver.com/isuhani/221203453140\" style=\"cursor:pointer;\" >URL 복사</a>\n\n            <a href=\"#\" class=\"btn_buddy btn_addbuddy pcol2 _buddy_popup_btn _returnFalse _rosRestrictAll\" onclick=\"sendClickNlog('pst.addnei', '');\"><i class=\"ico\"></i> 이웃추가<i class=\"aline\"></i></a>\n\t<div class=\"overflow_menu\" >\n        <a href=\"#\" class=\"btn_overflow_menu _open_overflowmenu pcol2 _param(221203453140) _returnFalse\" role=\"button\" area-haspopup=\"true\" area-expanded=\"false\"><span class=\"blind\">본문 기타 기능</span></a>\n\t\t<div id=\"overflowmenu-221203453140\" class=\"lyr_overflow_menu _overflowmenu_layer\" area-hidden=\"true\">\n               <a href=\"#\" onclick=\"window.nsc='blog.post';return false;\" id=\"_title_spiButton\" class=\"naver-splugin btn_splugin share _title_share\"\n                  data-style=\"unity\"\n                  data-url=\"https://blog.naver.com/isuhani/221203453140\"\n                  data-oninitialize=\"splugin_oninitialize(1);\"\n                  data-me-display=\"off\"\n                  data-likeServiceId=\"BLOG\"\n                  data-likeContentsId=\"isuhani_221203453140\"\n                  data-spic-cid=\"221203453140\"\n                  data-logDomain=\"https://proxy.blog.naver.com/spi/v1/api/shareLog\"\n                  data-canonical-url=\"https://blog.naver.com/isuhani/221203453140\"\n                  data-option=\"{baseElement:'_title_spiButton', layerPosition:'outside-bottom', align:'right', marginLeft:0, marginTop:4}\">\n                   공유하기\n                <span class=\"ico_share _title_share_icon\"></span>\n               </a>\n                <a href=\"#\" class=\"_report _param(https://srp2.naver.com/report?svc=BLG&exit=close&ctype=AA01&cwriterenc=GZhsg8oE%2FL2Gk5BGLI1HpaS9b5JQCqEwZbll4zE1mLA%3D&ctitle=%EC%8A%B5%EA%B4%80%EC%84%B1%20%EC%9C%A0%EC%82%B0%20%5B%EC%9D%B4%EC%88%98%ED%95%9C%EC%9D%98%EC%9B%90%20%EB%82%A8%EC%84%B1%EC%97%AD%ED%95%9C%EC%9D%98%EC%9B%90%20%EC%82%AC%EB%8B%B9%EB%8F%99%ED%95%9C%EC%9D%98%EC%9B%90%5D&cwriter=isuh***&dark=disable&memtype=Y&env=pc&cnickname=isuh***&vsvc=BLG&cid=isuhani%40%4049462061%40%40mylog%40%40221203453140) _returnFalse\">신고하기<span class=\"ico_report\"></span></a>\n\t\t</div>\n\t</div>\n    <input type=\"text\" value=\"https://blog.naver.com/isuhani/221203453140\" alt=\"url\" class=\"copyTargetUrl\" style=\"display:none;\" title=\"URL 복사\">\n</div>\n<!--\n -->\n        <!-- SE_DOC_HEADER_CONTENTS_END -->\n        <!-- SE_DOC_HEADER_TITLE_BOTTOM-->\n        <div id=\"SEDOC-1518065622545-1702553035_se_doc_title_bottom\" class=\"se_doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1518065622545-1702553035_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1518065622545-1702553035_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->이수한의원에 부인과 전문의인 나효석 원장님이 진료하고 계신 것은 알고 계시죠<span lang=\"EN-US\">? </span>그래서인지 요즘 부인과 환자들이 늘어나고 있습니다<span lang=\"EN-US\">. </span><br>여러분들에게 도움이 되고자<span lang=\"EN-US\">, </span>한의원에서 치료했을 때 치료효과가 좋은 부인과 질환에 대해서 알아보도록 하겠습니다<span lang=\"EN-US\">. </span><br>오늘은 첫 포스팅으로 한의원에 많이 찾아오시는 부인과 질환 중 습관성 유산에 대해서 알아보도록 하겠습니다<span><span lang=\"EN-US\">.</span><br></span><span><br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1518065622545-1702553035_image_0_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/75a41ab1ad94b0e0.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1518065622545-1702553035_image_0_img\" class=\"se_mediaImage __se_img_el\" src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/75a41ab1ad94b0e0.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/75a41ab1ad94b0e0.jpg\" data-width=\"725\" data-height=\"397\" width=\"725\" height=\"397\" data-attachment-id=\"IDTPQD5dtmE72hT5jF9O8yGdzRxk\" alt=\"\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->부인과 진료를 시작하고나서 양방병원 검사상 이상이 없는데 자꾸 유산이 된다면서 내원하는 환자들을 자주 뵙습니다<span lang=\"EN-US\">. </span>특히 자연유산을<span lang=\"EN-US\"> 2-3</span>번 이상 겪은 분들은 몸과 마음이 많이 지쳐 있게 됩니다<span lang=\"EN-US\">. </span>이런 과정들이 힘들어서 더 이상 임신을 시도하지 않겠다고 하시는 분도 있습니다<span lang=\"EN-US\">. <span>&nbsp;<br></span><span></span></span><br>임신<span lang=\"EN-US\"> 20</span>주 전에 자연유산이 되는 빈도는<span lang=\"EN-US\"> 15-20%</span>로서 생각 외로 높은 발생률을 보입니다<span lang=\"EN-US\">. </span>자연유산이<span lang=\"EN-US\"> 3</span>회이상 반복되는 경우를 습관성 유산이라고 합니다<span lang=\"EN-US\">. </span>첫번째 아기가 자연유산되었을 경우 두번째 자연유산이 될 빈도는<span lang=\"EN-US\"> 22%</span>로서 한번 유산됐다고 해서 다음 임신이 유산이 될 확률이 많이 높아지는 것은 아닙니다<span lang=\"EN-US\">. </span>하지만<span lang=\"EN-US\"> 2</span>회 유산 후의 위험률은<span lang=\"EN-US\"> 26%, 3</span>회 연속 유산 후의 유산률은<span lang=\"EN-US\"> 32%</span>로 유산횟수가 반복될수록 그 위험성은 커집니다<span lang=\"EN-US\">.</span><br>그래서 최근에는<span lang=\"EN-US\"> 2</span>번의 연속적인 유산이라도 산모의 나이가 많거나 임신과정이 힘들었던 경우는 습관성 유산에 대한 검사를 시행하는 경우가 많습니다<span lang=\"EN-US\">. <br></span><span lang=\"EN-US\"></span><br>습관성 유산에 대해서 양방 산부인과에서는 현재까지 명확한 치료법이 없는 것이 현실입니다<span lang=\"EN-US\">. </span>가능성이 있는 질환에 대한 검사를 하고 그런 원인이 밝혀진 경우에는 치료를 하는 정도의 대처를 하고 있지만<span lang=\"EN-US\">, </span>사실 원인 불명인 경우가 많습니다<span lang=\"EN-US\">. </span>양방 산부인과에서 보고 있는 습관성 유산의 원인은 크게 세 가지로 나눌 수 있습니다<span lang=\"EN-US\">. </span>염색체 이상<span lang=\"EN-US\">, </span>호르몬 인자<span lang=\"EN-US\">, </span>해부학적 이상의 세가지 원인이 많고 이 외에 임신부의 감염<span lang=\"EN-US\">, </span>영양결핍증이나 유독성 환경에 노출된 경우에는 면역학적 요인 등이 원인이 될 수 있습니다<span lang=\"EN-US\">. <span>&nbsp;</span><span>&nbsp;</span></span><br>염상체 이상이나 해부학적 이상을 제외한 경우와<span lang=\"EN-US\"> 50%</span>이상에서 발견되는 원인불명의 경우는 한방치료의 효과가 탁월합니다<span lang=\"EN-US\">.</span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1518065622545-1702553035_image_1_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/d64e92b5d70d94da.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1518065622545-1702553035_image_1_img\" class=\"se_mediaImage __se_img_el\" src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/d64e92b5d70d94da.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/d64e92b5d70d94da.jpg\" data-width=\"635\" data-height=\"527\" width=\"635\" height=\"527\" data-attachment-id=\"IU1aDKBx6oGGq5VrxtrB-XA-3Ylo\" alt=\"\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->한의학에서는 자연 유산을 반산<span lang=\"EN-US\">(</span>半産<span lang=\"EN-US\">)</span>이라고 부릅니다<span lang=\"EN-US\">. </span>가지가 말라버려 열매가 익기도 전에 떨어지는 것에 비유를 하고<span lang=\"EN-US\">, </span>가지가 말라버리게 한 원인에 따라 허<span lang=\"EN-US\">, </span>실을 나누고 그 경중을 따져 치료를 하게 됩니다<span lang=\"EN-US\">. <br></span><span lang=\"EN-US\"></span><br>자궁으로 갈 영양분이 부족하거나 온기<span lang=\"EN-US\">(</span>溫氣<span lang=\"EN-US\">)</span>가 부족해 유산이 되는 경우를 허증<span lang=\"EN-US\">(</span>虛症<span lang=\"EN-US\">), </span>일을 많이 하거나 화를 내어 칠정이 상하여 속의 화<span lang=\"EN-US\">(</span>火<span lang=\"EN-US\">)</span>가 동하거나 어혈이나 기체가 생겨 유산이 되는 경우를 실증<span lang=\"EN-US\">(</span>實症<span lang=\"EN-US\">)</span>으로 진단합니다<span lang=\"EN-US\">.&nbsp;</span>각각의 경중에 따라 처방을 내리고 치료를 합니다<span lang=\"EN-US\">. <br></span><span lang=\"EN-US\"></span><br>습관성 유산을 일으키는 가장 빈번한 경우에 대해서 쉽게 설명해 드리겠습니다<span lang=\"EN-US\">. <br></span><span lang=\"EN-US\"><br></span><span lang=\"EN-US\"></span>혈허<span lang=\"EN-US\">(</span>血虛<span lang=\"EN-US\">)</span>는 씨앗이 뿌려지는 땅<span lang=\"EN-US\">(</span>자궁내막<span lang=\"EN-US\">)</span>이 비옥하지 못하여 뿌리 내리는 것이 힘들고 신양허<span lang=\"EN-US\">(</span>腎陽墟<span lang=\"EN-US\">)</span>는 땅<span lang=\"EN-US\">(</span>자궁<span lang=\"EN-US\">)</span>이 차가워서 씨앗이 움트는 것이 힘들어지고 어혈<span lang=\"EN-US\">(</span>瘀血<span lang=\"EN-US\">)</span>은 태아에게 가는 혈액순환을 방해하여 태아에게 산소와 영양이 충분히 공급되지 못하게 합니다<span lang=\"EN-US\">.<br></span><span lang=\"EN-US\"></span><br>보통의 경우는 이런 원인들이 조금씩 혼재되어 있는 경우가 많기 때문에 정확한 진단이 필요합니다<span lang=\"EN-US\">. </span>근본적인 치료를 하지 않고서는 다음번 임신유지에도 실패를 할 수 있기 때문에 적극적인 치료가 필요합니다<span lang=\"EN-US\">.</span><br>이수한의원에서는 유산 후<span lang=\"EN-US\"> 2-3</span>개월 동안 치료를 하고 이후에 임신시도를 해서 건강한 자궁으로 건강한 아이를 잉태할 수 있게 도와드리겠습니다<span lang=\"EN-US\">. </span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n\t\t\t\t\t\t<a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1518065622545-1702553035_image_2_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/a5aa7d74e0f63bba.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n\t\t\t\t\t\t\t<img id=\"SEDOC-1518065622545-1702553035_image_2_img\" class=\"se_mediaImage __se_img_el\" src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/a5aa7d74e0f63bba.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/a5aa7d74e0f63bba.jpg\" data-width=\"640\" data-height=\"480\" width=\"640\" height=