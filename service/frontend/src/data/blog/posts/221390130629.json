inkdata='{\"imgId\" : \"SEDOC-1541131388302-2042157388_image_0_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/1b74733d1456da5a.png\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1541131388302-2042157388_image_0_img\" class=\"se_mediaImage __se_img_el\" src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/1b74733d1456da5a.png\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/1b74733d1456da5a.png\" data-width=\"299\" data-height=\"169\" width=\"299\" height=\"169\" data-attachment-id=\"I26XLty3GZ1msWxZV-DoyyS3a_yM\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->실제 한의원에서 기침환자를 보면 호흡기를 자극하는 원인이 후비루로 인한 것인지<span lang=\"EN-US\">, </span>기관지 자체의 염증에 의한 것인지 감별하는 것이 중요합니다<span lang=\"EN-US\">.<br></span><span lang=\"EN-US\"></span><br> 후비루에 의한 기침의 경우에는 부비동염<span lang=\"EN-US\">(</span>축농증<span lang=\"EN-US\">)</span>이 있는지를 확인해야하고 기관지의 문제에 의한 것이라면 감염성 염증인지<span lang=\"EN-US\">, </span>천식으로 인한 것인지 등을 확인해야합니다<span lang=\"EN-US\">.</span><br> <span lang=\"EN-US\">&nbsp;</span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-left\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:275px\">\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1541131388302-2042157388_image_1_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/d3ffdc57e58b9e41.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1541131388302-2042157388_image_1_img\" class=\"se_mediaImage __se_img_el\" src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/d3ffdc57e58b9e41.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/d3ffdc57e58b9e41.jpg\" data-width=\"275\" data-height=\"183\" width=\"275\" height=\"183\" data-attachment-id=\"ImYydM_CWPc9yQ9kwdV9noHr5_xw\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->일반적으로 병원에서는 감기로 인한 기침의 경우 항시스타민제와 비충혈제거제를 투여하게 됩니다<span lang=\"EN-US\">. </span>각각의 경우 졸음이나 코점막 자극증상 등의 부작용을 가지고 있다고 보고되니 신중한 투여가 필요합니다<span lang=\"EN-US\">.</span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-right\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span class=\"se_fs_T4\">참고</span><span class=\"se_fs_T4\" lang=\"EN-US\">-</span><span class=\"se_fs_T4\">일차진료 한의사를 위한 보험한약입문 이준우 저 </span><br> <span lang=\"EN-US\">&nbsp;</span><span class=\"se_fs_T4\"></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-justify\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span class=\"se_fs_T3\">저희 한의원에서는 기침 환자의 내원시 코와 목</span><span class=\"se_fs_T3\" lang=\"EN-US\">, </span><span class=\"se_fs_T3\">기관지 등을 면밀히 진찰하고 기침의 원인에 따라 </span><span class=\"se_fs_T3\" style=\"background-color: rgb(255, 245, 153);\">소청룡탕</span><span class=\"se_fs_T3\" lang=\"EN-US\">, </span><span class=\"se_fs_T3\" lang=\"EN-US\"></span><span class=\"se_fs_T3\" style=\"background-color: rgb(255, 245, 153);\">형개연교탕</span><span class=\"se_fs_T3\" lang=\"EN-US\">, </span><span class=\"se_fs_T3\" lang=\"EN-US\"></span><span class=\"se_fs_T3\" style=\"background-color: rgb(255, 245, 153);\">맥문동탕</span><span class=\"se_fs_T3\" lang=\"EN-US\">, </span><span class=\"se_fs_T3\" lang=\"EN-US\"></span><span class=\"se_fs_T3\" style=\"background-color: rgb(255, 245, 153);\">삼소음</span><span class=\"se_fs_T3\" lang=\"EN-US\">, </span><span class=\"se_fs_T3\" lang=\"EN-US\"></span><span class=\"se_fs_T3\" style=\"background-color: rgb(255, 245, 153);\">연교패독산 </span><span class=\"se_fs_T3\">등의 감기약을 처방합니다</span><span class=\"se_fs_T3\" lang=\"EN-US\">. </span><span class=\"se_fs_T3\">이 약들은 대부분 보험제재라 가격도 부담스럽지 않고 복용도 간편합니다</span><span class=\"se_fs_T3\" lang=\"EN-US\">. </span><span class=\"se_fs_T3\">또한 효과도 좋으니 한방감기약을 꼭 처방받아보세요</span><span lang=\"EN-US\"><span class=\"se_fs_T3\">. </span><span></span></span><span lang=\"EN-US\"><span>&nbsp;</span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-justify\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->이런 감기약을 처방받고도 증상의 호전이 미진하거나 딱 떨어지지 않는 기침이 오래 간다면 폐의 기운을 보하고 면역을 올리는 맞춤 처방을 하거나 경옥고를 처방하기도 합니다<span lang=\"EN-US\">.</span><br> <span lang=\"EN-US\">&nbsp;</span><br> 오래 가는 기침으로 고생하지 마시고 내원하셔서 진료받아보길 바랍니다<span lang=\"EN-US\">. </span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1541131388302-2042157388_image_2_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/523f04feeff64d88.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1541131388302-2042157388_image_2_img\" class=\"se_mediaImage __se_img_el\" src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/523f04feeff64d88.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/523f04feeff64d88.jpg\" data-width=\"1280\" data-height=\"1156\" width=\"1280\" height=\"1156\" data-attachment-id=\"IaMGd8C3OoYFjR4vSy3ptmDVeWvU\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-right\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n</div>\n<!-- SE_DOC_CONTENTS_END -->\n<div class=\"__se_doc_title_end\" id=\"se_doc_contents_end\"></div>\n<div id=\"SEDOC-1541131388302-2042157388_se_doc_footer\" class=\"se_doc_footer\"></div>\n</div></div>\n\t\t\t\t\t\t</div>",
