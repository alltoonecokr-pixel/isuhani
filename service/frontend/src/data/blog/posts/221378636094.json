  "body": "<div id=\"post-view221378636094\" class=\" pcol2 _param(1) _postViewArea221378636094\">\n\t\t\t\t\t\t\t<div style=\"font-size:10pt; font-family:'957317_10';\" class=\"view\"><div id=\"SEDOC-1539665250886--36945676\" class=\"se_doc_viewer se_body_wrap se_theme_transparent \" data-docversion=\"1.0\">\n<div class=\"se_doc_header_start\" id=\"SEDOC-1539665250886--36945676_se_doc_header_start\"></div>\n<!-- SE_DOC_HEADER_START -->\n<div id=\"SEDOC-1539665250886--36945676_viewer_head\" class=\"se_viewer_head\"></div>\n<div class=\"se_component_wrap\">\n<div class=\"se_component se_documentTitle documentTitle_blog  is-fill\">\n    <div class=\"se_sectionArea is-fill se_align-left\">\n        <!-- --> \n<div class=\"blog2_series\">\n\t<a href=\"/PostList.naver?blogId=isuhani&categoryNo=12&from=postList\" class=\"pcol2\" onclick=\"sendClickNlog('pst.category','');\">통증질환</a>\n</div>\n<div class=\"pcol1\"> \n<!--\n -->\n        <!-- SE_DOC_HEADER_TITLE_TOP-->\n     \t<div id=\"SEDOC-1539665250886--36945676_se_doc_title_top\" class=\"se_doc_title_top\"></div>\n        <div class=\"se_editArea\">\n        \t<div class=\"se_viewArea se_ff_nanumgothic se_fs_D2\">\n\t            <div class=\"se_editView se_title\">\n\t                <div class=\"se_textView\">\n                        <h3 class=\"se_textarea\">\n                            <!-- -->건염(Tendinitis, 힘줄염), 건병증(Tendinosis)<!-- -->\n                            \n                        </h3>\n                        \n                        \n\t                </div>\n\t            </div>\n\t        </div>\n        </div><!-- SE_DOC_HEADER_TITLE_MIDDLE-->\n        <div id=\"SEDOC-1539665250886--36945676_se_doc_title_middle\" class=\"se_doc_title_middle\"></div>\n        <!-- SE_DOC_HEADER_CONTENTS_START -->\n        <!-- -->\n</div>\n<div class=\"blog2_container\">\n    <span class=\"writer\">\n        <span class=\"area_profile\"><a href=\"https://blog.naver.com/isuhani\" class=\"link\" onclick=\"sendClickNlog('pst.profile', '');\" target=\"_top\"><img src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/9967affe77f2e25b.jpg\" class=\"img\" alt=\"프로파일\"></a></span>\n        <span class=\"nick\"><a href=\"https://blog.naver.com/isuhani\" class=\"link pcol2\" onclick=\"sendClickNlog('pst.username', '');\" target=\"_top\">문학진 나효석 원장</a></span>\n        <span class=\"desc\">\n            <i class=\"dot\"> ・ </i>\n            <span class=\"se_publishDate pcol2\">2018. 10. 16. 13:47</span>\n        </span>\n    </span>\n\n</div>\n<div class=\"blog2_post_function\">\n\t<a href=\"#\" id=\"copyBtn_221378636094\" class=\"url pcol2 _setClipboard _returnFalse _se3copybtn _transPosition\" title=\"https://blog.naver.com/isuhani/221378636094\" style=\"cursor:pointer;\" >URL 복사</a>\n\n            <a href=\"#\" class=\"btn_buddy btn_addbuddy pcol2 _buddy_popup_btn _returnFalse _rosRestrictAll\" onclick=\"sendClickNlog('pst.addnei', '');\"><i class=\"ico\"></i> 이웃추가<i class=\"aline\"></i></a>\n\t<div class=\"overflow_menu\" >\n        <a href=\"#\" class=\"btn_overflow_menu _open_overflowmenu pcol2 _param(221378636094) _returnFalse\" role=\"button\" area-haspopup=\"true\" area-expanded=\"false\"><span class=\"blind\">본문 기타 기능</span></a>\n\t\t<div id=\"overflowmenu-221378636094\" class=\"lyr_overflow_menu _overflowmenu_layer\" area-hidden=\"true\">\n               <a href=\"#\" onclick=\"window.nsc='blog.post';return false;\" id=\"_title_spiButton\" class=\"naver-splugin btn_splugin share _title_share\"\n                  data-style=\"unity\"\n                  data-url=\"https://blog.naver.com/isuhani/221378636094\"\n                  data-oninitialize=\"splugin_oninitialize(1);\"\n                  data-me-display=\"off\"\n                  data-likeServiceId=\"BLOG\"\n                  data-likeContentsId=\"isuhani_221378636094\"\n                  data-spic-cid=\"221378636094\"\n                  data-logDomain=\"https://proxy.blog.naver.com/spi/v1/api/shareLog\"\n                  data-canonical-url=\"https://blog.naver.com/isuhani/221378636094\"\n                  data-option=\"{baseElement:'_title_spiButton', layerPosition:'outside-bottom', align:'right', marginLeft:0, marginTop:4}\">\n                   공유하기\n                <span class=\"ico_share _title_share_icon\"></span>\n               </a>\n                <a href=\"#\" class=\"_report _param(https://srp2.naver.com/report?svc=BLG&exit=close&ctype=AA01&cwriterenc=0Womho5dnAgl0Z4hyG6jux5ioFZYPMIrqDm9vLf8nJ0%3D&ctitle=%EA%B1%B4%EC%97%BC(Tendinitis%2C%20%ED%9E%98%EC%A4%84%EC%97%BC)%2C%20%EA%B1%B4%EB%B3%91%EC%A6%9D(Tendinosis)&cwriter=isuh***&dark=disable&memtype=Y&env=pc&cnickname=isuh***&vsvc=BLG&cid=isuhani%40%4049462061%40%40mylog%40%40221378636094) _returnFalse\">신고하기<span class=\"ico_report\"></span></a>\n\t\t</div>\n\t</div>\n    <input type=\"text\" value=\"https://blog.naver.com/isuhani/221378636094\" alt=\"url\" class=\"copyTargetUrl\" style=\"display:none;\" title=\"URL 복사\">\n</div>\n<!--\n -->\n        <!-- SE_DOC_HEADER_CONTENTS_END -->\n        <!-- SE_DOC_HEADER_TITLE_BOTTOM-->\n        <div id=\"SEDOC-1539665250886--36945676_se_doc_title_bottom\" class=\"se_doc_title_bottom\"></div>\n    </div>\n</div>\n\n</div>\n<!-- B2C 상품 -->\n<!-- _BLOG_CONTENTS_HEADER_TAIL -->\n<!-- SE_DOC_HEADER_END -->\n<div class=\"se_doc_header_end\" id=\"SEDOC-1539665250886--36945676_se_doc_header_end\"></div>\n<div class=\"se_doc_contents_start\" id=\"SEDOC-1539665250886--36945676_se_doc_contents_start\"></div>\n<!-- SE_DOC_CONTENTS_START -->\n<div class=\"se_component_wrap sect_dsc __se_component_area\">\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>어깨가 아플때, 발 뒷꿈치가 아플때<br></span><span>회전근개 '건염', 아킬레스 '건염' 때문이라는 소견을 듣는 경우가 있습니다. <br></span><span>건 = Tendon 을 뜻하는 것으로 우리말로 하면 '힘줄'입니다. <br></span><span>근육을 뼈에 연결해주는 질긴 부위죠. <br></span><span>'힘줄'이라는 표현에서 알 수 있듯이 우리가 강한 힘을 내기 위해서는 근육의 발달도 중요하지만 힘줄이 얼마나 강한가도 중요합니다. 근육이 수축하면서 힘을 낼 때, 힘줄이 그 힘을 충분히 이겨내지 못하면 근육이 최대치의 능력발휘를 할 수가 없기 때문이죠. <br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1539665250886--36945676_image_0_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/52b5cfd89949f1e1.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1539665250886--36945676_image_0_img\" class=\"se_mediaImage __se_img_el\" src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/52b5cfd89949f1e1.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/52b5cfd89949f1e1.jpg\" data-width=\"640\" data-height=\"321\" width=\"640\" height=\"321\" data-attachment-id=\"InsGmrmjEyjBS82UbAX0WeEQ3UUU\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t\t\t<div class=\"se_editView\">\n\t\t\t\t\t\t\t\t<div class=\"se_textView se_mediaCaption\">\n                                        <span class=\"se_textarea\">건(Tendon)은 근육과 뼈를 이어주는 역할을 한다</span>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>이런 건(힘줄) 조직에 병이 생겼을 때 <br></span><span>건염(Tendinitis) <br></span><span>혹은<br></span><span>건병증(Tendinosis)<br></span><span>라고 합니다. <br></span><span><br></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>건염(Tendinitis)이란 갑작스럽고 과도한 부하(힘)가 근건 단위(musculotendinous unit)에 가해졌을 때 건의 미세 파열(micro tear)에 의해 발생하는 건 자체의 염증을 뜻합니다. <br></span><span>건병증(Tendinosis)은 만성적인 과사용(overuse)으로 인해 건 자체의 콜라겐의 퇴행성 변화에 의해 발생하는 것으로, 건 손상이 있을 때 휴식을 취하여 건이 치유되는 시간을 주지 않고 반복적인 염좌(strain)처럼 과사용 손상이 지속되었을 때 발생합니다. </span><br><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-left\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:284px\">\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1539665250886--36945676_image_1_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/5496f022a96b6f88.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1539665250886--36945676_image_1_img\" class=\"se_mediaImage __se_img_el\" src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/5496f022a96b6f88.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/5496f022a96b6f88.jpg\" data-width=\"284\" data-height=\"177\" width=\"284\" height=\"177\" data-attachment-id=\"IVT35ALhhEp5KZ9-vapaV-c0JFyI\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>단순하게 말하면 건염(tendinitis)은 건의 급성 염증을 말하고, 건병증(tendinosis)은 과사용에 따른 전형적인 만성 염증을 말하죠.&nbsp; <br></span><span>그러나 임상 현장에서는 일반적으로 구분없이 '건염'이라 통칭되곤 합니다. <br></span><span>여기서 '건염'이라 하면 건 자체의 염증을 의미하는데, 순수한 의미에서의 건염은 매우 드물고, 일반적인 외상으로 건이 경미하게 손상된 경우, 건 자체와 원인 미상의 염증성 반응이 발생한 경우에 '건염'이라 진단하고 있어요. 순수한 '건염'의 확진은 생검에 의하지 않고는 매우 어렵습니다.</span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1539665250886--36945676_image_2_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/5317f35916b6175d.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1539665250886--36945676_image_2_img\" class=\"se_mediaImage __se_img_el\" src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/5317f35916b6175d.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/5317f35916b6175d.jpg\" data-width=\"1280\" data-height=\"720\" width=\"1280\" height=\"720\" data-attachment-id=\"IHW3Cj3xfB-1dAGeHvMtr58MG6SM\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->과사용이나 외상에 의해 건이 마모되거나 부분적인 파열 또는 염증세포의 침윤이 발생하게 되면 -&gt; 건의 퇴행성 변화가 이차적으로 발생하게 되고 -&gt; <span>건의 국소적인 허혈상태가 야기됩니다.&nbsp;<br></span><span>이렇게 어혈상태가 된 건 부위에 칼슘 침착이 일어날 수도 있는데 이는 석회화로 진행될 수 있습니다. <br></span><span>이런 일련의 과정을 통해 건은 약해지고, 경우에 따라 건의 파열이 진행되기도 합니다. <br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>파열된 건의 재생은 젊은 사람일 경우에는 비교적 활발하여 빠르게 치유되지만 중년 이후에는 마모가 심하고 재생의 과정이 늦어집니다. 나이가 들 수록 힘줄의 부상을 조심해야 하겠죠. <br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-left\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:431px\">\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1539665250886--36945676_image_3_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/a472efe17c516a00.png\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1539665250886--36945676_image_3_img\" class=\"se_mediaImage __se_img_el\" src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/a472efe17c516a00.png\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/a472efe17c516a00.png\" data-width=\"431\" data-height=\"579\" width=\"431\" height=\"579\" data-attachment-id=\"IIuSwOQJTcRNGaTYaQPqz6nhv7C0\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { -->석회화 건염은 건 조직에 석회가 침착하게 되고 이로 인해 통증이 유발되는 질환으로 견관절에 가장 흔합니다. 회전근개의 석회 침착의 발생 원인에 대해서는 혈액공급의 장애나 고령에 의한 퇴행성 변화, 석회가 흡수되고 재생되는 과정에서 발생하는 섬유연골화생(fibrocartilagenous metaplasia) 등 다양한 가설이 있으나 아직 명확히 밝혀진 바는 없는 실정입니다. <!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span><br></span><span>건염의 증상<br></span><span>건염 부위의 통증과 때로는 부종과 발적을 동반하며 주위 관절에 전반적인 통증을 유발하기도 합니다. <br></span><span>석회화 건염의 경우 급성기에 조직학적으로 거대세포의 식작용과 부종이 나타나 건 내부의 압력 증가로 심한 통증이 발생하게 됩니다. 통증은 활동시 심해지거나 활동 후 발생하며 건염 증상이 수개월 지속될 경우 건병증으로 진행하기도 합니다. 건염은 급성! 건병증은 만성! 이니까요.<br></span><span></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-left\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:259px\">\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1539665250886--36945676_image_4_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/61b1307cc26ab9f5.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1539665250886--36945676_image_4_img\" class=\"se_mediaImage __se_img_el\" src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/61b1307cc26ab9f5.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/61b1307cc26ab9f5.jpg\" data-width=\"259\" data-height=\"194\" width=\"259\" height=\"194\" data-attachment-id=\"I6A_aMvXlMynezKoUVf3IU3oHKec\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span><br></span><span>건염의 치료<br></span><span>건염 부위의 휴식이 최우선입니다. 안써야 해요.<br></span><span>정형외과 등에서는 소염제를 처방하여 복용케 하겠죠. 건'염' 이니까. 염증을 없애줄 '소염제'가 처방됩니다. <br></span><span>간혹 빠른 효과를 위해 스테로이드 주사를 놓기도 하는데, 스테로이드 주사의 경우 단기 효과는 좋을 수 있으나 장기적 효과에 대해서 부정적인 보고가 있어 신중한 사용이 필요하겠습니다. <br></span><span>하지 부정열, 족부 변형, 체형의 왜곡 등이 있는 경우 보조기 사용을 고려해 볼 수 있습니다. 보조기를 통해 근골격계가 바른 정렬을 얻을 수 있다면 그만큼 건에 실리는 부하를 줄일 수 있어서 치료에 도움이 되겠죠.<br></span><span>체외 충격파 치료, 스트레칭 운동 등도 치료 방법으로 응용이 되고 있으며, 수술은 여러 보존적 치료에 반응하지 않는 경우에 한하여 제한적으로 시도해 볼 수 있겠습니다. <br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-left\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" style=\"max-width:262px\">\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1539665250886--36945676_image_5_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/48b627b182a95949.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1539665250886--36945676_image_5_img\" class=\"se_mediaImage __se_img_el\" src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/48b627b182a95949.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/48b627b182a95949.jpg\" data-width=\"262\" data-height=\"192\" width=\"262\" height=\"192\" data-attachment-id=\"IrFndYebcWuBVURqg3HNXVGS1w_I\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>한의원에서는 힘줄에 연결된 근육을 이완시켜 건(힘줄)에 전해지는 힘을 줄여서 건이 회복될 수 있게 해주는 침치료, 추나요법, 약침요법 등의 치료방법을 사용합니다. <br></span><span>또한 건염 부위에 혈액순환을 증가시켜 건의 허혈상태를 치료하는 습식부항, 침치료, 약침요법, 한약약물요법도 좋은 치료방법입니다. <br></span><span>근골격계의 정렬이 바르지 않아 틀어진 경우에는 척추 관절의 정렬을 바로잡기 위한 추나교정요법으로 근본 원인을 치료해야 합니다.<br></span><span>전신적 위약감으로 인해 부수적으로 발생한 힘줄 약화의 경우 전신 위약감을 해결하기 위한 한약(보약)을 처방합니다. <br></span><span><br></span><span><br></span><span></span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><span>최근 여가활동이 늘고 취미 또는 건강을 위해 운동을 하는 사람들이 늘면서 힘줄 손상으로 인한 건염환자가 많이 내원합니다. 중년이후에도 여전히 활발한 신체활동을 하면서 퇴행된 힘줄에 반복적인 손상이 누적되어 건염(건병증) 증상을 호소하는 분들의 내원도 늘었습니다. <br></span><span>건염일 경우 해당 힘줄을 사용하지 않고 휴식을 취하는게 우선인데, 조금 아파도 참고 운동하면 낫겠지 하는 생각에 참고 계속 사용하다가 증상을 악화시키는 분들도 적지 않습니다. <br></span><span>관절, 힘줄 부위의 통증이 생겼다면 해당 부위의 사용을 자제하고 병원 또는 한의원을 찾아 진료를 받고 적절한 치료를 받으시길 권합니다. 100세 시대, 오랫동안 써야할 건(힘줄)이니 제때 치료해서 기능을 회복시켜야 하지 않겠습니까? </span><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\t\t<div class=\"se_component se_image default\">\n\t\t\t<div class=\"se_sectionArea se_align-justify\">\n\t\t\t\t<div class=\"se_editArea\">\n\t\t\t\t\t<div class=\"se_viewArea\" >\n        <a href=\"#\" onclick=\"return false;\" class=\"se_mediaArea __se_image_link __se_link\" data-linktype=\"img\" data-linkdata='{\"imgId\" : \"SEDOC-1539665250886--36945676_image_6_img\", \"src\" : \"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/668e20e083b15b1a.jpg\", \"linkUse\" : \"false\", \"link\" : \"\"}'>\n                            <img id=\"SEDOC-1539665250886--36945676_image_6_img\" class=\"se_mediaImage __se_img_el\" src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/668e20e083b15b1a.jpg\" data-lazy-src=\"https://isuhani-clinic-data.s3.ap-northeast-2.amazonaws.com/images/legacy/668e20e083b15b1a.jpg\" data-width=\"2670\" data-height=\"651\" width=\"2670\" height=\"651\" data-attachment-id=\"IriWPs7W9a0alqvTh9nmyAuj8PWU\" alt=\"\">\n        \n        </a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n    \n\n\n\n\n\n\n\n\n<div class=\"se_component se_paragraph default\">\n    <div class=\"se_sectionArea\">\n        <div class=\"se_editArea\">\n            <div class=\"se_viewArea se_ff_nanumgothic se_fs_T3 se_align-left\" >\n                <div class=\"se_editView\">\n                    <div class=\"se_textView\">\n                        <p class=\"se_textarea\"><!-- SE3-TEXT { --><!-- } SE3-TEXT --></p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n\n\n\n\n\n\n\n\n\n\n\n\n</div>\n<!-- SE_DOC_CONTENTS_END -->\n<div class=\"__se_doc_title_end\" id=\"se_doc_contents_end\"></div>\n<div id=\"SEDOC-1539665250886--36945676_se_doc_footer\" class=\"se_doc_footer\"></div>\n</div></div>\n\t\t\t\t\t\t</div>",
